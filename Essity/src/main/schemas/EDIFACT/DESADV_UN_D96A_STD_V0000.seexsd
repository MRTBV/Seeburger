                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_5479">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Relation, coded" xml:lang="en">To specify the relationship between two or more items.

Note:

Code values to be provided.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element maxOccurs="10" minOccurs="0" name="SG3">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="RFF-DTM" xml:lang="en">A group of segments giving references relevant only to the specified party rather than the whole message.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:SegmentGroup">
                                        <xsd:sequence>
                                          <xsd:element maxOccurs="1" minOccurs="1" name="RFF">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="REFERENCE" xml:lang="en">A segment for referencing documents relating to the party specified by the NAD segment.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element name="C506">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="REFERENCE" xml:lang="en">Identification of a reference.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element name="_1153">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Reference qualifier" xml:lang="en">Code giving specific meaning to a reference segment or a reference number.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_1154">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Reference number" xml:lang="en">Identification number the nature and function of which can be qualified by an entry in data element 1153 Reference qualifier.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="35"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_1156">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Line number" xml:lang="en">Number of the line in the document/message referenced in 1154 Reference number.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="6"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_4000">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Reference version number" xml:lang="en">To uniquely identify a reference by its revision number.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="35"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="1" minOccurs="0" name="DTM">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">A segment for specifying Date/time/period of the referred document.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element name="C507">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">Date and/or time, or period relevant to the specified date/time/period type.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element name="_2005">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Date/time/period qualifier" xml:lang="en">Code giving specific meaning to a date, time or period.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_2380">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Date/time/period" xml:lang="en">The value of a date, a date and time, a time or of a period in a specified representation.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="35"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_2379">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Date/time/period format qualifier" xml:lang="en">Specification of the representation of a date, a date and time or of a period.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element maxOccurs="10" minOccurs="0" name="SG4">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="CTA-COM" xml:lang="en">A group of segments to identify the people, functions, departments and appropriate numbers to whom communication should be directed.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:SegmentGroup">
                                        <xsd:sequence>
                                          <xsd:element maxOccurs="1" minOccurs="1" name="CTA">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="CONTACT INFORMATION" xml:lang="en">A segment to identify the person, function or department to whom communication should be directed.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_3139">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Contact function, coded" xml:lang="en">Code specifying the function of a contact (e.g. department or person).</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="C056">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="DEPARTMENT OR EMPLOYEE DETAILS" xml:lang="en">Code and/or name of a department or employee. Code preferred.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element minOccurs="0" name="_3413">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Department or employee identification" xml:lang="en">Internal identification code.

Note:

Code specified by organisation concerned.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="17"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_3412">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Department or employee" xml:lang="en">The department or person within an organizational entity.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="35"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="5" minOccurs="0" name="COM">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="COMMUNICATION CONTACT" xml:lang="en">A segment to identify communication types and numbers for the person, function or department identified in the CTA.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element name="C076">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="COMMUNICATION CONTACT" xml:lang="en">Communication number of a department or employee in a specified channel.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element name="_3148">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Communication number" xml:lang="en">The communication number.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="512"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element name="_3155">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Communication channel qualifier" xml:lang="en">Code identifying the type of communication channel being used.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="10" minOccurs="0" name="SG5">
                        <xsd:annotation>
                          <xsd:documentation bic:title="TOD-LOC-FTX" xml:lang="en">A group of segments indicating terms of delivery.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:SegmentGroup">
                              <xsd:sequence>
                                <xsd:element maxOccurs="1" minOccurs="1" name="TOD">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="TERMS OF DELIVERY OR TRANSPORT" xml:lang="en">A segment indicating the terms of delivery and transfer for the whole despatch advice.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element minOccurs="0" name="_4055">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Terms of delivery or transport function, coded" xml:lang="en">Indication whether the terms relate to e.g. price conditions, delivery conditions, transport conditions, or a combination of these.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_4215">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Transport charges method of payment, coded" xml:lang="en">Identification of method of payment for transport charges.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C100">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="TERMS OF DELIVERY OR TRANSPORT" xml:lang="en">Terms of delivery or transport code from a specified source.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_4053">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Terms of delivery or transport, coded" xml:lang="en">Identification of the terms agreed between two parties (e.g. seller/buyer, shipper/carrier) under which a product or service is provided.

Note:

Use UN/ECE Recommendation No. 5 Incoterms 1990.  If not applicable, use appropriate code set in combination with 1131/3055.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_4052">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Terms of delivery or transport" xml:lang="en">Terms agreed between two parties (e.g. seller/buyer, shipper/carrier) under which a product or service is provided.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="70"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_4052">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Terms of delivery or transport" xml:lang="en">Terms agreed between two parties (e.g. seller/buyer, shipper/carrier) under which a product or service is provided.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="70"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element maxOccurs="5" minOccurs="0" name="LOC">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="PLACE/LOCATION IDENTIFICATION" xml:lang="en">A segment indicating locations relevant to the TOD segment.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element name="_3227">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Place/location qualifier" xml:lang="en">Code identifying the function of a location.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C517">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="LOCATION IDENTIFICATION" xml:lang="en">Identification of a location by code or name.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_3225">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Place/location identification" xml:lang="en">Identification of the name of place/location, other than 3164 City name.

Note:

Use UN/ECE Recommendation No. 16: UNLOCODE.  If not applicable, use appropriate code set in combination with 1131/3055.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="25"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3224">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Place/location" xml:lang="en">Name of place/location, other than 3164 City name.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="70"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C519">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="RELATED LOCATION ONE IDENTIFICATION" xml:lang="en">Identification the first related location by code or name.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_3223">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Related place/location one identification" xml:lang="en">Specification of the first related place/location by code.

Note:

Use UN/ECE Recommendation No. 16: UNLOCODE.  If not applicable, use appropriate code set in combination with 1131/3055.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="25"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3222">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Related place/location one" xml:lang="en">Specification of the first related place/location by name.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="70"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C553">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="RELATED LOCATION TWO IDENTIFICATION" xml:lang="en">Identification of second related location by code or name.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_3233">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Related place/location two identification" xml:lang="en">Specification of a second related place/location by code.

Note:

Use UN/ECE Recommendation No. 16: UNLOCODE.  If not applicable, use appropriate code set in combination with 1131/3055.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="25"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3232">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Related place/location two" xml:lang="en">Specification of a second related place/location by name.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="70"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_5479">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Relation, coded" xml:lang="en">To specify the relationship between two or more items.

Note:

Code values to be provided.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element maxOccurs="5" minOccurs="0" name="FTX">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="FREE TEXT" xml:lang="en">Additional free text pertinent to terms of delivery. In computer to computer exchanges such text will normally require the receiver to process this segment manually.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element name="_4451">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Text subject qualifier" xml:lang="en">Code specifying subject of a free text.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_4453">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Text function, coded" xml:lang="en">Code specifying how to handle the text.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C107">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="TEXT REFERENCE" xml:lang="en">Coded reference to a standard text and its source.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element name="_4441">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Free text identification" xml:lang="en">Free text in coded form.

Note:

User or association defined code.  May be used in combination with 1131/3055.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="17"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C108">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="TEXT LITERAL" xml:lang="en">Free text; one to five lines.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element name="_4440">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Free text" xml:lang="en">Free text field available to the message sender for information.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="70"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_4440">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Free text" xml:lang="en">Free text field available to the message sender for information.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="70"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_4440">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Free text" xml:lang="en">Free text field available to the message sender for information.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="70"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_4440">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Free text" xml:lang="en">Free text field available to the message sender for information.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="70"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_4440">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Free text" xml:lang="en">Free text field available to the message sender for information.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="70"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_3453">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Language, coded" xml:lang="en">Code of language (ISO 639-1988).

Note:

Use ISO 639-1988.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="10" minOccurs="0" name="SG6">
                        <xsd:annotation>
                          <xsd:documentation bic:title="TDT-PCD-SG7" xml:lang="en">A group of segments specifying details of the mode and means of transport and date/time of departure and destination relevant to the whole despatch advice.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:SegmentGroup">
                              <xsd:sequence>
                                <xsd:element maxOccurs="1" minOccurs="1" name="TDT">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="DETAILS OF TRANSPORT" xml:lang="en">A segment specifying the carriage, and the mode and means of transport of the goods being despatched.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element name="_8051">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Transport stage qualifier" xml:lang="en">Qualifier giving a specific meaning to the transport details.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_8028">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Conveyance reference number" xml:lang="en">Unique reference given by the carrier to a certain journey or departure of a means of transport (generic term).</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="17"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C220">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="MODE OF TRANSPORT" xml:lang="en">Method of transport code or name. Code preferred.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_8067">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Mode of transport, coded" xml:lang="en">Coded method of transport used for the carriage of the goods.

Note:

Use UN/ECE Recommendation No 19.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_8066">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Mode of transport" xml:lang="en">Method of transport used for the carriage of the goods.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="17"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C228">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="TRANSPORT MEANS" xml:lang="en">Code and/or name identifying the type of means of transport.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_8179">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Type of means of transport identification" xml:lang="en">Code defining the type of the means of transport being utilized.

Note:

No international codes available.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="8"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_8178">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Type of means of transport" xml:lang="en">Description of the type of the means of transport being utilized.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="17"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C040">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="CARRIER" xml:lang="en">Identification of a carrier by code and/or by name. Code preferred.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_3127">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Carrier identification" xml:lang="en">Identification of party undertaking or arranging transport of goods between named points.

Note:

User or association defined code.  May be used in combination with 1131/3055.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="17"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3128">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Carrier name" xml:lang="en">Name of party undertaking or arranging transport of goods between named points.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="35"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_8101">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Transit direction, coded" xml:lang="en">Identification of the point of origin and point of direction.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C401">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="EXCESS TRANSPORTATION INFORMATION" xml:lang="en">To provide details of reason for, and responsibility for, use of transportation other than normally utilized.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element name="_8457">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Excess transportation reason, coded" xml:lang="en">Indication of reason for excess transportation.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element name="_8459">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Excess transportation responsibility, coded" xml:lang="en">Indication of responsibility for excess transportation.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_7130">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Customer authorization number" xml:lang="en">Customer provided authorization number to allow supplier to ship goods under specific freight conditions.  This number will be transmitted back to customer in the dispatch advice message.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="17"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C222">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="TRANSPORT IDENTIFICATION" xml:lang="en">Code and/or name identifying the means of transport.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_8213">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Id. of means of transport identification" xml:lang="en">Identification of the means of transport by name or number.

Note:

Use relevant code.  May be used in combination with 1131/3055.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="9"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_8212">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Id. of the means of transport" xml:lang="en">Identification of the means of transport by name or number.

Note:

Use relevant code.  May be used in combination with 1131/3055.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="35"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_8453">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Nationality of means of transport, coded" xml:lang="en">Coded name of the country in which a means of transport is registered.

Note:

Use ISO 3166 alpha two country code.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_8281">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Transport ownership, coded" xml:lang="en">Code indicating the ownership of the means of transport.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element maxOccurs="6" minOccurs="0" name="PCD">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="PERCENTAGE DETAILS" xml:lang="en">A segment specifying the percentage of utilization of the capacity of the means of transport.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element name="C501">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="PERCENTAGE DETAILS" xml:lang="en">Percentage relating to a specified basis.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element name="_5245">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Percentage qualifier" xml:lang="en">Identification of the usage of a percentage.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="0" minOccurs="0" name="_5482">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Percentage" xml:lang="en">Value expressed as a percentage of a specified amount.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:N..">
                                                          <xsd:totalDigits value="10"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_5249">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Percentage basis, coded" xml:lang="en">Indication of the application of a percentage.

Note:

User or association defined code.  May be used in combination with 1131/3055.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element maxOccurs="10" minOccurs="0" name="SG7">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="LOC-DTM" xml:lang="en">A group of segments giving the location and date/time information relative to the transportation.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:SegmentGroup">
                                        <xsd:sequence>
                                          <xsd:element maxOccurs="1" minOccurs="1" name="LOC">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="PLACE/LOCATION IDENTIFICATION" xml:lang="en">A segment indicating locations relevant to the transport specified in the TDT segment.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element name="_3227">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Place/location qualifier" xml:lang="en">Code identifying the function of a location.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="C517">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="LOCATION IDENTIFICATION" xml:lang="en">Identification of a location by code or name.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element minOccurs="0" name="_3225">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Place/location identification" xml:lang="en">Identification of the name of place/location, other than 3164 City name.

Note:

Use UN/ECE Recommendation No. 16: UNLOCODE.  If not applicable, use appropriate code set in combination with 1131/3055.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="25"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_1131">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_3055">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_3224">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Place/location" xml:lang="en">Name of place/location, other than 3164 City name.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="70"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="C519">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="RELATED LOCATION ONE IDENTIFICATION" xml:lang="en">Identification the first related location by code or name.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element minOccurs="0" name="_3223">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Related place/location one identification" xml:lang="en">Specification of the first related place/location by code.

Note:

Use UN/ECE Recommendation No. 16: UNLOCODE.  If not applicable, use appropriate code set in combination with 1131/3055.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="25"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_1131">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_3055">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_3222">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Related place/location one" xml:lang="en">Specification of the first related place/location by name.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="70"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="C553">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="RELATED LOCATION TWO IDENTIFICATION" xml:lang="en">Identification of second related location by code or name.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element minOccurs="0" name="_3233">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Related place/location two identification" xml:lang="en">Specification of a second related place/location by code.

Note:

Use UN/ECE Recommendation No. 16: UNLOCODE.  If not applicable, use appropriate code set in combination with 1131/3055.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="25"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_1131">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_3055">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_3232">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Related place/location two" xml:lang="en">Specification of a second related place/location by name.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="70"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_5479">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Relation, coded" xml:lang="en">To specify the relationship between two or more items.

Note:

Code values to be provided.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="10" minOccurs="0" name="DTM">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">A segment giving the date/time/period information of departure and/or arrival of the transported goods for the specified location.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element name="C507">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">Date and/or time, or period relevant to the specified date/time/period type.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element name="_2005">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Date/time/period qualifier" xml:lang="en">Code giving specific meaning to a date, time or period.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_2380">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Date/time/period" xml:lang="en">The value of a date, a date and time, a time or of a period in a specified representation.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="35"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_2379">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Date/time/period format qualifier" xml:lang="en">Specification of the representation of a date, a date and time or of a period.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="10" minOccurs="0" name="SG8">
                        <xsd:annotation>
                          <xsd:documentation bic:title="EQD-MEA-SEL-EQA-SG9" xml:lang="en">A group of segments providing information relative to the equipment used for the transportation of goods relevant to the whole despatch advice.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:SegmentGroup">
                              <xsd:sequence>
                                <xsd:element maxOccurs="1" minOccurs="1" name="EQD">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="EQUIPMENT DETAILS" xml:lang="en">A segment to define fixed information regarding equipment used in conjunction with the whole despatch advice, and if required, to indicate responsibility for supply of the equipment.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element name="_8053">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Equipment qualifier" xml:lang="en">Code identifying type of equipment.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C237">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="EQUIPMENT IDENTIFICATION" xml:lang="en">Marks (letters and/or numbers) identifying equipment used for transport such as a container.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_8260">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Equipment identification number" xml:lang="en">Marks (letters and/or numbers) which identify equipment e.g. unit load device.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="17"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3207">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Country, coded" xml:lang="en">Identification of the name of a country or other geographical entity as specified in ISO 3166.

Note:

Use ISO 3166 two alpha country code.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C224">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="EQUIPMENT SIZE AND TYPE" xml:lang="en">Code and/or name identifying size and type of equipment used in transport. Code preferred.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_8155">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Equipment size and type identification" xml:lang="en">Coded description of the size and type of equipment e.g. unit load device.

Note:

User or association defined code.  May be used in combination with 1131/3055. See ISO 6346 for seagoing containers.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="10"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_8154">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Equipment size and type" xml:lang="en">Plain language description of the size and type of equipment e.g. unit load device.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="35"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_8077">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Equipment supplier, coded" xml:lang="en">To indicate the party that is the supplier of the equipment.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_8249">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Equipment status, coded" xml:lang="en">Indication of the action related to the equipment.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_8169">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Full/empty indicator, coded" xml:lang="en">To indicate the extent to which the equipment is full or empty.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element maxOccurs="5" minOccurs="0" name="MEA">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="MEASUREMENTS" xml:lang="en">A segment specifying physical measurements of equipment described in the EQD segment.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element name="_6311">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Measurement purpose qualifier" xml:lang="en">Specification of the purpose of the measurement.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C502">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="MEASUREMENT DETAILS" xml:lang="en">Identification of measurement type.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_6313">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Property measured, coded" xml:lang="en">Specification of the property measured.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_6321">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Measurement significance, coded" xml:lang="en">Code specifying the significance of a measurement value.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_6155">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Measurement attribute identification" xml:lang="en">Code used to specify non-discrete measurement values.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="17"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_6154">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Measurement attribute" xml:lang="en">To specify non-discrete measurement values.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="70"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C174">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="VALUE/RANGE" xml:lang="en">Measurement value and relevant minimum and maximum tolerances in that order.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element name="_6411">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Measure unit qualifier" xml:lang="en">Indication of the unit of measurement in which weight (mass), capacity, length, area, volume or other quantity is expressed.

Note:

See UN/ECE Recommendation 20.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_6314">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Measurement value" xml:lang="en">Value of the measured unit.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="18"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="0" minOccurs="0" name="_6162">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Range minimum" xml:lang="en">Minimum of a range.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:N..">
                                                          <xsd:totalDigits value="18"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="0" minOccurs="0" name="_6152">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Range maximum" xml:lang="en">Maximum of a range.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:N..">
                                                          <xsd:totalDigits value="18"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="0" minOccurs="0" name="_6432">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Significant digits" xml:lang="en">To specify the number of significant digits.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:N..">
                                                          <xsd:totalDigits value="2"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_7383">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Surface/layer indicator, coded" xml:lang="en">Code indicating the surface or layer of a product that is being described.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element maxOccurs="25" minOccurs="0" name="SEL">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="SEAL NUMBER" xml:lang="en">A segment specifying a seal number connected to a specific equipment named in the EQD.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element name="_9308">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Seal number" xml:lang="en">The number of a custom seal or another seal affixed to the containers or other transport unit.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="10"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C215">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="SEAL ISSUER" xml:lang="en">Identification of the issuer of a seal on equipment either by code or by name.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_9303">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Sealing party, coded" xml:lang="en">Identification of the issuer of the seal number.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_9302">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Sealing party" xml:lang="en">Clear text, representing the name of the issuer of the seal number.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="35"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_4517">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Seal condition, coded" xml:lang="en">To indicate the condition of a seal.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element maxOccurs="5" minOccurs="0" name="EQA">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="ATTACHED EQUIPMENT" xml:lang="en">A segment identifying equipment either attached to the equipment described in the EQD segment above, or equipment related to that described in the EQD segment, and which is further defined in a subsequent EQD segment.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element name="_8053">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Equipment qualifier" xml:lang="en">Code identifying type of equipment.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C237">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="EQUIPMENT IDENTIFICATION" xml:lang="en">Marks (letters and/or numbers) identifying equipment used for transport such as a container.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_8260">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Equipment identification number" xml:lang="en">Marks (letters and/or numbers) which identify equipment e.g. unit load device.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="17"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
