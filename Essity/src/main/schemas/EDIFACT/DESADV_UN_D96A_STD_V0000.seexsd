                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="4"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_8126">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Trem card number" xml:lang="en">The identification of a transport emergency card giving advice for emergency actions.</xsd:documentation>
                                                                </xsd:annotation>
