                                          </xsd:element>
                                          <xsd:element maxOccurs="1" minOccurs="0" name="TDT">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="DETAILS OF TRANSPORT" xml:lang="en">A segment specifying the carriage, and the mode and means of transport of the goods being despatched, e.g. shipment/consignment number, shipping method, carrier.</xsd:documentation>
                                            </xsd:annotation>
