                                          <xsd:element maxOccurs="5" minOccurs="0" name="DTM">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">A segment providing date, time information related to the line item, e.g. production date.</xsd:documentation>
                                            </xsd:annotation>
