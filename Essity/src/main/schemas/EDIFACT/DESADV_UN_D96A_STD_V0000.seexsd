                                          <xsd:element maxOccurs="9999" minOccurs="0" name="SG20">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="PCI-DTM-MEA-QTY-SG21-SG22" xml:lang="en">A group of segments identifying one specific package or a number of packages, their marks and numbers, measurements, quantities, date and time information and handling instructions.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:SegmentGroup">
                                                  <xsd:sequence>
                                                    <xsd:element maxOccurs="1" minOccurs="1" name="PCI">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="PACKAGE IDENTIFICATION" xml:lang="en">A segment specifying marking and labels used on individual packages or a range of packages.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:Segment">
                                                            <xsd:sequence>
                                                              <xsd:element minOccurs="0" name="_4233">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Marking instructions, coded" xml:lang="en">Code indicating instructions on how specified packages or physical units should be marked.</xsd:documentation>
                                                                </xsd:annotation>
