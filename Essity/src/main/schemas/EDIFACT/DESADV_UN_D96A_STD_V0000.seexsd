                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Hazardous material class code, identification" xml:lang="en">Code specifying the kind of hazard for a material.

Note:

Association defined code.  May be used in combination with 1131/3055.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="4"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_1131">
                                                                <xsd:annotation>
