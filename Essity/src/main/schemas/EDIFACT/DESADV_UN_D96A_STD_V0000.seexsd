                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
