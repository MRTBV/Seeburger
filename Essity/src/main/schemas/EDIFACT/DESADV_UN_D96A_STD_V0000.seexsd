                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_8211">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Permission for transport, coded" xml:lang="en">Code giving evidence that transportation of particular hazardous cargo is permitted and identifies the restrictions being put upon a particular transport.

Note:

Code values to be provided.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element maxOccurs="1" minOccurs="0" name="QTY">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="QUANTITY" xml:lang="en">A segment to specify quantity of the given dangerous goods.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:Segment">
                                                            <xsd:sequence>
                                                              <xsd:element name="C186">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="QUANTITY DETAILS" xml:lang="en">Quantity information in a transaction, qualified when relevant.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="edifact:FieldGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element name="_6063">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Quantity qualifier" xml:lang="en">Code giving specific meaning to a quantity.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" name="_6060">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Quantity" xml:lang="en">Numeric value of a quantity.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:N..">
                                                                              <xsd:totalDigits value="15"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_6411">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Measure unit qualifier" xml:lang="en">Indication of the unit of measurement in which weight (mass), capacity, length, area, volume or other quantity is expressed.

Note:

See UN/ECE Recommendation 20.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element maxOccurs="5" minOccurs="0" name="FTX">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="FREE TEXT" xml:lang="en">A segment to describe dangerous goods.</xsd:documentation>
                                                      </xsd:annotation>
