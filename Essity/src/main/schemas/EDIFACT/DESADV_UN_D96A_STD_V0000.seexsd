                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="70"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
