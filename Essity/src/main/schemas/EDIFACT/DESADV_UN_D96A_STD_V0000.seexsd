                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element maxOccurs="10" minOccurs="0" name="QTY">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="QUANTITY" xml:lang="en">A segment to specify the quantity of unpacked goods being placed in a specific equipment.</xsd:documentation>
                                                      </xsd:annotation>
