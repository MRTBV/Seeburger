                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="17"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="C220">
                                                      <xsd:annotation>
