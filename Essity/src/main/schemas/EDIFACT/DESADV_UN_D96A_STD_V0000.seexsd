                                          <xsd:element maxOccurs="100" minOccurs="0" name="SG18">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="LOC-NAD-DTM-QTY" xml:lang="en">A group of segments giving location information and where relevant, additional addresses, date and time, and quantities.</xsd:documentation>
                                            </xsd:annotation>
