                                          </xsd:element>
                                          <xsd:element maxOccurs="1000" minOccurs="0" name="SG19">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="SGP-QTY" xml:lang="en">A group of segments indicating the split placement of packages or unpacked goods into equipment.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:SegmentGroup">
                                                  <xsd:sequence>
                                                    <xsd:element maxOccurs="1" minOccurs="1" name="SGP">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="SPLIT GOODS PLACEMENT" xml:lang="en">A segment to specify the placement of goods in relation to one equipment. If goods are unpacked, their quantity would be given in the following QTY segment.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:Segment">
                                                            <xsd:sequence>
                                                              <xsd:element name="C237">
                                                                <xsd:annotation>
