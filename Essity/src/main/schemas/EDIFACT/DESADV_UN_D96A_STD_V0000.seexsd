                                </xsd:element>
                                <xsd:element maxOccurs="10" minOccurs="0" name="LOC">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="PLACE/LOCATION IDENTIFICATION" xml:lang="en">A segment indicating more details regarding specific places/locations related to the party specified in the NAD segment, e.g. internal site/building number.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element name="_3227">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Place/location qualifier" xml:lang="en">Code identifying the function of a location.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C517">
                                            <xsd:annotation>
