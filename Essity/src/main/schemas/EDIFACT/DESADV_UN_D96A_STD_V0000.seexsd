                                                              </xsd:element>
                                                              <xsd:element maxOccurs="1000" minOccurs="0" name="GIN">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="GOODS IDENTITY NUMBER" xml:lang="en">A segment providing identification numbers being applied to the packages containing hazardous goods.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="edifact:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element name="_7405">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Identity number qualifier" xml:lang="en">Code specifying the type/source of identity number.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element name="C208">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="IDENTITY NUMBER RANGE" xml:lang="en">Goods item identification numbers, start and end of consecutively numbered range.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:complexType>
                                                                            <xsd:complexContent>
                                                                              <xsd:extension base="edifact:FieldGroup">
                                                                                <xsd:sequence>
                                                                                  <xsd:element name="_7402">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identity number" xml:lang="en">The number given to an object for its unique identification.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="edifact:AN..">
                                                                                        <xsd:length value="35"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element minOccurs="0" name="_7402">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identity number" xml:lang="en">The number given to an object for its unique identification.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="edifact:AN..">
                                                                                        <xsd:length value="35"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="C208">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="IDENTITY NUMBER RANGE" xml:lang="en">Goods item identification numbers, start and end of consecutively numbered range.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:complexType>
                                                                            <xsd:complexContent>
                                                                              <xsd:extension base="edifact:FieldGroup">
                                                                                <xsd:sequence>
                                                                                  <xsd:element name="_7402">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identity number" xml:lang="en">The number given to an object for its unique identification.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="edifact:AN..">
                                                                                        <xsd:length value="35"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element minOccurs="0" name="_7402">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identity number" xml:lang="en">The number given to an object for its unique identification.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="edifact:AN..">
                                                                                        <xsd:length value="35"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="C208">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="IDENTITY NUMBER RANGE" xml:lang="en">Goods item identification numbers, start and end of consecutively numbered range.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:complexType>
                                                                            <xsd:complexContent>
                                                                              <xsd:extension base="edifact:FieldGroup">
                                                                                <xsd:sequence>
                                                                                  <xsd:element name="_7402">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identity number" xml:lang="en">The number given to an object for its unique identification.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="edifact:AN..">
                                                                                        <xsd:length value="35"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element minOccurs="0" name="_7402">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identity number" xml:lang="en">The number given to an object for its unique identification.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="edifact:AN..">
                                                                                        <xsd:length value="35"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="C208">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="IDENTITY NUMBER RANGE" xml:lang="en">Goods item identification numbers, start and end of consecutively numbered range.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:complexType>
                                                                            <xsd:complexContent>
                                                                              <xsd:extension base="edifact:FieldGroup">
                                                                                <xsd:sequence>
                                                                                  <xsd:element name="_7402">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identity number" xml:lang="en">The number given to an object for its unique identification.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="edifact:AN..">
                                                                                        <xsd:length value="35"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element minOccurs="0" name="_7402">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identity number" xml:lang="en">The number given to an object for its unique identification.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="edifact:AN..">
                                                                                        <xsd:length value="35"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="C208">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="IDENTITY NUMBER RANGE" xml:lang="en">Goods item identification numbers, start and end of consecutively numbered range.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:complexType>
                                                                            <xsd:complexContent>
                                                                              <xsd:extension base="edifact:FieldGroup">
                                                                                <xsd:sequence>
                                                                                  <xsd:element name="_7402">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identity number" xml:lang="en">The number given to an object for its unique identification.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="edifact:AN..">
                                                                                        <xsd:length value="35"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element minOccurs="0" name="_7402">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identity number" xml:lang="en">The number given to an object for its unique identification.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="edifact:AN..">
                                                                                        <xsd:length value="35"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="10" minOccurs="0" name="SG23">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="QVR-DTM" xml:lang="en">A group of segments identifying quantity variances, the reason for the variance, and, when relevant, date and time information.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:SegmentGroup">
                                                  <xsd:sequence>
                                                    <xsd:element maxOccurs="1" minOccurs="1" name="QVR">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="QUANTITY VARIANCES" xml:lang="en">A segment identifying a quantity variance and the reason for the variance.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:Segment">
                                                            <xsd:sequence>
                                                              <xsd:element minOccurs="0" name="C279">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="QUANTITY DIFFERENCE INFORMATION" xml:lang="en">Information on quantity difference.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="edifact:FieldGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="0" name="_6064">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Quantity difference" xml:lang="en">Numeric value of variance between ordered/shipped/invoiced quantities.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:N..">
                                                                              <xsd:totalDigits value="15"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_6063">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Quantity qualifier" xml:lang="en">Code giving specific meaning to a quantity.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_4221">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Discrepancy, coded" xml:lang="en">Code defining the disposition of any difference between the quantity ordered and invoiced, or shipped and invoiced for a line item or transaction.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="C960">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="REASON FOR CHANGE" xml:lang="en">Code and/or description of the reason for a change.

Note:

This composite data element replaces composite C262 (which has been deleted in this directory).</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="edifact:FieldGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element minOccurs="0" name="_4295">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Change reason, coded" xml:lang="en">Identification of the reason for a change.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_1131">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_3055">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_4294">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Change reason" xml:lang="en">Description of the reason for a change.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="35"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element maxOccurs="5" minOccurs="0" name="DTM">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">A segment to give date and time information relative to the quantity variances, e.g. proposed delivery date on the back order.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:Segment">
                                                            <xsd:sequence>
                                                              <xsd:element name="C507">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">Date and/or time, or period relevant to the specified date/time/period type.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="edifact:FieldGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element name="_2005">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Date/time/period qualifier" xml:lang="en">Code giving specific meaning to a date, time or period.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_2380">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Date/time/period" xml:lang="en">The value of a date, a date and time, a time or of a period in a specified representation.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="35"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_2379">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Date/time/period format qualifier" xml:lang="en">Specification of the representation of a date, a date and time or of a period.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="5" minOccurs="0" name="CNT">
                        <xsd:annotation>
                          <xsd:documentation bic:title="CONTROL TOTAL" xml:lang="en">A segment by which control totals may be provided by sender for checking by the receiver.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:Segment">
                              <xsd:sequence>
                                <xsd:element name="C270">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="CONTROL" xml:lang="en">Control total for checking integrity of a message or part of a message.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:FieldGroup">
                                        <xsd:sequence>
                                          <xsd:element name="_6069">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Control qualifier" xml:lang="en">Determines the source data elements in the message which forms the basis for 6066 Control value.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element default="0" name="_6066">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Control value" xml:lang="en">Value obtained from summing the values specified by the Control Qualifier throughout the message (Hash total).</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:N..">
                                                <xsd:totalDigits value="18"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_6411">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Measure unit qualifier" xml:lang="en">Indication of the unit of measurement in which weight (mass), capacity, length, area, volume or other quantity is expressed.

Note:

See UN/ECE Recommendation 20.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="1" minOccurs="1" name="UNT">
                        <xsd:annotation>
                          <xsd:documentation bic:title="MESSAGE TRAILER" xml:lang="en">A service segment ending a message, giving the total number of segments in the message and the control reference number of the message.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:Segment">
                              <xsd:sequence>
                                <xsd:element default="0" name="_0074">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Number of segments in a message" xml:lang="en">Control count of number of segments in a message.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:N..">
                                      <xsd:totalDigits value="6"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element name="_0062">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Message reference number" xml:lang="en">Unique message reference assigned by the sender.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="14"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                    </xsd:sequence>
                  </xsd:extension>
                </xsd:complexContent>
              </xsd:complexType>
            </xsd:element>
            <xsd:element maxOccurs="1" minOccurs="1" name="UNZ">
              <xsd:annotation>
                <xsd:documentation bic:title="INTERCHANGE TRAILER" xml:lang="en">To end and check the completeness of an interchange.</xsd:documentation>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:complexContent>
                  <xsd:extension base="edifact:Segment">
                    <xsd:sequence>
                      <xsd:element default="0" name="_0036">
                        <xsd:annotation>
                          <xsd:documentation bic:title="Interchange control count" xml:lang="en">Count either of the number of messages or, if used, of the number of functional groups in an interchange.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:simpleType>
                          <xsd:restriction base="edifact:N..">
                            <xsd:totalDigits value="6"/>
                          </xsd:restriction>
                        </xsd:simpleType>
                      </xsd:element>
                      <xsd:element name="_0020">
                        <xsd:annotation>
                          <xsd:documentation bic:title="Interchange control reference" xml:lang="en">Unique reference assigned by the sender to an interchange.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:simpleType>
                          <xsd:restriction base="edifact:AN..">
                            <xsd:length value="14"/>
                          </xsd:restriction>
                        </xsd:simpleType>
                      </xsd:element>
                    </xsd:sequence>
                  </xsd:extension>
                </xsd:complexContent>
              </xsd:complexType>
            </xsd:element>
          </xsd:sequence>
        </xsd:extension>
      </xsd:complexContent>
    </xsd:complexType>
  </xsd:element>
</xsd:schema>
