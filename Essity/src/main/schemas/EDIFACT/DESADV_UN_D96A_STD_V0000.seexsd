                                          </xsd:element>
                                          <xsd:element maxOccurs="100" minOccurs="0" name="DLM">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="DELIVERY LIMITATIONS" xml:lang="en">A segment to identify any limitation on delivery of goods e.g. hold until final approval by supplier.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element minOccurs="0" name="_4455">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Back order, coded" xml:lang="en">Code to identify the back order agreement.</xsd:documentation>
                                                      </xsd:annotation>
