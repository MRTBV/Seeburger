                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="edifact:FieldGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element minOccurs="0" name="_8158">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Hazard identification number, upper part" xml:lang="en">The id. number for the Orange Placard (upper part) required on the means of transport.</xsd:documentation>
                                                                          </xsd:annotation>
