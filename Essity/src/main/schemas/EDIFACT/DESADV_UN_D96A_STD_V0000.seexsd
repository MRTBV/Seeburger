                                              <xsd:documentation bic:title="RELATED IDENTIFICATION NUMBERS" xml:lang="en">A segment providing sets of related identification numbers for a line item, e.g. engine number, chassis number and transmission number for a vehicle.</xsd:documentation>
                                            </xsd:annotation>
