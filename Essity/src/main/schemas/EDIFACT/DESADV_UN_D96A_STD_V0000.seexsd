                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="5" minOccurs="0" name="NAD">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="NAME AND ADDRESS" xml:lang="en">A segment for identifying names and addresses and their functions relevant to the item, e.g. manufacturer.</xsd:documentation>
                                            </xsd:annotation>
