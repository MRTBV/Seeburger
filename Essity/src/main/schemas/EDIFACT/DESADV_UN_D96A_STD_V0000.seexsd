                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="C210">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="MARKS &amp; LABELS" xml:lang="en">Shipping marks on packages in free text; one to ten lines.</xsd:documentation>
