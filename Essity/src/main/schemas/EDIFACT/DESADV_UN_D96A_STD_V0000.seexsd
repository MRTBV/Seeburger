<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<xsd:schema xmlns:bic="http://www.seeburger.com/bicng/lang/schema/" xmlns:edifact="http://www.seeburger.com/bicng/lang/schema/edifact" xmlns:xsd="http://www.w3.org/2001/XMLSchema" bic:messageType="EDIFACT">
  <xsd:import namespace="http://www.seeburger.com/bicng/lang/schema/edifact" schemaLocation="platform:/plugin/com.seeburger.bicng.lang.schema.facade.edifact/resources/edifact.xsd"/>
  <xsd:element name="DESADV_UN_D96A_STD">
    <xsd:complexType>
      <xsd:complexContent>
        <xsd:extension base="edifact:SegmentGroup">
          <xsd:sequence>
            <xsd:element maxOccurs="1" minOccurs="0" name="UNA">
              <xsd:annotation>
                <xsd:documentation bic:title="SERVICE STRING ADVICE" xml:lang="en">To define the characters selected for use as delimiters and indicators in the rest of the interchange that follows.</xsd:documentation>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:complexContent>
                  <xsd:extension base="edifact:Segment">
                    <xsd:sequence>
                      <xsd:element default="      " name="DELIMITER">
                        <xsd:simpleType>
                          <xsd:restriction base="edifact:A">
                            <xsd:length value="6"/>
                          </xsd:restriction>
                        </xsd:simpleType>
                      </xsd:element>
                    </xsd:sequence>
                  </xsd:extension>
                </xsd:complexContent>
              </xsd:complexType>
            </xsd:element>
            <xsd:element maxOccurs="1" minOccurs="1" name="UNB">
              <xsd:annotation>
                <xsd:documentation bic:title="INTERCHANGE HEADER" xml:lang="en">To start, identify and specify an interchange.</xsd:documentation>
              </xsd:annotation>
              <xsd:complexType>
                <xsd:complexContent>
                  <xsd:extension base="edifact:Segment">
                    <xsd:sequence>
                      <xsd:element name="S001">
                        <xsd:annotation>
                          <xsd:documentation bic:title="SYNTAX IDENTIFIER" xml:lang="en">Identification of the agency controlling the syntax and indication of syntax level</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:FieldGroup">
                              <xsd:sequence>
                                <xsd:element default="    " name="_0001">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Syntax identifier" xml:lang="en">Coded identification of the agency controlling a syntax and syntax level used in an interchange</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:A">
                                      <xsd:length value="4"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element default="0" name="_0002">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Syntax version number" xml:lang="en">Version number of the syntax identified in the syntax identifier (0001)</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:N">
                                      <xsd:totalDigits value="1"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element name="S002">
                        <xsd:annotation>
                          <xsd:documentation bic:title="INTERCHANGE SENDER" xml:lang="en">Identification of the sender of the interchange</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:FieldGroup">
                              <xsd:sequence>
                                <xsd:element name="_0004">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Sender identification" xml:lang="en">Name or coded representation of the sender of a data interchange.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="35"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_0007">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Partner identification code qualifier" xml:lang="en">Qualifier referring to the source of codes for the identifiers of interchanging partners.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="4"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_0008">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Address for reverse routing" xml:lang="en">Address specified by the sender of an interchange to be included by the recipient in the response interchanges to facilitate internal routing.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="14"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element name="S003">
                        <xsd:annotation>
                          <xsd:documentation bic:title="INTERCHANGE RECIPIENT" xml:lang="en">Identification of the recipient of the interchange</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:FieldGroup">
                              <xsd:sequence>
                                <xsd:element name="_0010">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Recipient identification" xml:lang="en">Name or coded representation of the recipient of a data interchange.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="35"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_0007">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Partner identification code qualifier" xml:lang="en">Qualifier referring to the source of codes for the identifiers of interchanging partners.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="4"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_0014">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Routing address" xml:lang="en">Address specified by the recipient of an interchange to be included by the sender and used by the recipient for routing of received interchanges inside his organization.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="14"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element name="S004">
                        <xsd:annotation>
                          <xsd:documentation bic:title="DATE/TIME OF PREPARATION" xml:lang="en">Date/time of preparation of the interchange</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:FieldGroup">
                              <xsd:sequence>
                                <xsd:element default="000000" name="_0017">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Date of preparation" xml:lang="en">Local date when an interchange or a functional group was prepared.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:N">
                                      <xsd:totalDigits value="6"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element default="0000" name="_0019">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Time of preparation" xml:lang="en">Local time of day when an interchange or a functional group was prepared.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:N">
                                      <xsd:totalDigits value="4"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element name="_0020">
                        <xsd:annotation>
                          <xsd:documentation bic:title="Interchange control reference" xml:lang="en">Unique reference assigned by the sender to an interchange.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:simpleType>
                          <xsd:restriction base="edifact:AN..">
                            <xsd:length value="14"/>
                          </xsd:restriction>
                        </xsd:simpleType>
                      </xsd:element>
                      <xsd:element minOccurs="0" name="S005">
                        <xsd:annotation>
                          <xsd:documentation bic:title="RECIPIENT'S REFERENCE PASSWORD" xml:lang="en">Reference or password as agreed between the communicating partners.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:FieldGroup">
                              <xsd:sequence>
                                <xsd:element name="_0022">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Recipient's reference/password" xml:lang="en">Unique reference assigned by the recipient to the data interchange or a password to the recipient's system or to a third party network as specified in the partners interchange agreement.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="14"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element default="  " minOccurs="0" name="_0025">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Recipient's reference/password qualifier" xml:lang="en">Qualifier for the recipient's reference or password.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN">
                                      <xsd:length value="2"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element minOccurs="0" name="_0026">
                        <xsd:annotation>
                          <xsd:documentation bic:title="Application reference" xml:lang="en">Identification of the application area assigned by the sender, to which the messages in the interchange relate e.g. the message identifier if all the messages in the interchange are of the same type.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:simpleType>
                          <xsd:restriction base="edifact:AN..">
                            <xsd:length value="14"/>
                          </xsd:restriction>
                        </xsd:simpleType>
                      </xsd:element>
                      <xsd:element default=" " minOccurs="0" name="_0029">
                        <xsd:annotation>
                          <xsd:documentation bic:title="Processing priority code" xml:lang="en">Code determined by the sender requesting processing priority for the interchange.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:simpleType>
                          <xsd:restriction base="edifact:A">
                            <xsd:length value="1"/>
                          </xsd:restriction>
                        </xsd:simpleType>
                      </xsd:element>
                      <xsd:element default="0" minOccurs="0" name="_0031">
                        <xsd:annotation>
                          <xsd:documentation bic:title="Acknowledgement request" xml:lang="en">Code determined by the sender for acknowledgement of the interchange.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:simpleType>
                          <xsd:restriction base="edifact:N">
                            <xsd:totalDigits value="1"/>
                          </xsd:restriction>
                        </xsd:simpleType>
                      </xsd:element>
                      <xsd:element minOccurs="0" name="_0032">
                        <xsd:annotation>
                          <xsd:documentation bic:title="Communications agreement ID" xml:lang="en">Identification by name or code of the type of agreement under which the interchange takes place.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:simpleType>
                          <xsd:restriction base="edifact:AN..">
                            <xsd:length value="35"/>
                          </xsd:restriction>
                        </xsd:simpleType>
                      </xsd:element>
                      <xsd:element default="0" minOccurs="0" name="_0035">
                        <xsd:annotation>
                          <xsd:documentation bic:title="Test indicator" xml:lang="en">Indication that the interchange is a test.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:simpleType>
                          <xsd:restriction base="edifact:N">
                            <xsd:totalDigits value="1"/>
                          </xsd:restriction>
                        </xsd:simpleType>
                      </xsd:element>
                    </xsd:sequence>
                  </xsd:extension>
                </xsd:complexContent>
              </xsd:complexType>
            </xsd:element>
            <xsd:element maxOccurs="unbounded" minOccurs="1" name="Message">
              <xsd:complexType>
                <xsd:complexContent>
                  <xsd:extension base="edifact:SegmentGroup">
                    <xsd:sequence>
                      <xsd:element maxOccurs="1" minOccurs="1" name="UNH">
                        <xsd:annotation>
                          <xsd:documentation bic:title="MESSAGE HEADER" xml:lang="en">A service segment starting and uniquely identifying a message. The message type code for the Despatch advice message is DESADV.

Note: Despatch advice messages conforming to this document must contain the following data in segment UNH, composite S009:

Data element  0065 DESADV
0052 D
0054 97A
0051 UN</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:Segment">
                              <xsd:sequence>
                                <xsd:element name="_0062">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Message reference number" xml:lang="en">Unique message reference assigned by the sender.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="14"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element name="S009">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="MESSAGE IDENTIFIER" xml:lang="en">Identification of the type, version etc. of the message being interchanged.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:FieldGroup">
                                        <xsd:sequence>
                                          <xsd:element name="_0065">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Message type identifier" xml:lang="en">Code identifying a type of message and assigned by its controlling agency.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="6"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element name="_0052">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Message type version number" xml:lang="en">Version number of a message type.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element name="_0054">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Message type release number" xml:lang="en">Release number within the current message type version number (0052).</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element name="_0051">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Controlling agency" xml:lang="en">Code identifying the agency controlling the specification, maintenance and publication of the message type.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="2"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_0057">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Association assigned code" xml:lang="en">Code, assigned by the association responsible for the design and maintenance of the message type concerned, which further identifies the message.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="6"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_0068">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Common access reference" xml:lang="en">Reference serving as a key to relate all subsequent transfers of data to the same business case or file.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="35"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="S010">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="STATUS OF THE TRANSFER" xml:lang="en">Statement that the message is one in a sequence of transfers relating to the same topic.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:FieldGroup">
                                        <xsd:sequence>
                                          <xsd:element default="0" name="_0070">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Sequence message transfer number" xml:lang="en">Number assigned by the sender indicating that the message is an addition or change of a previously sent message relating to the same topic</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:N..">
                                                <xsd:totalDigits value="2"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element default=" " minOccurs="0" name="_0073">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="First/last sequence message transfer indication" xml:lang="en">Indication used for the first and last message in a sequence of the same type of message relating to the same topic.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:A">
                                                <xsd:length value="1"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="1" minOccurs="1" name="BGM">
                        <xsd:annotation>
                          <xsd:documentation bic:title="BEGINNING OF MESSAGE" xml:lang="en">A segment for unique identification of the Despatch Advice document, by means of its name and its number.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:Segment">
                              <xsd:sequence>
                                <xsd:element minOccurs="0" name="C002">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="DOCUMENT/MESSAGE NAME" xml:lang="en">Identification of a type of document/message by code or name. Code preferred.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:FieldGroup">
                                        <xsd:sequence>
                                          <xsd:element minOccurs="0" name="_1001">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Document/message name, coded" xml:lang="en">Document/message identifier expressed in code.

Note:

Users should note that code values marked as additions or changes are included pending approval by the 1001 Maintenance Agency and may be disapproved or changed. The results of this review will be reflected in a future version of the draft directory.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_1131">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_3055">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_1000">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Document/message name" xml:lang="en">Plain language identifier specifying the function of a document/message.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="35"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="C106">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="DOCUMENT/MESSAGE IDENTIFICATION" xml:lang="en">Identification of a document/message by its number and eventually its version or revision.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:FieldGroup">
                                        <xsd:sequence>
                                          <xsd:element minOccurs="0" name="_1004">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Document/message number" xml:lang="en">Reference number assigned to the document/message by the issuer.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="35"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_1056">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Version" xml:lang="en">To specify the version number or name of an object.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="9"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_1060">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Revision number" xml:lang="en">To specify a revision number.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="6"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_1225">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Message function, coded" xml:lang="en">Code indicating the function of the message.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="3"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_4343">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Response type, coded" xml:lang="en">Code specifying the type of acknowledgment required or transmitted.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="3"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="10" minOccurs="0" name="DTM">
                        <xsd:annotation>
                          <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">Date/time/period related to the whole message. The DTM segment must be specified at least once to identify the Despatch Advice date.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:Segment">
                              <xsd:sequence>
                                <xsd:element name="C507">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">Date and/or time, or period relevant to the specified date/time/period type.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:FieldGroup">
                                        <xsd:sequence>
                                          <xsd:element name="_2005">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Date/time/period qualifier" xml:lang="en">Code giving specific meaning to a date, time or period.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_2380">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Date/time/period" xml:lang="en">The value of a date, a date and time, a time or of a period in a specified representation.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="35"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_2379">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Date/time/period format qualifier" xml:lang="en">Specification of the representation of a date, a date and time or of a period.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="5" minOccurs="0" name="ALI">
                        <xsd:annotation>
                          <xsd:documentation bic:title="ADDITIONAL INFORMATION" xml:lang="en">A segment indicating that the message is subject to special conditions due to origin, customs preference or commercial factors.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:Segment">
                              <xsd:sequence>
                                <xsd:element minOccurs="0" name="_3239">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Country of origin, coded" xml:lang="en">Country in which the goods have been produced or manufactured, according to criteria laid down for the purposes of application of the Customs tariff, of quantitative restrictions, or of any other measure related to trade.

Note:

See Country and currency codes (UNTDED) or ISO 3166 two alpha country code (Code set 3207).</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="3"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_9213">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Type of duty regime, coded" xml:lang="en">Identification of the statement of the full/preferential regime according to which duty is assessed.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="3"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_4183">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Special conditions, coded" xml:lang="en">Indication of a specific condition.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="3"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_4183">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Special conditions, coded" xml:lang="en">Indication of a specific condition.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="3"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_4183">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Special conditions, coded" xml:lang="en">Indication of a specific condition.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="3"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_4183">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Special conditions, coded" xml:lang="en">Indication of a specific condition.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="3"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_4183">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Special conditions, coded" xml:lang="en">Indication of a specific condition.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="3"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="5" minOccurs="0" name="MEA">
                        <xsd:annotation>
                          <xsd:documentation bic:title="MEASUREMENTS" xml:lang="en">A segment specifying the weight and volume of the consignment.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:Segment">
                              <xsd:sequence>
                                <xsd:element name="_6311">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Measurement purpose qualifier" xml:lang="en">Specification of the purpose of the measurement.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="3"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="C502">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="MEASUREMENT DETAILS" xml:lang="en">Identification of measurement type.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:FieldGroup">
                                        <xsd:sequence>
                                          <xsd:element minOccurs="0" name="_6313">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Property measured, coded" xml:lang="en">Specification of the property measured.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_6321">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Measurement significance, coded" xml:lang="en">Code specifying the significance of a measurement value.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_6155">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Measurement attribute identification" xml:lang="en">Code used to specify non-discrete measurement values.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="17"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_6154">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Measurement attribute" xml:lang="en">To specify non-discrete measurement values.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="70"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="C174">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="VALUE/RANGE" xml:lang="en">Measurement value and relevant minimum and maximum tolerances in that order.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:FieldGroup">
                                        <xsd:sequence>
                                          <xsd:element name="_6411">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Measure unit qualifier" xml:lang="en">Indication of the unit of measurement in which weight (mass), capacity, length, area, volume or other quantity is expressed.

Note:

See UN/ECE Recommendation 20.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_6314">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Measurement value" xml:lang="en">Value of the measured unit.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="18"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element default="0" minOccurs="0" name="_6162">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Range minimum" xml:lang="en">Minimum of a range.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:N..">
                                                <xsd:totalDigits value="18"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element default="0" minOccurs="0" name="_6152">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Range maximum" xml:lang="en">Maximum of a range.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:N..">
                                                <xsd:totalDigits value="18"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element default="0" minOccurs="0" name="_6432">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Significant digits" xml:lang="en">To specify the number of significant digits.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:N..">
                                                <xsd:totalDigits value="2"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="_7383">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Surface/layer indicator, coded" xml:lang="en">Code indicating the surface or layer of a product that is being described.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="edifact:AN..">
                                      <xsd:length value="3"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="5" minOccurs="0" name="MOA">
                        <xsd:annotation>
                          <xsd:documentation bic:title="MONETARY AMOUNT" xml:lang="en">A segment to transmit monetary amounts for the whole despatch required by the consignee to prepare customs clearance procedures.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:Segment">
                              <xsd:sequence>
                                <xsd:element name="C516">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="MONETARY AMOUNT" xml:lang="en">Amount of goods or services stated as a monetary amount in a specified currency.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:FieldGroup">
                                        <xsd:sequence>
                                          <xsd:element name="_5025">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Monetary amount type qualifier" xml:lang="en">Indication of type of amount.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element default="0" minOccurs="0" name="_5004">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Monetary amount" xml:lang="en">Number of monetary units.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:N..">
                                                <xsd:totalDigits value="18"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_6345">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Currency, coded" xml:lang="en">Identification of the name or symbol of the monetary unit involved in the transaction.

Note:

Use ISO 4217 three alpha code.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_6343">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Currency qualifier" xml:lang="en">Code giving specific meaning to data element 6345 Currency.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="_4405">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Status, coded" xml:lang="en">Provides information regarding a status.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="10" minOccurs="0" name="SG1">
                        <xsd:annotation>
                          <xsd:documentation bic:title="RFF-DTM" xml:lang="en">A group of segments giving references where necessary, their dates relating to the whole message, e.g. contract number.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:SegmentGroup">
                              <xsd:sequence>
                                <xsd:element maxOccurs="1" minOccurs="1" name="RFF">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="REFERENCE" xml:lang="en">A segment for referencing documents relating to the whole despatch advice message, e.g. purchase orders, delivery instructions, import/export license.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element name="C506">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="REFERENCE" xml:lang="en">Identification of a reference.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element name="_1153">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Reference qualifier" xml:lang="en">Code giving specific meaning to a reference segment or a reference number.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1154">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Reference number" xml:lang="en">Identification number the nature and function of which can be qualified by an entry in data element 1153 Reference qualifier.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="35"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1156">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Line number" xml:lang="en">Number of the line in the document/message referenced in 1154 Reference number.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="6"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_4000">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Reference version number" xml:lang="en">To uniquely identify a reference by its revision number.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="35"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element maxOccurs="1" minOccurs="0" name="DTM">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">Date/time/period from the referred document.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element name="C507">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">Date and/or time, or period relevant to the specified date/time/period type.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element name="_2005">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Date/time/period qualifier" xml:lang="en">Code giving specific meaning to a date, time or period.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_2380">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Date/time/period" xml:lang="en">The value of a date, a date and time, a time or of a period in a specified representation.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="35"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_2379">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Date/time/period format qualifier" xml:lang="en">Specification of the representation of a date, a date and time or of a period.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="10" minOccurs="0" name="SG2">
                        <xsd:annotation>
                          <xsd:documentation bic:title="NAD-LOC-SG3-SG4" xml:lang="en">A group of segments identifying names, addresses, locations, and required supporting documents relevant to the whole Despatch Advice.</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="edifact:SegmentGroup">
                              <xsd:sequence>
                                <xsd:element maxOccurs="1" minOccurs="1" name="NAD">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="NAME AND ADDRESS" xml:lang="en">A segment for identifying names, addresses, and their functions relevant to the whole Despatch Advice. Identification of the parties involved is recommended for the Despatch Advice message, and is to be given in the NAD segment.

It is recommended that where possible, only the coded form of the party ID should be specified, e.g. the buyer and seller are known to each other, thus only the coded ID is required. The consignee or delivery address may vary and would have to be clearly specified, preferably in structured format.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:Segment">
                                        <xsd:sequence>
                                          <xsd:element name="_3035">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Party qualifier" xml:lang="en">Code giving specific meaning to a party.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="edifact:AN..">
                                                <xsd:length value="3"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C082">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="PARTY IDENTIFICATION DETAILS" xml:lang="en">Identification of a transaction party by code.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element name="_3039">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Party id. identification" xml:lang="en">Code identifying a party involved in a transaction.

Note:

User or association defined code.  May be used in combination with 1131/3055.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="35"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_1131">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element minOccurs="0" name="C058">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="NAME AND ADDRESS" xml:lang="en">Unstructured name and address: one to five lines.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:FieldGroup">
                                                  <xsd:sequence>
                                                    <xsd:element name="_3124">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Name and address line" xml:lang="en">Free form name and address description.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
