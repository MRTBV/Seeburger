                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="7"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_8078">
                                                                          <xsd:annotation>
