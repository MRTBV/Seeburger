                                                    <xsd:element maxOccurs="1" minOccurs="0" name="DTM">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">A segment providing date/time information relevant for delivery to the specific location.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:Segment">
                                                            <xsd:sequence>
                                                              <xsd:element name="C507">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="DATE/TIME/PERIOD" xml:lang="en">Date and/or time, or period relevant to the specified date/time/period type.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="edifact:FieldGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element name="_2005">
                                                                          <xsd:annotation>
