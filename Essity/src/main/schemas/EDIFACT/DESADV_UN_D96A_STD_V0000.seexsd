                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element maxOccurs="1" minOccurs="0" name="NAD">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="NAME AND ADDRESS" xml:lang="en">A segment for identifying names and addresses and their functions relevant to the delivery point.

It is recommended that where possible only the coded form of the party ID should be specified, e.g. the buyer and seller are known to each other, thus only the coded ID is required. The consignee or delivery address may vary and would have to be clearly specified, preferably in structured format.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:Segment">
                                                            <xsd:sequence>
                                                              <xsd:element name="_3035">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Party qualifier" xml:lang="en">Code giving specific meaning to a party.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="C082">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="PARTY IDENTIFICATION DETAILS" xml:lang="en">Identification of a transaction party by code.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="edifact:FieldGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element name="_3039">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Party id. identification" xml:lang="en">Code identifying a party involved in a transaction.

Note:

User or association defined code.  May be used in combination with 1131/3055.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
