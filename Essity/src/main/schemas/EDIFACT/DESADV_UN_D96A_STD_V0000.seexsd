                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element name="_4451">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Text subject qualifier" xml:lang="en">Code specifying subject of a free text.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_4453">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Text function, coded" xml:lang="en">Code specifying how to handle the text.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="C107">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="TEXT REFERENCE" xml:lang="en">Coded reference to a standard text and its source.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element name="_4441">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Free text identification" xml:lang="en">Free text in coded form.

Note:

User or association defined code.  May be used in combination with 1131/3055.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="17"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_1131">
                                                                <xsd:annotation>
