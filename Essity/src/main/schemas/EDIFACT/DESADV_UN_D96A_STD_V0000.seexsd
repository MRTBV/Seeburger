                                                              </xsd:element>
                                                              <xsd:element default="0" minOccurs="0" name="_7224">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Number of packages" xml:lang="en">Number of individual parts of a shipment either unpacked, or packed in such a way that they cannot be divided without first undoing the packing.</xsd:documentation>
