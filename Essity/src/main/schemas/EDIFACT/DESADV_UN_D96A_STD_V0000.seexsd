                                <xsd:element maxOccurs="9999" minOccurs="0" name="SG11">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="PAC-MEA-QTY-SG12-SG13" xml:lang="en">A group of segments identifying packaging, physical dimensions, marks and numbers, quantities, date and time information, handling information and information about packing at this level.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="edifact:SegmentGroup">
                                        <xsd:sequence>
                                          <xsd:element maxOccurs="1" minOccurs="1" name="PAC">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="PACKAGE" xml:lang="en">A segment specifying the number and type of the packages/physical units and the physical type of packaging for the despatched goods.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element default="0" minOccurs="0" name="_7224">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Number of packages" xml:lang="en">Number of individual parts of a shipment either unpacked, or packed in such a way that they cannot be divided without first undoing the packing.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:N..">
                                                          <xsd:totalDigits value="8"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="C531">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="PACKAGING DETAILS" xml:lang="en">Packaging level and details, terms and conditions.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element minOccurs="0" name="_7075">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Packaging level, coded" xml:lang="en">Indication of level of packaging specified.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_7233">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Packaging related information, coded" xml:lang="en">Code giving packaging, handling and marking related information.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_7073">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Packaging terms and conditions, coded" xml:lang="en">Code identifying packaging terms and conditions.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="C202">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="PACKAGE TYPE" xml:lang="en">Type of package by name or by code from a specified source.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element minOccurs="0" name="_7065">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Type of packages identification" xml:lang="en">Coded description of the form in which goods are presented.

Note:

See UN/ECE Recommendation No. 21 (See Vol. II of UNTDED). May be used in combination with 1131/3055.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="17"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_1131">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_3055">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_7064">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Type of packages" xml:lang="en">Description of the form in which goods are presented.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="35"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="C402">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="PACKAGE TYPE IDENTIFICATION" xml:lang="en">Identification of the form in which goods are described.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element name="_7077">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Item description type, coded" xml:lang="en">Code indicating the format of a description.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element name="_7064">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Type of packages" xml:lang="en">Description of the form in which goods are presented.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="35"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_7143">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Item number type, coded" xml:lang="en">Identification of the type of item number.

Note:

User or association defined code.  May be used in combination with 1131/3055.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_7064">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Type of packages" xml:lang="en">Description of the form in which goods are presented.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="35"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_7143">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Item number type, coded" xml:lang="en">Identification of the type of item number.

Note:

User or association defined code.  May be used in combination with 1131/3055.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="C532">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="RETURNABLE PACKAGE DETAILS" xml:lang="en">Indication of responsibility for payment and load contents of returnable packages.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element minOccurs="0" name="_8395">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Returnable package freight payment responsibility, coded" xml:lang="en">To indicate responsibility for payment of return freight charges for packaging that is returnable.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_8393">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Returnable package load contents, coded" xml:lang="en">To indicate the composition of goods loaded into a returnable package.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="10" minOccurs="0" name="MEA">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="MEASUREMENTS" xml:lang="en">A segment specifying physical measurements of the packages/physical units described in the PAC segment.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element name="_6311">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Measurement purpose qualifier" xml:lang="en">Specification of the purpose of the measurement.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="C502">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="MEASUREMENT DETAILS" xml:lang="en">Identification of measurement type.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element minOccurs="0" name="_6313">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Property measured, coded" xml:lang="en">Specification of the property measured.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_6321">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Measurement significance, coded" xml:lang="en">Code specifying the significance of a measurement value.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_6155">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Measurement attribute identification" xml:lang="en">Code used to specify non-discrete measurement values.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="17"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_6154">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Measurement attribute" xml:lang="en">To specify non-discrete measurement values.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="70"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="C174">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="VALUE/RANGE" xml:lang="en">Measurement value and relevant minimum and maximum tolerances in that order.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element name="_6411">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Measure unit qualifier" xml:lang="en">Indication of the unit of measurement in which weight (mass), capacity, length, area, volume or other quantity is expressed.

Note:

See UN/ECE Recommendation 20.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_6314">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Measurement value" xml:lang="en">Value of the measured unit.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="18"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default="0" minOccurs="0" name="_6162">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Range minimum" xml:lang="en">Minimum of a range.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:N..">
                                                                    <xsd:totalDigits value="18"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default="0" minOccurs="0" name="_6152">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Range maximum" xml:lang="en">Maximum of a range.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:N..">
                                                                    <xsd:totalDigits value="18"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default="0" minOccurs="0" name="_6432">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Significant digits" xml:lang="en">To specify the number of significant digits.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:N..">
                                                                    <xsd:totalDigits value="2"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                    <xsd:element minOccurs="0" name="_7383">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Surface/layer indicator, coded" xml:lang="en">Code indicating the surface or layer of a product that is being described.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
                                                          <xsd:length value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="10" minOccurs="0" name="QTY">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="QUANTITY" xml:lang="en">A segment to specify the quantity per package described in the PAC segment.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element name="C186">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="QUANTITY DETAILS" xml:lang="en">Quantity information in a transaction, qualified when relevant.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:FieldGroup">
                                                            <xsd:sequence>
                                                              <xsd:element name="_6063">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Quantity qualifier" xml:lang="en">Code giving specific meaning to a quantity.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default="0" name="_6060">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Quantity" xml:lang="en">Numeric value of a quantity.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:N..">
                                                                    <xsd:totalDigits value="15"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_6411">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Measure unit qualifier" xml:lang="en">Indication of the unit of measurement in which weight (mass), capacity, length, area, volume or other quantity is expressed.

Note:

See UN/ECE Recommendation 20.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="3"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="10" minOccurs="0" name="SG12">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="HAN-FTX" xml:lang="en">A group of segments providing information on hazardous goods and handling.</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="edifact:SegmentGroup">
                                                  <xsd:sequence>
                                                    <xsd:element maxOccurs="1" minOccurs="1" name="HAN">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="HANDLING INSTRUCTIONS" xml:lang="en">A segment providing information on required handling and notification of hazardous materials in the specified package.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="edifact:Segment">
                                                            <xsd:sequence>
                                                              <xsd:element minOccurs="0" name="C524">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="HANDLING INSTRUCTIONS" xml:lang="en">Instruction for the handling of goods, products or articles in shipment, storage etc.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="edifact:FieldGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element minOccurs="0" name="_4079">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Handling instructions, coded" xml:lang="en">Identification of the instructions on how specified goods, packages or containers should be handled.

Note:

User or association defined code.  May be used in combination with 1131/3055.  See also UNTDED 5.9 p.2 CIMP.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_1131">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_3055">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_4078">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Handling instructions" xml:lang="en">Instructions on how specified goods, packages or containers should be handled.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="70"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="C218">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="HAZARDOUS MATERIAL" xml:lang="en">To specify a hazardous material.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="edifact:FieldGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element minOccurs="0" name="_7419">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Hazardous material class code, identification" xml:lang="en">Code specifying the kind of hazard for a material.

Note:

Association defined code.  May be used in combination with 1131/3055.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="4"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_1131">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Code list qualifier" xml:lang="en">Identification of a code list.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_3055">
