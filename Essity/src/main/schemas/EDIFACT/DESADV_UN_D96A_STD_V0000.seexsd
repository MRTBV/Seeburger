                                                    <xsd:element minOccurs="0" name="_3055">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Code list responsible agency, coded" xml:lang="en">Code identifying the agency responsible for a code list.</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="edifact:AN..">
