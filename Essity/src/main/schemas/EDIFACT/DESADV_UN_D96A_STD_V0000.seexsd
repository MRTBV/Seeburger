                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="C058">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="NAME AND ADDRESS" xml:lang="en">Unstructured name and address: one to five lines.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="edifact:FieldGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element name="_3124">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Name and address line" xml:lang="en">Free form name and address description.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="35"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_3124">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Name and address line" xml:lang="en">Free form name and address description.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="35"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_3124">
                                                                          <xsd:annotation>
