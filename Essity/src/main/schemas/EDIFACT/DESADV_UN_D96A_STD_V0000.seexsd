                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="35"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_2379">
                                                                <xsd:annotation>
