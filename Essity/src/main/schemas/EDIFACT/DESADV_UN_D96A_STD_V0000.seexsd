                                                                            <xsd:restriction base="edifact:AN..">
                                                                              <xsd:length value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="_3055">
                                                                          <xsd:annotation>
