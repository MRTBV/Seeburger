                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="35"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="10" minOccurs="0" name="FTX">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="FREE TEXT" xml:lang="en">A segment with free text information in coded or clear form to give further clarification, when required, for hazardous material.</xsd:documentation>
                                            </xsd:annotation>
