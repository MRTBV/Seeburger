                                                    <xsd:element maxOccurs="10" minOccurs="0" name="QTY">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="QUANTITY" xml:lang="en">A segment to specify quantity for the given location.</xsd:documentation>
