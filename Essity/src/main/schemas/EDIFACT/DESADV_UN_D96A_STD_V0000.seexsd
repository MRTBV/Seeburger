                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="_8255">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Packing instruction, coded" xml:lang="en">Code defining the quantity and the type of package in which a product is allowed to be shipped in a passenger or freight aircraft.

