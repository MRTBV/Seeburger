                                                                  <xsd:restriction base="edifact:AN..">
                                                                    <xsd:length value="10"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element minOccurs="0" name="C235">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="HAZARD IDENTIFICATION" xml:lang="en">Identification of the Orange placard required on the means of transport.</xsd:documentation>
                                                                </xsd:annotation>
