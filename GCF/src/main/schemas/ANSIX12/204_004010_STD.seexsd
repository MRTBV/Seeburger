                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="2"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_1018">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Exponent" xml:lang="en">Description: Power to which a unit is raised</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:R">
                                                                                        <xsd:minInclusive value="-999999999999999"/>
                                                                                        <xsd:maxInclusive value="999999999999999"/>
                                                                                        <xsd:totalDigits value="15"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_649">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Multiplier" xml:lang="en">Description: Value to be used as a multiplier to obtain a new value</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:R">
                                                                                        <xsd:minInclusive value="-9999999999"/>
                                                                                        <xsd:maxInclusive value="9999999999"/>
                                                                                        <xsd:totalDigits value="10"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_740">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Range Minimum" xml:lang="en">Description: The value specifying the minimum of the measurement range</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-99999999999999999999"/>
                                                                              <xsd:maxInclusive value="99999999999999999999"/>
                                                                              <xsd:totalDigits value="20"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_741">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Range Maximum" xml:lang="en">Description: The value specifying the maximum of the measurement range</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-99999999999999999999"/>
                                                                              <xsd:maxInclusive value="99999999999999999999"/>
                                                                              <xsd:totalDigits value="20"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_935">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Measurement Significance Code" xml:lang="en">Description: Code used to benchmark, qualify or further define a measurement value</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_936">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Measurement Attribute Code" xml:lang="en">Description: Code used to express an attribute response when a numeric measurement value cannot be determined</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_752">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Surface/Layer/Position Code" xml:lang="en">Description: Code indicating the product surface, layer or position that is being described</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_1373">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Measurement Method or Device" xml:lang="en">Description: The method or device used to record the measurement</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="4"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="2" minOccurs="0" name="M7">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Seal Numbers" xml:lang="en">Purpose: To record seal numbers used and the organization that applied the seals
Comments: M705 indicates the name of the organization which applied the seal(s).

</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="  " name="_225">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Seal Number" xml:lang="en">Description: Unique number on seal used to close a shipment</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="15"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_225">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Seal Number" xml:lang="en">Description: Unique number on seal used to close a shipment</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="15"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_225">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Seal Number" xml:lang="en">Description: Unique number on seal used to close a shipment</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="15"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_225">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Seal Number" xml:lang="en">Description: Unique number on seal used to close a shipment</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="15"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_98">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Entity Identifier Code" xml:lang="en">Description: Code identifying an organizational entity, a physical location, property or an individual</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="3"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="999" minOccurs="1" name="S0300">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Stop Off Details" xml:lang="en">Purpose: To specify stop-off detail reference numbers and stop reason</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="ansix12:SegmentGroup">
                                                  <xsd:sequence>
                                                    <xsd:element maxOccurs="1" minOccurs="1" name="S5">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Stop Off Details" xml:lang="en">Purpose: To specify stop-off detail reference numbers and stop reason
Semantics: S509 is the stop reason description.


Syntax Rules:
P0304 : If either S503 or S504 is present, then the other is required.
P0506 : If either S505 or S506 is present, then the other is required.
P0708 : If either S507 or S508 is present, then the other is required.
</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="ansix12:Segment">
                                                            <xsd:sequence>
                                                              <xsd:element default="0" name="_165">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Stop Sequence Number" xml:lang="en">Description: Identifying number for the specific stop and the sequence in which the stop is to be performed</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="ansix12:N">
                                                                    <xsd:minInclusive value="-999"/>
                                                                    <xsd:maxInclusive value="999"/>
                                                                    <xsd:totalDigits value="3"/>
                                                                    <xsd:fractionDigits value="0"/>
                                                                    <xsd:minLength value="0"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default="  " name="_163">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Stop Reason Code" xml:lang="en">Description: Code specifying the reason for the stop</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="ansix12:AN">
                                                                    <xsd:length value="2"/>
                                                                    <xsd:minLength value="2"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default="0" minOccurs="0" name="_81">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="ansix12:R">
                                                                    <xsd:minInclusive value="-9999999999"/>
                                                                    <xsd:maxInclusive value="9999999999"/>
                                                                    <xsd:totalDigits value="10"/>
                                                                    <xsd:minLength value="1"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default=" " minOccurs="0" name="_188">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="ansix12:AN">
                                                                    <xsd:length value="1"/>
                                                                    <xsd:minLength value="1"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default="0" minOccurs="0" name="_382">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Number of Units Shipped" xml:lang="en">Description: Numeric value of units shipped in manufacturer's shipping units for a line item or transaction set</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="ansix12:R">
                                                                    <xsd:minInclusive value="-9999999999"/>
                                                                    <xsd:maxInclusive value="9999999999"/>
                                                                    <xsd:totalDigits value="10"/>
                                                                    <xsd:minLength value="1"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default="  " minOccurs="0" name="_355">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="ansix12:AN">
                                                                    <xsd:length value="2"/>
                                                                    <xsd:minLength value="2"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default="0" minOccurs="0" name="_183">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Volume" xml:lang="en">Description: Value of volumetric measure</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="ansix12:R">
                                                                    <xsd:minInclusive value="-99999999"/>
                                                                    <xsd:maxInclusive value="99999999"/>
                                                                    <xsd:totalDigits value="8"/>
                                                                    <xsd:minLength value="1"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default=" " minOccurs="0" name="_184">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Volume Unit Qualifier" xml:lang="en">Description: Code identifying the volume unit</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="ansix12:AN">
                                                                    <xsd:length value="1"/>
                                                                    <xsd:minLength value="1"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default=" " minOccurs="0" name="_352">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Description" xml:lang="en">Description: A free-form description to clarify the related data elements and their content</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="ansix12:AN">
                                                                    <xsd:length value="80"/>
                                                                    <xsd:minLength value="1"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default="      " minOccurs="0" name="_154">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Standard Point Location Code" xml:lang="en">Description: Code (Standard Point Location) defined by NMFTA point development group as the official code assigned to a city or point (for ratemaking purposes) within a city</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="ansix12:AN">
                                                                    <xsd:length value="9"/>
                                                                    <xsd:minLength value="6"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element default=" " minOccurs="0" name="_190">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Accomplish Code" xml:lang="en">Description: Code indicating the status of a specified stop</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="ansix12:AN">
                                                                    <xsd:length value="1"/>
                                                                    <xsd:minLength value="1"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="50" minOccurs="0" name="L11">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Business Instructions and Reference Number" xml:lang="en">Purpose: To specify instructions in this business relationship or a reference number
Syntax Rules:
R0103 : At least one of L1101 or L1103 is required.
P0102 : If either L1101 or L1102 is present, then the other is required.
</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default=" " minOccurs="0" name="_127">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="30"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_128">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="3"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_352">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Description" xml:lang="en">Description: A free-form description to clarify the related data elements and their content</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="80"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="2" minOccurs="0" name="G62">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Date/Time" xml:lang="en">Purpose: To specify pertinent dates and times
Notes: Use G62 segment either in loop 0300 or loop 0350, but not both.
Syntax Rules:
R0103 : At least one of G6201 or G6203 is required.
P0102 : If either G6201 or G6202 is present, then the other is required.
P0304 : If either G6203 or G6204 is present, then the other is required.
</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="  " minOccurs="0" name="_432">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Date Qualifier" xml:lang="en">Description: Code specifying type of date</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="        " minOccurs="0" name="_373">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Date" xml:lang="en">Description: Date expressed as CCYYMMDD</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:DT">
                                                                              <xsd:length value="8"/>
                                                                              <xsd:minLength value="8"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_176">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Time Qualifier" xml:lang="en">Description: Code specifying the reported time</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="    " minOccurs="0" name="_337">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Time" xml:lang="en">Description: Time expressed in 24-hour clock time as follows: HHMM, or HHMMSS, or HHMMSSD, or HHMMSSDD, where H = hours (00-23), M = minutes (00-59), S = integer seconds (00-59) and DD = decimal seconds; decimal seconds are expressed as follows: D = tenths (0-9) and DD = hundredths (00-99)</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:TM">
                                                                              <xsd:length value="8"/>
                                                                              <xsd:minLength value="4"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_623">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Time Code" xml:lang="en">Description: Code identifying the time. In accordance with International Standards Organization standard 8601, time can be specified by a + or - and an indication in hours in relation to Universal Time Coordinate (UTC) time; since + is a restricted character, + and - are substituted by P and M in the codes that follow</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="1" minOccurs="0" name="AT8">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Shipment Weight, Packaging and Quantity Data" xml:lang="en">Purpose: To specify shipment details in terms of weight, and quantity of handling units
Notes: Segment AT8 in loop 0300 is intended for the transmitting of total weight, quantity, and volume relative to the specific stop-off. Should weight, quantity, and volume also be sent in segment AT8 in loop 0320 and tied to commodity detail, then the accumulated amounts of weight, quantity, and volume in the AT8 segment in loop 0320 should equal the amounts in the single AT8 occurrence in loop 0300.
Semantics: AT804 is the quantity of handling units that are not unitized (for example a carton). When added to the quantity in AT805, it is the total quantity of handling units in the shipment.

AT805 is the quantity of handling units that are unitized (for example on a pallet or slip sheet). When added to the quantity in AT804 it is the total quantity of handling units for the shipment.


Syntax Rules:
P010203 : If either AT801, AT802 or AT803 is present, then the other is required.
P0607 : If either AT806 or AT807 is present, then the other is required.
</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default=" " minOccurs="0" name="_187">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Weight Qualifier" xml:lang="en">Description: Code defining the type of weight</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_188">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_81">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-9999999999"/>
                                                                              <xsd:maxInclusive value="9999999999"/>
                                                                              <xsd:totalDigits value="10"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_80">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Lading Quantity" xml:lang="en">Description: Number of units (pieces) of the lading commodity</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-9999999"/>
                                                                              <xsd:maxInclusive value="9999999"/>
                                                                              <xsd:totalDigits value="7"/>
                                                                              <xsd:fractionDigits value="0"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_80">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Lading Quantity" xml:lang="en">Description: Number of units (pieces) of the lading commodity</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-9999999"/>
                                                                              <xsd:maxInclusive value="9999999"/>
                                                                              <xsd:totalDigits value="7"/>
                                                                              <xsd:fractionDigits value="0"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_184">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Volume Unit Qualifier" xml:lang="en">Description: Code identifying the volume unit</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_183">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Volume" xml:lang="en">Description: Value of volumetric measure</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-99999999"/>
                                                                              <xsd:maxInclusive value="99999999"/>
                                                                              <xsd:totalDigits value="8"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="999" minOccurs="0" name="LAD">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Lading Detail" xml:lang="en">Purpose: To transmit detailed lading data pertinent to a pickup or delivery
Notes: Use LAD segment either in loop 0300 or loop 0350, but not both.
Syntax Rules:
P0102 : If either LAD01 or LAD02 is present, then the other is required.
P0304 : If either LAD03 or LAD04 is present, then the other is required.
P0506 : If either LAD05 or LAD06 is present, then the other is required.
P0708 : If either LAD07 or LAD08 is present, then the other is required.
P0910 : If either LAD09 or LAD10 is present, then the other is required.
P1112 : If either LAD11 or LAD12 is present, then the other is required.
</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="   " minOccurs="0" name="_211">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Packaging Form Code" xml:lang="en">Description: Code for packaging form of the lading quantity</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="3"/>
                                                                              <xsd:minLength value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_80">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Lading Quantity" xml:lang="en">Description: Number of units (pieces) of the lading commodity</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-9999999"/>
                                                                              <xsd:maxInclusive value="9999999"/>
                                                                              <xsd:totalDigits value="7"/>
                                                                              <xsd:fractionDigits value="0"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_188">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_395">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Unit Weight" xml:lang="en">Description: Numeric value of weight per unit</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-99999999"/>
                                                                              <xsd:maxInclusive value="99999999"/>
                                                                              <xsd:totalDigits value="8"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_188">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_81">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-9999999999"/>
                                                                              <xsd:maxInclusive value="9999999999"/>
                                                                              <xsd:totalDigits value="10"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_235">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Product/Service ID Qualifier" xml:lang="en">Description: Code identifying the type/source of the descriptive number used in Product/Service ID (234)</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_234">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Product/Service ID" xml:lang="en">Description: Identifying number for a product or service</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="48"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_235">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Product/Service ID Qualifier" xml:lang="en">Description: Code identifying the type/source of the descriptive number used in Product/Service ID (234)</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_234">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Product/Service ID" xml:lang="en">Description: Identifying number for a product or service</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="48"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_235">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Product/Service ID Qualifier" xml:lang="en">Description: Code identifying the type/source of the descriptive number used in Product/Service ID (234)</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_234">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Product/Service ID" xml:lang="en">Description: Identifying number for a product or service</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="48"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_79">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Lading Description" xml:lang="en">Description: Description of an item as required for rating and billing purposes</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="50"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="6" minOccurs="0" name="AT5">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Bill of Lading Handling Requirements" xml:lang="en">Purpose: To identify Bill of Lading handling and service requirements
Syntax Rules:
E0103 : Only one of AT501 or AT503 may be present.
E0203 : Only one of AT502 or AT503 may be present.
</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="  " minOccurs="0" name="_152">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Special Handling Code" xml:lang="en">Description: Code specifying special transportation handling instructions</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="3"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_560">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Special Services Code" xml:lang="en">Description: Code identifying the special service</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="10"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_153">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Special Handling Description" xml:lang="en">Description: Free-form additional description of special handling instructions to appear on printed bill if special handling code is not adequate</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="30"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="1" minOccurs="0" name="PLD">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Pallet Information" xml:lang="en">Purpose: To specify pallet information including quantity, exchange, and weight
Syntax Rules:
P0304 : If either PLD03 or PLD04 is present, then the other is required.
</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="0" name="_406">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Quantity of Pallets Shipped" xml:lang="en">Description: Number of pallets shipped</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-999"/>
                                                                              <xsd:maxInclusive value="999"/>
                                                                              <xsd:totalDigits value="3"/>
                                                                              <xsd:fractionDigits value="0"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_399">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Pallet Exchange Code" xml:lang="en">Description: Code specifying pallet exchange instructions</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_188">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_81">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-9999999999"/>
                                                                              <xsd:maxInclusive value="9999999999"/>
                                                                              <xsd:totalDigits value="10"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="20" minOccurs="0" name="NTE">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Note/Special Instruction" xml:lang="en">Purpose: To transmit information in a free-form format, if necessary, for comment or special instruction
Comments: The NTE segment permits free-form information/data which, under ANSI X12 standard implementations, is not machine processable. The use of the NTE segment should therefore be avoided, if at all possible, in an automated environment.

</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="   " minOccurs="0" name="_363">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Note Reference Code" xml:lang="en">Description: Code identifying the functional area or purpose for which the note applies</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="3"/>
                                                                              <xsd:minLength value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " name="_352">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Description" xml:lang="en">Description: A free-form description to clarify the related data elements and their content</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="80"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="1" minOccurs="0" name="S0310">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Name" xml:lang="en">Purpose: To identify a party by type of organization, name, and code</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:SegmentGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element maxOccurs="1" minOccurs="0" name="N1">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Name" xml:lang="en">Purpose: To identify a party by type of organization, name, and code
Comments: This segment, used alone, provides the most efficient method of providing organizational identification. To obtain this efficiency the "ID Code" (N104) must provide a key to the table maintained by the transaction processing party.

N105 and N106 further define the type of entity in N101.


Syntax Rules:
R0203 : At least one of N102 or N103 is required.
P0304 : If either N103 or N104 is present, then the other is required.
</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:complexType>
                                                                            <xsd:complexContent>
                                                                              <xsd:extension base="ansix12:Segment">
                                                                                <xsd:sequence>
                                                                                  <xsd:element default="  " name="_98">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Entity Identifier Code" xml:lang="en">Description: Code identifying an organizational entity, a physical location, property or an individual</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="3"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_93">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="60"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_66">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identification Code Qualifier" xml:lang="en">Description: Code designating the system/method of code structure used for Identification Code (67)</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="2"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_67">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identification Code" xml:lang="en">Description: Code identifying a party or other code</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="80"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_706">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Entity Relationship Code" xml:lang="en">Description: Code describing entity relationship</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="2"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_98">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Entity Identifier Code" xml:lang="en">Description: Code identifying an organizational entity, a physical location, property or an individual</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="3"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="1" minOccurs="0" name="N2">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Additional Name Information" xml:lang="en">Purpose: To specify additional names or those longer than 35 characters in length</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default=" " name="_93">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="60"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_93">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="60"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="2" minOccurs="0" name="N3">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Address Information" xml:lang="en">Purpose: To specify the location of the named party</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default=" " name="_166">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Address Information" xml:lang="en">Description: Address information</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="55"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_166">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Address Information" xml:lang="en">Description: Address information</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="55"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="1" minOccurs="0" name="N4">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Geographic Location" xml:lang="en">Purpose: To specify the geographic place of the named party
Comments: A combination of either N401 through N404, or N405 and N406 may be adequate to specify a location.

N402 is required only if city name (N401) is in the U.S. or Canada.


Syntax Rules:
C0605 : If N406 is present, then N405 is required.
</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="  " minOccurs="0" name="_19">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="City Name" xml:lang="en">Description: Free-form text for city name</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="30"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_156">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="State or Province Code" xml:lang="en">Description: Code (Standard State/Province) as defined by appropriate government agency</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="   " minOccurs="0" name="_116">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Postal Code" xml:lang="en">Description: Code defining international postal zone code excluding punctuation and blanks (zip code for United States)</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="15"/>
                                                                                                  <xsd:minLength value="3"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_26">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Country Code" xml:lang="en">Description: Code identifying the country</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="3"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_309">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Location Qualifier" xml:lang="en">Description: Code identifying type of location</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_310">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Location Identifier" xml:lang="en">Description: Code which identifies a specific location</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="30"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="3" minOccurs="0" name="G61">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Contact" xml:lang="en">Purpose: To identify a person or office to whom communications should be directed
Comments: G6103 qualifies G6104.


Syntax Rules:
P0304 : If either G6103 or G6104 is present, then the other is required.
</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="  " name="_366">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Contact Function Code" xml:lang="en">Description: Code identifying the major duty or responsibility of the person or group named</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " name="_93">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="60"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_365">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Communication Number Qualifier" xml:lang="en">Description: Code identifying the type of communication number</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_364">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Communication Number" xml:lang="en">Description: Complete communications number including country or area code when applicable</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="80"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_443">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Contact Inquiry Reference" xml:lang="en">Description: Additional reference number or description to clarify a contact number</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="20"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="99" minOccurs="0" name="S0320">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Description, Marks and Numbers" xml:lang="en">Purpose: To specify the line item in terms of description, quantity, packaging, and marks and numbers</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:SegmentGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element maxOccurs="1" minOccurs="0" name="L5">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Description, Marks and Numbers" xml:lang="en">Purpose: To specify the line item in terms of description, quantity, packaging, and marks and numbers
Comments: L502 may be used to send quantity information as part of the product description.


Syntax Rules:
P0304 : If either L503 or L504 is present, then the other is required.
C0706 : If L507 is present, then L506 is required.
P0809 : If either L508 or L509 is present, then the other is required.
</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:complexType>
                                                                            <xsd:complexContent>
                                                                              <xsd:extension base="ansix12:Segment">
                                                                                <xsd:sequence>
                                                                                  <xsd:element default="0" minOccurs="0" name="_213">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Lading Line Item Number" xml:lang="en">Description: Sequential line number for a lading item</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:N">
                                                                                        <xsd:minInclusive value="-999"/>
                                                                                        <xsd:maxInclusive value="999"/>
                                                                                        <xsd:totalDigits value="3"/>
                                                                                        <xsd:fractionDigits value="0"/>
                                                                                        <xsd:minLength value="0"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_79">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Lading Description" xml:lang="en">Description: Description of an item as required for rating and billing purposes</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="50"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_22">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Commodity Code" xml:lang="en">Description: Code describing a commodity or group of commodities</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="30"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_23">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Commodity Code Qualifier" xml:lang="en">Description: Code identifying the commodity coding system used for Commodity Code</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="1"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="   " minOccurs="0" name="_103">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Packaging Code" xml:lang="en">Description: Code identifying the type of packaging; Part 1: Packaging Form, Part 2: Packaging Material; if the Data Element is used, then Part 1 is always required</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="5"/>
                                                                                        <xsd:minLength value="3"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_87">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Marks and Numbers" xml:lang="en">Description: Marks and numbers used to identify a shipment or parts of a shipment</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="48"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_88">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Marks and Numbers Qualifier" xml:lang="en">Description: Code specifying the application or source of Marks and Numbers (87)</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="2"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_23">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Commodity Code Qualifier" xml:lang="en">Description: Code identifying the commodity coding system used for Commodity Code</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="1"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_22">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Commodity Code" xml:lang="en">Description: Code describing a commodity or group of commodities</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="30"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_595">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Compartment ID Code" xml:lang="en">Description: Code identifying the compartment in a compartmentalized tank car</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="1"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="1" minOccurs="0" name="AT8">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Shipment Weight, Packaging and Quantity Data" xml:lang="en">Purpose: To specify shipment details in terms of weight, and quantity of handling units
Semantics: AT804 is the quantity of handling units that are not unitized (for example a carton). When added to the quantity in AT805, it is the total quantity of handling units in the shipment.

AT805 is the quantity of handling units that are unitized (for example on a pallet or slip sheet). When added to the quantity in AT804 it is the total quantity of handling units for the shipment.


Syntax Rules:
P010203 : If either AT801, AT802 or AT803 is present, then the other is required.
P0607 : If either AT806 or AT807 is present, then the other is required.
</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default=" " minOccurs="0" name="_187">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Weight Qualifier" xml:lang="en">Description: Code defining the type of weight</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_188">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="1"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_81">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-9999999999"/>
                                                                                                  <xsd:maxInclusive value="9999999999"/>
                                                                                                  <xsd:totalDigits value="10"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_80">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Lading Quantity" xml:lang="en">Description: Number of units (pieces) of the lading commodity</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:N">
                                                                                                  <xsd:minInclusive value="-9999999"/>
                                                                                                  <xsd:maxInclusive value="9999999"/>
                                                                                                  <xsd:totalDigits value="7"/>
                                                                                                  <xsd:fractionDigits value="0"/>
                                                                                                  <xsd:minLength value="0"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_80">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Lading Quantity" xml:lang="en">Description: Number of units (pieces) of the lading commodity</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:N">
                                                                                                  <xsd:minInclusive value="-9999999"/>
                                                                                                  <xsd:maxInclusive value="9999999"/>
                                                                                                  <xsd:totalDigits value="7"/>
                                                                                                  <xsd:fractionDigits value="0"/>
                                                                                                  <xsd:minLength value="0"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_184">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Volume Unit Qualifier" xml:lang="en">Description: Code identifying the volume unit</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="1"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_183">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Volume" xml:lang="en">Description: Value of volumetric measure</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-99999999"/>
                                                                                                  <xsd:maxInclusive value="99999999"/>
                                                                                                  <xsd:totalDigits value="8"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="99" minOccurs="0" name="S0325">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Contact" xml:lang="en">Purpose: To identify a person or office to whom communications should be directed
Notes: The G61 segment contains the person or company to be contacted by the carrier in case of emergency.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:SegmentGroup">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element maxOccurs="1" minOccurs="0" name="G61">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Contact" xml:lang="en">Purpose: To identify a person or office to whom communications should be directed
Notes: The G61 segment contains the person or company to be contacted by the carrier in case of emergency.
Comments: G6103 qualifies G6104.


Syntax Rules:
P0304 : If either G6103 or G6104 is present, then the other is required.
</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:complexType>
                                                                                                <xsd:complexContent>
                                                                                                  <xsd:extension base="ansix12:Segment">
                                                                                                    <xsd:sequence>
                                                                                                      <xsd:element default="  " name="_366">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Contact Function Code" xml:lang="en">Description: Code identifying the major duty or responsibility of the person or group named</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " name="_93">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="60"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_365">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Communication Number Qualifier" xml:lang="en">Description: Code identifying the type of communication number</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_364">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Communication Number" xml:lang="en">Description: Complete communications number including country or area code when applicable</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="80"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_443">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Contact Inquiry Reference" xml:lang="en">Description: Additional reference number or description to clarify a contact number</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="20"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element maxOccurs="5" minOccurs="0" name="L11">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Business Instructions and Reference Number" xml:lang="en">Purpose: To specify instructions in this business relationship or a reference number
Notes: The L11 segment contains the specific hazardous material reference numbers. Used in loop 0325 it pertains to all iterations of loop 0330 following.
Syntax Rules:
R0103 : At least one of L1101 or L1103 is required.
P0102 : If either L1101 or L1102 is present, then the other is required.
</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:complexType>
                                                                                                          <xsd:complexContent>
                                                                                                            <xsd:extension base="ansix12:Segment">
                                                                                                              <xsd:sequence>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="30"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_128">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="3"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_352">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Description" xml:lang="en">Description: A free-form description to clarify the related data elements and their content</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="80"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                              </xsd:sequence>
                                                                                                            </xsd:extension>
                                                                                                          </xsd:complexContent>
                                                                                                        </xsd:complexType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element maxOccurs="6" minOccurs="0" name="LH6">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Hazardous Certification" xml:lang="en">Purpose: To specify the name of the person certifying that the shipment complies with the regulations and/or the actual certification
Syntax Rules:
P0203 : If either LH602 or LH603 is present, then the other is required.
</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:complexType>
                                                                                                          <xsd:complexContent>
                                                                                                            <xsd:extension base="ansix12:Segment">
                                                                                                              <xsd:sequence>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_93">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="60"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_272">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Hazardous Certification Code" xml:lang="en">Description: Code indicating the form of the hazardous certification</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="1"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_273">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Hazardous Certification Declaration" xml:lang="en">Description: Hazardous material certification verbiage as required by Title 49 of Code of Federal Regulations</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="25"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_273">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Hazardous Certification Declaration" xml:lang="en">Description: Hazardous material certification verbiage as required by Title 49 of Code of Federal Regulations</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="25"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                              </xsd:sequence>
                                                                                                            </xsd:extension>
                                                                                                          </xsd:complexContent>
                                                                                                        </xsd:complexType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element maxOccurs="25" minOccurs="0" name="S0330">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Hazardous Identification Information" xml:lang="en">Purpose: To specify the hazardous commodity identification reference number and quantity</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:complexType>
                                                                                                          <xsd:complexContent>
                                                                                                            <xsd:extension base="ansix12:SegmentGroup">
                                                                                                              <xsd:sequence>
                                                                                                                <xsd:element maxOccurs="1" minOccurs="0" name="LH1">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Hazardous Identification Information" xml:lang="en">Purpose: To specify the hazardous commodity identification reference number and quantity
Comments: LH101 and LH102 are used to convey the number and type of packages for bulk and nonbulk movements.

LH106 and LH107 are used to convey the quantity or volume and unit of measure for nonbulk shipments only.

In LH109, a value of "R" or "P" requires that the receiver generate the words "residue: last contained" prior to the shipping name in accordance with regulations.

</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:complexType>
                                                                                                                    <xsd:complexContent>
                                                                                                                      <xsd:extension base="ansix12:Segment">
                                                                                                                        <xsd:sequence>
                                                                                                                          <xsd:element default="  " name="_355">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="2"/>
                                                                                                                                <xsd:minLength value="2"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default="0" name="_80">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Lading Quantity" xml:lang="en">Description: Number of units (pieces) of the lading commodity</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:N">
                                                                                                                                <xsd:minInclusive value="-9999999"/>
                                                                                                                                <xsd:maxInclusive value="9999999"/>
                                                                                                                                <xsd:totalDigits value="7"/>
                                                                                                                                <xsd:fractionDigits value="0"/>
                                                                                                                                <xsd:minLength value="0"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default="      " minOccurs="0" name="_277">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="UN/NA Identification Code" xml:lang="en">Description: Code identifying the hazardous material identification number as required by Title 49 of the code of Federal Regulations; UN/NA stands for United Nations/North America</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="6"/>
                                                                                                                                <xsd:minLength value="6"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default=" " minOccurs="0" name="_200">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Hazardous Materials Page" xml:lang="en">Description: The United Nations page number as required for the international transport of hazardous materials</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="6"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default=" " minOccurs="0" name="_22">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Commodity Code" xml:lang="en">Description: Code describing a commodity or group of commodities</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="30"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="2"/>
                                                                                                                                <xsd:minLength value="2"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default="0" minOccurs="0" name="_380">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:R">
                                                                                                                                <xsd:minInclusive value="-999999999999999"/>
                                                                                                                                <xsd:maxInclusive value="999999999999999"/>
                                                                                                                                <xsd:totalDigits value="15"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default=" " minOccurs="0" name="_595">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Compartment ID Code" xml:lang="en">Description: Code identifying the compartment in a compartmentalized tank car</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="1"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default=" " minOccurs="0" name="_665">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Residue Indicator Code" xml:lang="en">Description: Code indicating that the material being described is that which remains in a packaging (including a tank car) after it has been unloaded</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="1"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default=" " minOccurs="0" name="_254">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Packing Group Code" xml:lang="en">Description: Code indicating degree of danger in terms of Roman number I, II or III</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="3"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default=" " minOccurs="0" name="_1375">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Interim Hazardous Material Regulatory Number" xml:lang="en">Description: Identifies the current regulatory version number used for hazardous materials shipments</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="5"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element maxOccurs="4" minOccurs="0" name="LH2">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Hazardous Classification Information" xml:lang="en">Purpose: To specify the hazardous notation and endorsement information
Semantics: LH206 and LH207 indicate the flashpoint temperature.

LH208 and LH209 indicate the control temperature.

LH210 and LH211 indicate the emergency temperature.


Syntax Rules:
P0607 : If either LH206 or LH207 is present, then the other is required.
P0809 : If either LH208 or LH209 is present, then the other is required.
P1011 : If either LH210 or LH211 is present, then the other is required.
</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:complexType>
                                                                                                                              <xsd:complexContent>
                                                                                                                                <xsd:extension base="ansix12:Segment">
                                                                                                                                  <xsd:sequence>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_215">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Classification" xml:lang="en">Description: The hazardous classification corresponding to the shipping name of the hazardous commodity</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="30"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_983">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Class Qualifier" xml:lang="en">Description: Code qualifying hazardous class</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="1"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="              " minOccurs="0" name="_218">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Placard Notation" xml:lang="en">Description: The placard notation corresponding to the hazard class of the hazardous commodity</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="40"/>
                                                                                                                                          <xsd:minLength value="14"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="    " minOccurs="0" name="_222">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Endorsement" xml:lang="en">Description: The placard endorsement that is to be shown on the shipping papers for the hazardous commodity</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="25"/>
                                                                                                                                          <xsd:minLength value="4"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="  " minOccurs="0" name="_759">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Reportable Quantity Code" xml:lang="en">Description: Code to identify presence of hazardous substance</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="2"/>
                                                                                                                                          <xsd:minLength value="2"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="2"/>
                                                                                                                                          <xsd:minLength value="2"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="0" minOccurs="0" name="_408">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Temperature" xml:lang="en">Description: Temperature</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:R">
                                                                                                                                          <xsd:minInclusive value="-9999"/>
                                                                                                                                          <xsd:maxInclusive value="9999"/>
                                                                                                                                          <xsd:totalDigits value="4"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="2"/>
                                                                                                                                          <xsd:minLength value="2"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="0" minOccurs="0" name="_408">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Temperature" xml:lang="en">Description: Temperature</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:R">
                                                                                                                                          <xsd:minInclusive value="-9999"/>
                                                                                                                                          <xsd:maxInclusive value="9999"/>
                                                                                                                                          <xsd:totalDigits value="4"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="2"/>
                                                                                                                                          <xsd:minLength value="2"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="0" minOccurs="0" name="_408">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Temperature" xml:lang="en">Description: Temperature</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:R">
                                                                                                                                          <xsd:minInclusive value="-9999"/>
                                                                                                                                          <xsd:maxInclusive value="9999"/>
                                                                                                                                          <xsd:totalDigits value="4"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                  </xsd:sequence>
                                                                                                                                </xsd:extension>
                                                                                                                              </xsd:complexContent>
                                                                                                                            </xsd:complexType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element maxOccurs="10" minOccurs="0" name="LH3">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Hazardous Material Shipping Name" xml:lang="en">Purpose: To specify the hazardous material shipping name and additional descriptive requirements
Semantics: If LH304 is "Y", then this is an Association of American Railroads Operations and Transportation Bulletin 55 commodity. If "N", it is not an Association of American Railroads Operations and Transportation Bulletin 55 commodity.


Syntax Rules:
P0102 : If either LH301 or LH302 is present, then the other is required.
</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:complexType>
                                                                                                                              <xsd:complexContent>
                                                                                                                                <xsd:extension base="ansix12:Segment">
                                                                                                                                  <xsd:sequence>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_224">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Material Shipping Name" xml:lang="en">Description: The proper shipping name of the hazardous commodity as specified by the Code of Federal Regulations, Title 49</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="25"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_984">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Material Shipping Name Qualifier" xml:lang="en">Description: Qualifier indicating the source (regulatory) of the proper shipping name</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="1"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="   " minOccurs="0" name="_985">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="N.O.S. Indicator Code" xml:lang="en">Description: Code indicating the type of regulatory requirements that apply to a description; N.O.S. stands for Not Otherwise Specified</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="3"/>
                                                                                                                                          <xsd:minLength value="3"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_1073">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Yes/No Condition or Response Code" xml:lang="en">Description: Code indicating a Yes or No condition or response</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="1"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                  </xsd:sequence>
                                                                                                                                </xsd:extension>
                                                                                                                              </xsd:complexContent>
                                                                                                                            </xsd:complexType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element maxOccurs="20" minOccurs="0" name="LFH">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Freeform Hazardous Material Information" xml:lang="en">Purpose: To uniquely identify the variable information required by government regulation covering the transportation of hazardous material shipments
Semantics: LFH06 indicates activity of the radioactive material.

LFH07 indicates transport index of the radioactive material.


Syntax Rules:
P0506 : If either LFH05 or LFH06 is present, then the other is required.
</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:complexType>
                                                                                                                              <xsd:complexContent>
                                                                                                                                <xsd:extension base="ansix12:Segment">
                                                                                                                                  <xsd:sequence>
                                                                                                                                    <xsd:element default="   " name="_808">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Material Shipment Information Qualifier" xml:lang="en">Description: Qualifier indicating the type of information being passed so that a receiver may format a description of hazardous commodity movements that meets regulatory requirements</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="3"/>
                                                                                                                                          <xsd:minLength value="3"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " name="_809">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Material Shipment Information" xml:lang="en">Description: Specific information required by law for hazardous material shipments</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="25"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_809">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Material Shipment Information" xml:lang="en">Description: Specific information required by law for hazardous material shipments</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="25"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_1023">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazard Zone Code" xml:lang="en">Description: Code specifying the Department of Transportation assigned zone designating the Inhalation Toxicity Hazard Zone</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="1"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="2"/>
                                                                                                                                          <xsd:minLength value="2"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="0" minOccurs="0" name="_380">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:R">
                                                                                                                                          <xsd:minInclusive value="-999999999999999"/>
                                                                                                                                          <xsd:maxInclusive value="999999999999999"/>
                                                                                                                                          <xsd:totalDigits value="15"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="0" minOccurs="0" name="_380">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:R">
                                                                                                                                          <xsd:minInclusive value="-999999999999999"/>
                                                                                                                                          <xsd:maxInclusive value="999999999999999"/>
                                                                                                                                          <xsd:totalDigits value="15"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                  </xsd:sequence>
                                                                                                                                </xsd:extension>
                                                                                                                              </xsd:complexContent>
                                                                                                                            </xsd:complexType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element maxOccurs="3" minOccurs="0" name="LEP">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="EPA Required Data" xml:lang="en">Purpose: To specify the Environmental Protection Agency (EPA) information relating to shipments of hazardous material
Semantics: LEP03 is used to identify the state or province responsible for the hazardous waste number contained in LEP04.

LEP04 is the hazardous waste number.


Syntax Rules:
P0304 : If either LEP03 or LEP04 is present, then the other is required.
</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:complexType>
                                                                                                                              <xsd:complexContent>
                                                                                                                                <xsd:extension base="ansix12:Segment">
                                                                                                                                  <xsd:sequence>
                                                                                                                                    <xsd:element default="    " minOccurs="0" name="_806">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="EPA Waste Stream Number Code" xml:lang="en">Description: Waste stream number applicable to the movement of hazardous waste as determined by government regulations</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="6"/>
                                                                                                                                          <xsd:minLength value="4"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="            " minOccurs="0" name="_807">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Waste Characteristics Code" xml:lang="en">Description: Waste characteristics as defined by regulatory requirements</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="16"/>
                                                                                                                                          <xsd:minLength value="12"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="  " minOccurs="0" name="_156">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="State or Province Code" xml:lang="en">Description: Code (Standard State/Province) as defined by appropriate government agency</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="2"/>
                                                                                                                                          <xsd:minLength value="2"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="30"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                  </xsd:sequence>
                                                                                                                                </xsd:extension>
                                                                                                                              </xsd:complexContent>
                                                                                                                            </xsd:complexType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element maxOccurs="1" minOccurs="0" name="LH4">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Canadian Dangerous Requirements" xml:lang="en">Purpose: To specify additional Transport Canada requirements covering transportation of dangerous goods in Canada
Semantics: LH411 is an additional telephone number.


Comments: LH402 is used for the emergency response plan telephone number.

LH404 is for the first subsidiary classification.

LH405 is for the second subsidiary classification.

LH406 is for the third subsidiary classification.


Syntax Rules:
P0812 : If either LH408 or LH412 is present, then the other is required.
</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:complexType>
                                                                                                                              <xsd:complexContent>
                                                                                                                                <xsd:extension base="ansix12:Segment">
                                                                                                                                  <xsd:sequence>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_238">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Emergency Response Plan Number" xml:lang="en">Description: The identity number of a specific hazardous emergency response plan that is assigned by the Director General of Canada</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="12"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_364">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Communication Number" xml:lang="en">Description: Complete communications number including country or area code when applicable</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="80"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_254">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Packing Group Code" xml:lang="en">Description: Code indicating degree of danger in terms of Roman number I, II or III</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="3"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_230">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Subsidiary Classification" xml:lang="en">Description: Code indicating the classification of dangerous goods, other than the primary classification, that is associated with a number or a set of numbers</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="3"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_230">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Subsidiary Classification" xml:lang="en">Description: Code indicating the classification of dangerous goods, other than the primary classification, that is associated with a number or a set of numbers</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="3"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_230">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Subsidiary Classification" xml:lang="en">Description: Code indicating the classification of dangerous goods, other than the primary classification, that is associated with a number or a set of numbers</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="3"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_271">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Subsidiary Risk Indicator" xml:lang="en">Description: Code identifying the type of subsidiary risk</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="2"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="0" minOccurs="0" name="_267">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Net Explosive Quantity" xml:lang="en">Description: Net weight of the explosive quantity of the hazardous commodity</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:N">
                                                                                                                                          <xsd:minInclusive value="-999999"/>
                                                                                                                                          <xsd:maxInclusive value="999999"/>
                                                                                                                                          <xsd:totalDigits value="6"/>
                                                                                                                                          <xsd:fractionDigits value="0"/>
                                                                                                                                          <xsd:minLength value="0"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_805">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Canadian Hazardous Notation" xml:lang="en">Description: Notation required by Canadian regulatory agencies</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="25"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_986">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Special Commodity Indicator Code" xml:lang="en">Description: Code indicating 'Special Commodity' notation on operational waybill as identified by the Transportation of Dangerous Goods Act and Regulation (TDG)</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="1"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_364">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Communication Number" xml:lang="en">Description: Complete communications number including country or area code when applicable</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="80"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="2"/>
                                                                                                                                          <xsd:minLength value="2"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                  </xsd:sequence>
                                                                                                                                </xsd:extension>
                                                                                                                              </xsd:complexContent>
                                                                                                                            </xsd:complexType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element maxOccurs="3" minOccurs="0" name="LHT">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Transborder Hazardous Requirements" xml:lang="en">Purpose: To specify the placard information required by the second government agency when shipment is to cross into another country</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:complexType>
                                                                                                                              <xsd:complexContent>
                                                                                                                                <xsd:extension base="ansix12:Segment">
                                                                                                                                  <xsd:sequence>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_215">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Classification" xml:lang="en">Description: The hazardous classification corresponding to the shipping name of the hazardous commodity</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="30"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="              " minOccurs="0" name="_218">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Placard Notation" xml:lang="en">Description: The placard notation corresponding to the hazard class of the hazardous commodity</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="40"/>
                                                                                                                                          <xsd:minLength value="14"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="    " minOccurs="0" name="_222">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Endorsement" xml:lang="en">Description: The placard endorsement that is to be shown on the shipping papers for the hazardous commodity</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="25"/>
                                                                                                                                          <xsd:minLength value="4"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                  </xsd:sequence>
                                                                                                                                </xsd:extension>
                                                                                                                              </xsd:complexContent>
                                                                                                                            </xsd:complexType>
                                                                                                                          </xsd:element>
                                                                                                                        </xsd:sequence>
                                                                                                                      </xsd:extension>
                                                                                                                    </xsd:complexContent>
                                                                                                                  </xsd:complexType>
                                                                                                                </xsd:element>
                                                                                                              </xsd:sequence>
                                                                                                            </xsd:extension>
                                                                                                          </xsd:complexContent>
                                                                                                        </xsd:complexType>
                                                                                                      </xsd:element>
                                                                                                    </xsd:sequence>
                                                                                                  </xsd:extension>
                                                                                                </xsd:complexContent>
                                                                                              </xsd:complexType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="999" minOccurs="0" name="S0350">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Order Identification Detail" xml:lang="en">Purpose: To specify order identification detail
Notes: Use loop 0350 for conveying seller's order/invoice level detail or buyer's purchase order level detail. If not using order level detail, this loop should not be used.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:SegmentGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element maxOccurs="1" minOccurs="0" name="OID">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Order Identification Detail" xml:lang="en">Purpose: To specify order identification detail
Notes: Use loop 0350 for conveying seller's order/invoice level detail or buyer's purchase order level detail. If not using order level detail, this loop should not be used.
Semantics: OID01 is the seller's order identification number.

OID03 is the number assigned by the consignee to further define the purchase order number.


Syntax Rules:
R0102 : At least one of OID01 or OID02 is required.
C0302 : If OID03 is present, then OID02 is required.
P0405 : If either OID04 or OID05 is present, then the other is required.
P0607 : If either OID06 or OID07 is present, then the other is required.
P0809 : If either OID08 or OID09 is present, then the other is required.
</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:complexType>
                                                                            <xsd:complexContent>
                                                                              <xsd:extension base="ansix12:Segment">
                                                                                <xsd:sequence>
                                                                                  <xsd:element default=" " minOccurs="0" name="_127">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="30"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_324">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Purchase Order Number" xml:lang="en">Description: Identifying number for Purchase Order assigned by the orderer/purchaser</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="22"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_127">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="30"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_355">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="2"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_380">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:R">
                                                                                        <xsd:minInclusive value="-999999999999999"/>
                                                                                        <xsd:maxInclusive value="999999999999999"/>
                                                                                        <xsd:totalDigits value="15"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_188">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="1"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_81">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:R">
                                                                                        <xsd:minInclusive value="-9999999999"/>
                                                                                        <xsd:maxInclusive value="9999999999"/>
                                                                                        <xsd:totalDigits value="10"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_184">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Volume Unit Qualifier" xml:lang="en">Description: Code identifying the volume unit</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="1"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_183">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Volume" xml:lang="en">Description: Value of volumetric measure</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:R">
                                                                                        <xsd:minInclusive value="-99999999"/>
                                                                                        <xsd:maxInclusive value="99999999"/>
                                                                                        <xsd:totalDigits value="8"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="2" minOccurs="0" name="G62">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Date/Time" xml:lang="en">Purpose: To specify pertinent dates and times
Syntax Rules:
R0103 : At least one of G6201 or G6203 is required.
P0102 : If either G6201 or G6202 is present, then the other is required.
P0304 : If either G6203 or G6204 is present, then the other is required.
</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="  " minOccurs="0" name="_432">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Date Qualifier" xml:lang="en">Description: Code specifying type of date</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="        " minOccurs="0" name="_373">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Date" xml:lang="en">Description: Date expressed as CCYYMMDD</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:DT">
                                                                                                  <xsd:length value="8"/>
                                                                                                  <xsd:minLength value="8"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_176">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Time Qualifier" xml:lang="en">Description: Code specifying the reported time</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="    " minOccurs="0" name="_337">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Time" xml:lang="en">Description: Time expressed in 24-hour clock time as follows: HHMM, or HHMMSS, or HHMMSSD, or HHMMSSDD, where H = hours (00-23), M = minutes (00-59), S = integer seconds (00-59) and DD = decimal seconds; decimal seconds are expressed as follows: D = tenths (0-9) and DD = hundredths (00-99)</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:TM">
                                                                                                  <xsd:length value="8"/>
                                                                                                  <xsd:minLength value="4"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_623">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Time Code" xml:lang="en">Description: Code identifying the time. In accordance with International Standards Organization standard 8601, time can be specified by a + or - and an indication in hours in relation to Universal Time Coordinate (UTC) time; since + is a restricted character, + and - are substituted by P and M in the codes that follow</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="999" minOccurs="0" name="LAD">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Lading Detail" xml:lang="en">Purpose: To transmit detailed lading data pertinent to a pickup or delivery
Syntax Rules:
P0102 : If either LAD01 or LAD02 is present, then the other is required.
P0304 : If either LAD03 or LAD04 is present, then the other is required.
P0506 : If either LAD05 or LAD06 is present, then the other is required.
P0708 : If either LAD07 or LAD08 is present, then the other is required.
P0910 : If either LAD09 or LAD10 is present, then the other is required.
P1112 : If either LAD11 or LAD12 is present, then the other is required.
</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="   " minOccurs="0" name="_211">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Packaging Form Code" xml:lang="en">Description: Code for packaging form of the lading quantity</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="3"/>
                                                                                                  <xsd:minLength value="3"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_80">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Lading Quantity" xml:lang="en">Description: Number of units (pieces) of the lading commodity</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:N">
                                                                                                  <xsd:minInclusive value="-9999999"/>
                                                                                                  <xsd:maxInclusive value="9999999"/>
                                                                                                  <xsd:totalDigits value="7"/>
                                                                                                  <xsd:fractionDigits value="0"/>
                                                                                                  <xsd:minLength value="0"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_188">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="1"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_395">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Unit Weight" xml:lang="en">Description: Numeric value of weight per unit</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-99999999"/>
                                                                                                  <xsd:maxInclusive value="99999999"/>
                                                                                                  <xsd:totalDigits value="8"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_188">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="1"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_81">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-9999999999"/>
                                                                                                  <xsd:maxInclusive value="9999999999"/>
                                                                                                  <xsd:totalDigits value="10"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_235">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Product/Service ID Qualifier" xml:lang="en">Description: Code identifying the type/source of the descriptive number used in Product/Service ID (234)</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_234">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Product/Service ID" xml:lang="en">Description: Identifying number for a product or service</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="48"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_235">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Product/Service ID Qualifier" xml:lang="en">Description: Code identifying the type/source of the descriptive number used in Product/Service ID (234)</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_234">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Product/Service ID" xml:lang="en">Description: Identifying number for a product or service</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="48"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_235">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Product/Service ID Qualifier" xml:lang="en">Description: Code identifying the type/source of the descriptive number used in Product/Service ID (234)</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_234">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Product/Service ID" xml:lang="en">Description: Identifying number for a product or service</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="48"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_79">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Lading Description" xml:lang="en">Description: Description of an item as required for rating and billing purposes</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="50"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="99" minOccurs="0" name="S0360">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Description, Marks and Numbers" xml:lang="en">Purpose: To specify the line item in terms of description, quantity, packaging, and marks and numbers
Notes: If sending order level detail within the 0350 loop, then use L5 and AT8 segments in loop 0360 to relay commodity detail. Otherwise, use L5 and AT8 segments within the 0320 loop to relay commodity detail. Use either loop 0320 or loop 0360, but not both.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:SegmentGroup">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element maxOccurs="1" minOccurs="0" name="L5">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Description, Marks and Numbers" xml:lang="en">Purpose: To specify the line item in terms of description, quantity, packaging, and marks and numbers
Notes: If sending order level detail within the 0350 loop, then use L5 and AT8 segments in loop 0360 to relay commodity detail. Otherwise, use L5 and AT8 segments within the 0320 loop to relay commodity detail. Use either loop 0320 or loop 0360, but not both.
Comments: L502 may be used to send quantity information as part of the product description.


Syntax Rules:
P0304 : If either L503 or L504 is present, then the other is required.
C0706 : If L507 is present, then L506 is required.
P0809 : If either L508 or L509 is present, then the other is required.
</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:complexType>
                                                                                                <xsd:complexContent>
                                                                                                  <xsd:extension base="ansix12:Segment">
                                                                                                    <xsd:sequence>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_213">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Lading Line Item Number" xml:lang="en">Description: Sequential line number for a lading item</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:N">
                                                                                                            <xsd:minInclusive value="-999"/>
                                                                                                            <xsd:maxInclusive value="999"/>
                                                                                                            <xsd:totalDigits value="3"/>
                                                                                                            <xsd:fractionDigits value="0"/>
                                                                                                            <xsd:minLength value="0"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_79">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Lading Description" xml:lang="en">Description: Description of an item as required for rating and billing purposes</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="50"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_22">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Commodity Code" xml:lang="en">Description: Code describing a commodity or group of commodities</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="30"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_23">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Commodity Code Qualifier" xml:lang="en">Description: Code identifying the commodity coding system used for Commodity Code</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="1"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="   " minOccurs="0" name="_103">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Packaging Code" xml:lang="en">Description: Code identifying the type of packaging; Part 1: Packaging Form, Part 2: Packaging Material; if the Data Element is used, then Part 1 is always required</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="5"/>
                                                                                                            <xsd:minLength value="3"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_87">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Marks and Numbers" xml:lang="en">Description: Marks and numbers used to identify a shipment or parts of a shipment</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="48"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_88">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Marks and Numbers Qualifier" xml:lang="en">Description: Code specifying the application or source of Marks and Numbers (87)</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_23">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Commodity Code Qualifier" xml:lang="en">Description: Code identifying the commodity coding system used for Commodity Code</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="1"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_22">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Commodity Code" xml:lang="en">Description: Code describing a commodity or group of commodities</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="30"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_595">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Compartment ID Code" xml:lang="en">Description: Code identifying the compartment in a compartmentalized tank car</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="1"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element maxOccurs="1" minOccurs="0" name="AT8">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Shipment Weight, Packaging and Quantity Data" xml:lang="en">Purpose: To specify shipment details in terms of weight, and quantity of handling units
Notes: Accumulated weights, quantities, and volumes sent in the AT8 segment in loop 0360 should total to the weight, quantity, and volume in the OID segment in loop 0350. Accumulated weights and quantities in the LAD segment in loop 0350 should total to the weight and quantity in the OID segment in loop 0350.
Semantics: AT804 is the quantity of handling units that are not unitized (for example a carton). When added to the quantity in AT805, it is the total quantity of handling units in the shipment.

AT805 is the quantity of handling units that are unitized (for example on a pallet or slip sheet). When added to the quantity in AT804 it is the total quantity of handling units for the shipment.


Syntax Rules:
P010203 : If either AT801, AT802 or AT803 is present, then the other is required.
P0607 : If either AT806 or AT807 is present, then the other is required.
</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:complexType>
                                                                                                          <xsd:complexContent>
                                                                                                            <xsd:extension base="ansix12:Segment">
                                                                                                              <xsd:sequence>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_187">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Weight Qualifier" xml:lang="en">Description: Code defining the type of weight</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="2"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_188">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="1"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="0" minOccurs="0" name="_81">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:R">
                                                                                                                      <xsd:minInclusive value="-9999999999"/>
                                                                                                                      <xsd:maxInclusive value="9999999999"/>
                                                                                                                      <xsd:totalDigits value="10"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="0" minOccurs="0" name="_80">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Lading Quantity" xml:lang="en">Description: Number of units (pieces) of the lading commodity</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:N">
                                                                                                                      <xsd:minInclusive value="-9999999"/>
                                                                                                                      <xsd:maxInclusive value="9999999"/>
                                                                                                                      <xsd:totalDigits value="7"/>
                                                                                                                      <xsd:fractionDigits value="0"/>
                                                                                                                      <xsd:minLength value="0"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="0" minOccurs="0" name="_80">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Lading Quantity" xml:lang="en">Description: Number of units (pieces) of the lading commodity</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:N">
                                                                                                                      <xsd:minInclusive value="-9999999"/>
                                                                                                                      <xsd:maxInclusive value="9999999"/>
                                                                                                                      <xsd:totalDigits value="7"/>
                                                                                                                      <xsd:fractionDigits value="0"/>
                                                                                                                      <xsd:minLength value="0"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_184">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Volume Unit Qualifier" xml:lang="en">Description: Code identifying the volume unit</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="1"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="0" minOccurs="0" name="_183">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Volume" xml:lang="en">Description: Value of volumetric measure</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:R">
                                                                                                                      <xsd:minInclusive value="-99999999"/>
                                                                                                                      <xsd:maxInclusive value="99999999"/>
                                                                                                                      <xsd:totalDigits value="8"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                              </xsd:sequence>
                                                                                                            </xsd:extension>
                                                                                                          </xsd:complexContent>
                                                                                                        </xsd:complexType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element maxOccurs="99" minOccurs="0" name="S0365">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Contact" xml:lang="en">Purpose: To identify a person or office to whom communications should be directed
Notes: The G61 segment contains the person or company to be contacted by the carrier in case of emergency.</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:complexType>
                                                                                                          <xsd:complexContent>
                                                                                                            <xsd:extension base="ansix12:SegmentGroup">
                                                                                                              <xsd:sequence>
                                                                                                                <xsd:element maxOccurs="1" minOccurs="0" name="G61">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Contact" xml:lang="en">Purpose: To identify a person or office to whom communications should be directed
Notes: The G61 segment contains the person or company to be contacted by the carrier in case of emergency.
Comments: G6103 qualifies G6104.


Syntax Rules:
P0304 : If either G6103 or G6104 is present, then the other is required.
</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:complexType>
                                                                                                                    <xsd:complexContent>
                                                                                                                      <xsd:extension base="ansix12:Segment">
                                                                                                                        <xsd:sequence>
                                                                                                                          <xsd:element default="  " name="_366">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Contact Function Code" xml:lang="en">Description: Code identifying the major duty or responsibility of the person or group named</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="2"/>
                                                                                                                                <xsd:minLength value="2"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default=" " name="_93">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="60"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default="  " minOccurs="0" name="_365">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Communication Number Qualifier" xml:lang="en">Description: Code identifying the type of communication number</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="2"/>
                                                                                                                                <xsd:minLength value="2"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default=" " minOccurs="0" name="_364">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Communication Number" xml:lang="en">Description: Complete communications number including country or area code when applicable</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="80"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default=" " minOccurs="0" name="_443">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Contact Inquiry Reference" xml:lang="en">Description: Additional reference number or description to clarify a contact number</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="20"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element maxOccurs="5" minOccurs="0" name="L11">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Business Instructions and Reference Number" xml:lang="en">Purpose: To specify instructions in this business relationship or a reference number
Notes: The L11 segment contains the specific hazardous material reference numbers. Used in loop 0365 it pertains to all iterations of loop 0370 following.
Syntax Rules:
R0103 : At least one of L1101 or L1103 is required.
P0102 : If either L1101 or L1102 is present, then the other is required.
</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:complexType>
                                                                                                                              <xsd:complexContent>
                                                                                                                                <xsd:extension base="ansix12:Segment">
                                                                                                                                  <xsd:sequence>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="30"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default="  " minOccurs="0" name="_128">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="3"/>
                                                                                                                                          <xsd:minLength value="2"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_352">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Description" xml:lang="en">Description: A free-form description to clarify the related data elements and their content</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="80"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                  </xsd:sequence>
                                                                                                                                </xsd:extension>
                                                                                                                              </xsd:complexContent>
                                                                                                                            </xsd:complexType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element maxOccurs="6" minOccurs="0" name="LH6">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Hazardous Certification" xml:lang="en">Purpose: To specify the name of the person certifying that the shipment complies with the regulations and/or the actual certification
Syntax Rules:
P0203 : If either LH602 or LH603 is present, then the other is required.
</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:complexType>
                                                                                                                              <xsd:complexContent>
                                                                                                                                <xsd:extension base="ansix12:Segment">
                                                                                                                                  <xsd:sequence>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_93">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="60"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_272">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Certification Code" xml:lang="en">Description: Code indicating the form of the hazardous certification</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="1"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_273">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Certification Declaration" xml:lang="en">Description: Hazardous material certification verbiage as required by Title 49 of Code of Federal Regulations</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="25"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                    <xsd:element default=" " minOccurs="0" name="_273">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Certification Declaration" xml:lang="en">Description: Hazardous material certification verbiage as required by Title 49 of Code of Federal Regulations</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:simpleType>
                                                                                                                                        <xsd:restriction base="ansix12:AN">
                                                                                                                                          <xsd:length value="25"/>
                                                                                                                                          <xsd:minLength value="1"/>
                                                                                                                                        </xsd:restriction>
                                                                                                                                      </xsd:simpleType>
                                                                                                                                    </xsd:element>
                                                                                                                                  </xsd:sequence>
                                                                                                                                </xsd:extension>
                                                                                                                              </xsd:complexContent>
                                                                                                                            </xsd:complexType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element maxOccurs="25" minOccurs="0" name="S0370">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Hazardous Identification Information" xml:lang="en">Purpose: To specify the hazardous commodity identification reference number and quantity</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:complexType>
                                                                                                                              <xsd:complexContent>
                                                                                                                                <xsd:extension base="ansix12:SegmentGroup">
                                                                                                                                  <xsd:sequence>
                                                                                                                                    <xsd:element maxOccurs="1" minOccurs="0" name="LH1">
                                                                                                                                      <xsd:annotation>
                                                                                                                                        <xsd:documentation bic:title="Hazardous Identification Information" xml:lang="en">Purpose: To specify the hazardous commodity identification reference number and quantity
Comments: LH101 and LH102 are used to convey the number and type of packages for bulk and nonbulk movements.

LH106 and LH107 are used to convey the quantity or volume and unit of measure for nonbulk shipments only.

In LH109, a value of "R" or "P" requires that the receiver generate the words "residue: last contained" prior to the shipping name in accordance with regulations.

</xsd:documentation>
                                                                                                                                      </xsd:annotation>
                                                                                                                                      <xsd:complexType>
                                                                                                                                        <xsd:complexContent>
                                                                                                                                          <xsd:extension base="ansix12:Segment">
                                                                                                                                            <xsd:sequence>
                                                                                                                                              <xsd:element default="  " name="_355">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:simpleType>
                                                                                                                                                  <xsd:restriction base="ansix12:AN">
                                                                                                                                                    <xsd:length value="2"/>
                                                                                                                                                    <xsd:minLength value="2"/>
                                                                                                                                                  </xsd:restriction>
                                                                                                                                                </xsd:simpleType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element default="0" name="_80">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Lading Quantity" xml:lang="en">Description: Number of units (pieces) of the lading commodity</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:simpleType>
                                                                                                                                                  <xsd:restriction base="ansix12:N">
                                                                                                                                                    <xsd:minInclusive value="-9999999"/>
                                                                                                                                                    <xsd:maxInclusive value="9999999"/>
                                                                                                                                                    <xsd:totalDigits value="7"/>
                                                                                                                                                    <xsd:fractionDigits value="0"/>
                                                                                                                                                    <xsd:minLength value="0"/>
                                                                                                                                                  </xsd:restriction>
                                                                                                                                                </xsd:simpleType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element default="      " minOccurs="0" name="_277">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="UN/NA Identification Code" xml:lang="en">Description: Code identifying the hazardous material identification number as required by Title 49 of the code of Federal Regulations; UN/NA stands for United Nations/North America</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:simpleType>
                                                                                                                                                  <xsd:restriction base="ansix12:AN">
                                                                                                                                                    <xsd:length value="6"/>
                                                                                                                                                    <xsd:minLength value="6"/>
                                                                                                                                                  </xsd:restriction>
                                                                                                                                                </xsd:simpleType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element default=" " minOccurs="0" name="_200">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Hazardous Materials Page" xml:lang="en">Description: The United Nations page number as required for the international transport of hazardous materials</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:simpleType>
                                                                                                                                                  <xsd:restriction base="ansix12:AN">
                                                                                                                                                    <xsd:length value="6"/>
                                                                                                                                                    <xsd:minLength value="1"/>
                                                                                                                                                  </xsd:restriction>
                                                                                                                                                </xsd:simpleType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element default=" " minOccurs="0" name="_22">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Commodity Code" xml:lang="en">Description: Code describing a commodity or group of commodities</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:simpleType>
                                                                                                                                                  <xsd:restriction base="ansix12:AN">
                                                                                                                                                    <xsd:length value="30"/>
                                                                                                                                                    <xsd:minLength value="1"/>
                                                                                                                                                  </xsd:restriction>
                                                                                                                                                </xsd:simpleType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:simpleType>
                                                                                                                                                  <xsd:restriction base="ansix12:AN">
                                                                                                                                                    <xsd:length value="2"/>
                                                                                                                                                    <xsd:minLength value="2"/>
                                                                                                                                                  </xsd:restriction>
                                                                                                                                                </xsd:simpleType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element default="0" minOccurs="0" name="_380">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:simpleType>
                                                                                                                                                  <xsd:restriction base="ansix12:R">
                                                                                                                                                    <xsd:minInclusive value="-999999999999999"/>
                                                                                                                                                    <xsd:maxInclusive value="999999999999999"/>
                                                                                                                                                    <xsd:totalDigits value="15"/>
                                                                                                                                                    <xsd:minLength value="1"/>
                                                                                                                                                  </xsd:restriction>
                                                                                                                                                </xsd:simpleType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element default=" " minOccurs="0" name="_595">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Compartment ID Code" xml:lang="en">Description: Code identifying the compartment in a compartmentalized tank car</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:simpleType>
                                                                                                                                                  <xsd:restriction base="ansix12:AN">
                                                                                                                                                    <xsd:length value="1"/>
                                                                                                                                                    <xsd:minLength value="1"/>
                                                                                                                                                  </xsd:restriction>
                                                                                                                                                </xsd:simpleType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element default=" " minOccurs="0" name="_665">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Residue Indicator Code" xml:lang="en">Description: Code indicating that the material being described is that which remains in a packaging (including a tank car) after it has been unloaded</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:simpleType>
                                                                                                                                                  <xsd:restriction base="ansix12:AN">
                                                                                                                                                    <xsd:length value="1"/>
                                                                                                                                                    <xsd:minLength value="1"/>
                                                                                                                                                  </xsd:restriction>
                                                                                                                                                </xsd:simpleType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element default=" " minOccurs="0" name="_254">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Packing Group Code" xml:lang="en">Description: Code indicating degree of danger in terms of Roman number I, II or III</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:simpleType>
                                                                                                                                                  <xsd:restriction base="ansix12:AN">
                                                                                                                                                    <xsd:length value="3"/>
                                                                                                                                                    <xsd:minLength value="1"/>
                                                                                                                                                  </xsd:restriction>
                                                                                                                                                </xsd:simpleType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element default=" " minOccurs="0" name="_1375">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Interim Hazardous Material Regulatory Number" xml:lang="en">Description: Identifies the current regulatory version number used for hazardous materials shipments</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:simpleType>
                                                                                                                                                  <xsd:restriction base="ansix12:AN">
                                                                                                                                                    <xsd:length value="5"/>
                                                                                                                                                    <xsd:minLength value="1"/>
                                                                                                                                                  </xsd:restriction>
                                                                                                                                                </xsd:simpleType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element maxOccurs="4" minOccurs="0" name="LH2">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Hazardous Classification Information" xml:lang="en">Purpose: To specify the hazardous notation and endorsement information
Semantics: LH206 and LH207 indicate the flashpoint temperature.

LH208 and LH209 indicate the control temperature.

LH210 and LH211 indicate the emergency temperature.


Syntax Rules:
P0607 : If either LH206 or LH207 is present, then the other is required.
P0809 : If either LH208 or LH209 is present, then the other is required.
P1011 : If either LH210 or LH211 is present, then the other is required.
</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:complexType>
                                                                                                                                                  <xsd:complexContent>
                                                                                                                                                    <xsd:extension base="ansix12:Segment">
                                                                                                                                                      <xsd:sequence>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_215">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazardous Classification" xml:lang="en">Description: The hazardous classification corresponding to the shipping name of the hazardous commodity</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="30"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_983">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazardous Class Qualifier" xml:lang="en">Description: Code qualifying hazardous class</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="1"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="              " minOccurs="0" name="_218">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazardous Placard Notation" xml:lang="en">Description: The placard notation corresponding to the hazard class of the hazardous commodity</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="40"/>
                                                                                                                                                              <xsd:minLength value="14"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="    " minOccurs="0" name="_222">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazardous Endorsement" xml:lang="en">Description: The placard endorsement that is to be shown on the shipping papers for the hazardous commodity</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="25"/>
                                                                                                                                                              <xsd:minLength value="4"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="  " minOccurs="0" name="_759">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Reportable Quantity Code" xml:lang="en">Description: Code to identify presence of hazardous substance</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="2"/>
                                                                                                                                                              <xsd:minLength value="2"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="2"/>
                                                                                                                                                              <xsd:minLength value="2"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="0" minOccurs="0" name="_408">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Temperature" xml:lang="en">Description: Temperature</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:R">
                                                                                                                                                              <xsd:minInclusive value="-9999"/>
                                                                                                                                                              <xsd:maxInclusive value="9999"/>
                                                                                                                                                              <xsd:totalDigits value="4"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="2"/>
                                                                                                                                                              <xsd:minLength value="2"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="0" minOccurs="0" name="_408">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Temperature" xml:lang="en">Description: Temperature</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:R">
                                                                                                                                                              <xsd:minInclusive value="-9999"/>
                                                                                                                                                              <xsd:maxInclusive value="9999"/>
                                                                                                                                                              <xsd:totalDigits value="4"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="2"/>
                                                                                                                                                              <xsd:minLength value="2"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="0" minOccurs="0" name="_408">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Temperature" xml:lang="en">Description: Temperature</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:R">
                                                                                                                                                              <xsd:minInclusive value="-9999"/>
                                                                                                                                                              <xsd:maxInclusive value="9999"/>
                                                                                                                                                              <xsd:totalDigits value="4"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                      </xsd:sequence>
                                                                                                                                                    </xsd:extension>
                                                                                                                                                  </xsd:complexContent>
                                                                                                                                                </xsd:complexType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element maxOccurs="10" minOccurs="0" name="LH3">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Hazardous Material Shipping Name" xml:lang="en">Purpose: To specify the hazardous material shipping name and additional descriptive requirements
Semantics: If LH304 is "Y", then this is an Association of American Railroads Operations and Transportation Bulletin 55 commodity. If "N", it is not an Association of American Railroads Operations and Transportation Bulletin 55 commodity.


Syntax Rules:
P0102 : If either LH301 or LH302 is present, then the other is required.
</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:complexType>
                                                                                                                                                  <xsd:complexContent>
                                                                                                                                                    <xsd:extension base="ansix12:Segment">
                                                                                                                                                      <xsd:sequence>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_224">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazardous Material Shipping Name" xml:lang="en">Description: The proper shipping name of the hazardous commodity as specified by the Code of Federal Regulations, Title 49</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="25"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_984">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazardous Material Shipping Name Qualifier" xml:lang="en">Description: Qualifier indicating the source (regulatory) of the proper shipping name</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="1"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="   " minOccurs="0" name="_985">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="N.O.S. Indicator Code" xml:lang="en">Description: Code indicating the type of regulatory requirements that apply to a description; N.O.S. stands for Not Otherwise Specified</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="3"/>
                                                                                                                                                              <xsd:minLength value="3"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_1073">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Yes/No Condition or Response Code" xml:lang="en">Description: Code indicating a Yes or No condition or response</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="1"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                      </xsd:sequence>
                                                                                                                                                    </xsd:extension>
                                                                                                                                                  </xsd:complexContent>
                                                                                                                                                </xsd:complexType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element maxOccurs="20" minOccurs="0" name="LFH">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Freeform Hazardous Material Information" xml:lang="en">Purpose: To uniquely identify the variable information required by government regulation covering the transportation of hazardous material shipments
Semantics: LFH06 indicates activity of the radioactive material.

LFH07 indicates transport index of the radioactive material.


Syntax Rules:
P0506 : If either LFH05 or LFH06 is present, then the other is required.
</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:complexType>
                                                                                                                                                  <xsd:complexContent>
                                                                                                                                                    <xsd:extension base="ansix12:Segment">
                                                                                                                                                      <xsd:sequence>
                                                                                                                                                        <xsd:element default="   " name="_808">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazardous Material Shipment Information Qualifier" xml:lang="en">Description: Qualifier indicating the type of information being passed so that a receiver may format a description of hazardous commodity movements that meets regulatory requirements</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="3"/>
                                                                                                                                                              <xsd:minLength value="3"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " name="_809">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazardous Material Shipment Information" xml:lang="en">Description: Specific information required by law for hazardous material shipments</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="25"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_809">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazardous Material Shipment Information" xml:lang="en">Description: Specific information required by law for hazardous material shipments</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="25"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_1023">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazard Zone Code" xml:lang="en">Description: Code specifying the Department of Transportation assigned zone designating the Inhalation Toxicity Hazard Zone</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="1"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="2"/>
                                                                                                                                                              <xsd:minLength value="2"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="0" minOccurs="0" name="_380">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:R">
                                                                                                                                                              <xsd:minInclusive value="-999999999999999"/>
                                                                                                                                                              <xsd:maxInclusive value="999999999999999"/>
                                                                                                                                                              <xsd:totalDigits value="15"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="0" minOccurs="0" name="_380">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:R">
                                                                                                                                                              <xsd:minInclusive value="-999999999999999"/>
                                                                                                                                                              <xsd:maxInclusive value="999999999999999"/>
                                                                                                                                                              <xsd:totalDigits value="15"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                      </xsd:sequence>
                                                                                                                                                    </xsd:extension>
                                                                                                                                                  </xsd:complexContent>
                                                                                                                                                </xsd:complexType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element maxOccurs="3" minOccurs="0" name="LEP">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="EPA Required Data" xml:lang="en">Purpose: To specify the Environmental Protection Agency (EPA) information relating to shipments of hazardous material
Semantics: LEP03 is used to identify the state or province responsible for the hazardous waste number contained in LEP04.

LEP04 is the hazardous waste number.


Syntax Rules:
P0304 : If either LEP03 or LEP04 is present, then the other is required.
</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:complexType>
                                                                                                                                                  <xsd:complexContent>
                                                                                                                                                    <xsd:extension base="ansix12:Segment">
                                                                                                                                                      <xsd:sequence>
                                                                                                                                                        <xsd:element default="    " minOccurs="0" name="_806">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="EPA Waste Stream Number Code" xml:lang="en">Description: Waste stream number applicable to the movement of hazardous waste as determined by government regulations</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="6"/>
                                                                                                                                                              <xsd:minLength value="4"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="            " minOccurs="0" name="_807">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Waste Characteristics Code" xml:lang="en">Description: Waste characteristics as defined by regulatory requirements</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="16"/>
                                                                                                                                                              <xsd:minLength value="12"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="  " minOccurs="0" name="_156">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="State or Province Code" xml:lang="en">Description: Code (Standard State/Province) as defined by appropriate government agency</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="2"/>
                                                                                                                                                              <xsd:minLength value="2"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="30"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                      </xsd:sequence>
                                                                                                                                                    </xsd:extension>
                                                                                                                                                  </xsd:complexContent>
                                                                                                                                                </xsd:complexType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element maxOccurs="1" minOccurs="0" name="LH4">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Canadian Dangerous Requirements" xml:lang="en">Purpose: To specify additional Transport Canada requirements covering transportation of dangerous goods in Canada
Semantics: LH411 is an additional telephone number.


Comments: LH402 is used for the emergency response plan telephone number.

LH404 is for the first subsidiary classification.

LH405 is for the second subsidiary classification.

LH406 is for the third subsidiary classification.


Syntax Rules:
P0812 : If either LH408 or LH412 is present, then the other is required.
</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:complexType>
                                                                                                                                                  <xsd:complexContent>
                                                                                                                                                    <xsd:extension base="ansix12:Segment">
                                                                                                                                                      <xsd:sequence>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_238">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Emergency Response Plan Number" xml:lang="en">Description: The identity number of a specific hazardous emergency response plan that is assigned by the Director General of Canada</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="12"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_364">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Communication Number" xml:lang="en">Description: Complete communications number including country or area code when applicable</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="80"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_254">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Packing Group Code" xml:lang="en">Description: Code indicating degree of danger in terms of Roman number I, II or III</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="3"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_230">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Subsidiary Classification" xml:lang="en">Description: Code indicating the classification of dangerous goods, other than the primary classification, that is associated with a number or a set of numbers</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="3"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_230">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Subsidiary Classification" xml:lang="en">Description: Code indicating the classification of dangerous goods, other than the primary classification, that is associated with a number or a set of numbers</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="3"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_230">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Subsidiary Classification" xml:lang="en">Description: Code indicating the classification of dangerous goods, other than the primary classification, that is associated with a number or a set of numbers</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="3"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_271">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Subsidiary Risk Indicator" xml:lang="en">Description: Code identifying the type of subsidiary risk</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="2"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="0" minOccurs="0" name="_267">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Net Explosive Quantity" xml:lang="en">Description: Net weight of the explosive quantity of the hazardous commodity</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:N">
                                                                                                                                                              <xsd:minInclusive value="-999999"/>
                                                                                                                                                              <xsd:maxInclusive value="999999"/>
                                                                                                                                                              <xsd:totalDigits value="6"/>
                                                                                                                                                              <xsd:fractionDigits value="0"/>
                                                                                                                                                              <xsd:minLength value="0"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_805">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Canadian Hazardous Notation" xml:lang="en">Description: Notation required by Canadian regulatory agencies</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="25"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_986">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Special Commodity Indicator Code" xml:lang="en">Description: Code indicating 'Special Commodity' notation on operational waybill as identified by the Transportation of Dangerous Goods Act and Regulation (TDG)</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="1"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_364">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Communication Number" xml:lang="en">Description: Complete communications number including country or area code when applicable</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="80"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="2"/>
                                                                                                                                                              <xsd:minLength value="2"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                      </xsd:sequence>
                                                                                                                                                    </xsd:extension>
                                                                                                                                                  </xsd:complexContent>
                                                                                                                                                </xsd:complexType>
                                                                                                                                              </xsd:element>
                                                                                                                                              <xsd:element maxOccurs="3" minOccurs="0" name="LHT">
                                                                                                                                                <xsd:annotation>
                                                                                                                                                  <xsd:documentation bic:title="Transborder Hazardous Requirements" xml:lang="en">Purpose: To specify the placard information required by the second government agency when shipment is to cross into another country</xsd:documentation>
                                                                                                                                                </xsd:annotation>
                                                                                                                                                <xsd:complexType>
                                                                                                                                                  <xsd:complexContent>
                                                                                                                                                    <xsd:extension base="ansix12:Segment">
                                                                                                                                                      <xsd:sequence>
                                                                                                                                                        <xsd:element default=" " minOccurs="0" name="_215">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazardous Classification" xml:lang="en">Description: The hazardous classification corresponding to the shipping name of the hazardous commodity</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="30"/>
                                                                                                                                                              <xsd:minLength value="1"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="              " minOccurs="0" name="_218">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazardous Placard Notation" xml:lang="en">Description: The placard notation corresponding to the hazard class of the hazardous commodity</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="40"/>
                                                                                                                                                              <xsd:minLength value="14"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                        <xsd:element default="    " minOccurs="0" name="_222">
                                                                                                                                                          <xsd:annotation>
                                                                                                                                                            <xsd:documentation bic:title="Hazardous Endorsement" xml:lang="en">Description: The placard endorsement that is to be shown on the shipping papers for the hazardous commodity</xsd:documentation>
                                                                                                                                                          </xsd:annotation>
                                                                                                                                                          <xsd:simpleType>
                                                                                                                                                            <xsd:restriction base="ansix12:AN">
                                                                                                                                                              <xsd:length value="25"/>
                                                                                                                                                              <xsd:minLength value="4"/>
                                                                                                                                                            </xsd:restriction>
                                                                                                                                                          </xsd:simpleType>
                                                                                                                                                        </xsd:element>
                                                                                                                                                      </xsd:sequence>
                                                                                                                                                    </xsd:extension>
                                                                                                                                                  </xsd:complexContent>
                                                                                                                                                </xsd:complexType>
                                                                                                                                              </xsd:element>
                                                                                                                                            </xsd:sequence>
                                                                                                                                          </xsd:extension>
                                                                                                                                        </xsd:complexContent>
                                                                                                                                      </xsd:complexType>
                                                                                                                                    </xsd:element>
                                                                                                                                  </xsd:sequence>
                                                                                                                                </xsd:extension>
                                                                                                                              </xsd:complexContent>
                                                                                                                            </xsd:complexType>
                                                                                                                          </xsd:element>
                                                                                                                        </xsd:sequence>
                                                                                                                      </xsd:extension>
                                                                                                                    </xsd:complexContent>
                                                                                                                  </xsd:complexType>
                                                                                                                </xsd:element>
                                                                                                              </xsd:sequence>
                                                                                                            </xsd:extension>
                                                                                                          </xsd:complexContent>
                                                                                                        </xsd:complexType>
                                                                                                      </xsd:element>
                                                                                                    </xsd:sequence>
                                                                                                  </xsd:extension>
                                                                                                </xsd:complexContent>
                                                                                              </xsd:complexType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="10" minOccurs="0" name="S0380">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Equipment Details" xml:lang="en">Purpose: To identify the equipment</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:SegmentGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element maxOccurs="1" minOccurs="0" name="N7">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Equipment Details" xml:lang="en">Purpose: To identify the equipment
Semantics: N712 is the owner of the equipment.

N723 is the operator or carrier of the rights of the equipment.


Comments: N701 is mandatory for rail transactions.

N720 and N721 are expressed in inches.


Syntax Rules:
P0304 : If either N703 or N704 is present, then the other is required.
P0516 : If either N705 or N716 is present, then the other is required.
P0809 : If either N708 or N709 is present, then the other is required.
</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:complexType>
                                                                            <xsd:complexContent>
                                                                              <xsd:extension base="ansix12:Segment">
                                                                                <xsd:sequence>
                                                                                  <xsd:element default=" " minOccurs="0" name="_206">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Equipment Initial" xml:lang="en">Description: Prefix or alphabetic part of an equipment unit's identifying number</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="4"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " name="_207">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Equipment Number" xml:lang="en">Description: Sequencing or serial part of an equipment unit's identifying number (pure numeric form for equipment number is preferred)</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="10"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_81">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:R">
                                                                                        <xsd:minInclusive value="-9999999999"/>
                                                                                        <xsd:maxInclusive value="9999999999"/>
                                                                                        <xsd:totalDigits value="10"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_187">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Weight Qualifier" xml:lang="en">Description: Code defining the type of weight</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="2"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="000" minOccurs="0" name="_167">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Tare Weight" xml:lang="en">Description: Weight of the equipment</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:N">
                                                                                        <xsd:minInclusive value="-99999999"/>
                                                                                        <xsd:maxInclusive value="99999999"/>
                                                                                        <xsd:totalDigits value="8"/>
                                                                                        <xsd:fractionDigits value="0"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="00" minOccurs="0" name="_232">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Weight Allowance" xml:lang="en">Description: Allowance made for increased weight due to such factors as snow</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:N">
                                                                                        <xsd:minInclusive value="-999999"/>
                                                                                        <xsd:maxInclusive value="999999"/>
                                                                                        <xsd:totalDigits value="6"/>
                                                                                        <xsd:fractionDigits value="0"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_205">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Dunnage" xml:lang="en">Description: Weight of material used to protect lading (even bracings, false floors, etc.)</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:N">
                                                                                        <xsd:minInclusive value="-999999"/>
                                                                                        <xsd:maxInclusive value="999999"/>
                                                                                        <xsd:totalDigits value="6"/>
                                                                                        <xsd:fractionDigits value="0"/>
                                                                                        <xsd:minLength value="0"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_183">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Volume" xml:lang="en">Description: Value of volumetric measure</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:R">
                                                                                        <xsd:minInclusive value="-99999999"/>
                                                                                        <xsd:maxInclusive value="99999999"/>
                                                                                        <xsd:totalDigits value="8"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_184">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Volume Unit Qualifier" xml:lang="en">Description: Code identifying the volume unit</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="1"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_102">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Ownership Code" xml:lang="en">Description: Code indicating the relationship of equipment to carrier or ownership of equipment</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="1"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_40">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Equipment Description Code" xml:lang="en">Description: Code identifying type of equipment used for shipment</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="2"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_140">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Standard Carrier Alpha Code" xml:lang="en">Description: Standard Carrier Alpha Code</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="4"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="   " minOccurs="0" name="_319">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Temperature Control" xml:lang="en">Description: Free-form abbreviation of temperature range or flash-point temperature</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="6"/>
                                                                                        <xsd:minLength value="3"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_219">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Position" xml:lang="en">Description: Relative position of shipment in car, trailer, or container (mutually defined)</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="3"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0000" minOccurs="0" name="_567">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Equipment Length" xml:lang="en">Description: Length (in feet and inches) of equipment ordered or used to transport shipment (The format is FFFII where FFF is feet and II is inches; the range for II is 00 through 11)</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:N">
                                                                                        <xsd:minInclusive value="-99999"/>
                                                                                        <xsd:maxInclusive value="99999"/>
                                                                                        <xsd:totalDigits value="5"/>
                                                                                        <xsd:fractionDigits value="0"/>
                                                                                        <xsd:minLength value="3"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_571">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Tare Qualifier Code" xml:lang="en">Description: Code identifying the type of tare</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="1"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_188">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="1"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_761">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Equipment Number Check Digit" xml:lang="en">Description: Number which designates the check digit applied to a piece of equipment</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:N">
                                                                                        <xsd:totalDigits value="1"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_56">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Type of Service Code" xml:lang="en">Description: Code specifying extent of transportation service requested</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="2"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_65">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Height" xml:lang="en">Description: Vertical dimension of an object measured when the object is in the upright position</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:R">
                                                                                        <xsd:minInclusive value="-99999999"/>
                                                                                        <xsd:maxInclusive value="99999999"/>
                                                                                        <xsd:totalDigits value="8"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_189">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Width" xml:lang="en">Description: Shorter measurement of the two horizontal dimensions measured with the object in the upright position</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:R">
                                                                                        <xsd:minInclusive value="-99999999"/>
                                                                                        <xsd:maxInclusive value="99999999"/>
                                                                                        <xsd:totalDigits value="8"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="    " minOccurs="0" name="_24">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Equipment Type" xml:lang="en">Description: Code identifying equipment type</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="4"/>
                                                                                        <xsd:minLength value="4"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_140">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Standard Carrier Alpha Code" xml:lang="en">Description: Standard Carrier Alpha Code</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="4"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_301">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Car Type Code" xml:lang="en">Description: Code specifying type of rail car or intermodal equipment type and its general characteristics</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="4"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="1" minOccurs="0" name="N7A">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Accessorial Equipment Details" xml:lang="en">Purpose: To identify the accessorial equipment required to load or unload product
Semantics: N7A02 is the length of the hose in feet.

N7A03 is the diameter of the hose in inches. The hose connects the trailer with the storage tank, etc.

N7A05 is the diameter of the outlet or inlet in inches.

N7A06 is the diameter of the hose in inches. This hose connects the trailer to an unloading device (pump, blower, etc.).

</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="  " minOccurs="0" name="_1042">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Load or Device Code" xml:lang="en">Description: Code identifying the device required to load or unload product</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_82">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Length" xml:lang="en">Description: Largest horizontal dimension of an object measured when the object is in the upright position</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-99999999"/>
                                                                                                  <xsd:maxInclusive value="99999999"/>
                                                                                                  <xsd:totalDigits value="8"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_1043">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Diameter" xml:lang="en">Description: Diameter of the object</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-99"/>
                                                                                                  <xsd:maxInclusive value="99"/>
                                                                                                  <xsd:totalDigits value="2"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="   " minOccurs="0" name="_1044">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Hose Type Code" xml:lang="en">Description: Code identifying the type of hose required for loading or unloading the product</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="3"/>
                                                                                                  <xsd:minLength value="3"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_1043">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Diameter" xml:lang="en">Description: Diameter of the object</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-99"/>
                                                                                                  <xsd:maxInclusive value="99"/>
                                                                                                  <xsd:totalDigits value="2"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_1043">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Diameter" xml:lang="en">Description: Diameter of the object</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-99"/>
                                                                                                  <xsd:maxInclusive value="99"/>
                                                                                                  <xsd:totalDigits value="2"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_1045">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Inlet or Outlet Material Type Code" xml:lang="en">Description: Code indicating the type of material used in the construction of the inlet or outlet</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_1046">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Inlet or Outlet Fitting Type Code" xml:lang="en">Description: Code indicating the type of fitting required to make the connection of the inlet or outlet</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_1047">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Miscellaneous Equipment Code" xml:lang="en">Description: Code indicating the miscellaneous equipment required to load or unload a product</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="1" minOccurs="0" name="N7B">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Additional Equipment Details" xml:lang="en">Purpose: To identify additional equipment details
Semantics: N7B06 is the Department of Transportation or the Interstate Commerce Commission Motor Carrier Cargo Tank Specification.


Comments: N7B06 may include but are not limited to MC300 through MC307, MC310 through MC312, MC330, MC331, MC338, DOT 406, DOT 407, and DOT 412.

</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="0" minOccurs="0" name="_1024">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Number of Tank Compartments" xml:lang="en">Description: Number of compartments in a Tank Trailer</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:N">
                                                                                                  <xsd:minInclusive value="-99"/>
                                                                                                  <xsd:maxInclusive value="99"/>
                                                                                                  <xsd:totalDigits value="2"/>
                                                                                                  <xsd:fractionDigits value="0"/>
                                                                                                  <xsd:minLength value="0"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_1025">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Loading or Discharge Location Code" xml:lang="en">Description: Code indicating the location of the loading or discharge line connection used for loading or unloading product from a trailer or container</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="1"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="   " minOccurs="0" name="_1026">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Vessel Material Code" xml:lang="en">Description: Code indicating the material that is used in construction of the cargo tank vessel</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="3"/>
                                                                                                  <xsd:minLength value="3"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="   " minOccurs="0" name="_1030">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Gasket Type Code" xml:lang="en">Description: Code indicating the type of gaskets (used in the trailer valves and hoses) that are required to load or unload the product</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="3"/>
                                                                                                  <xsd:minLength value="3"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="   " minOccurs="0" name="_1031">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Trailer Lining Type Code" xml:lang="en">Description: Code indicating the type of trailer (vessel) lining required by the product</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="3"/>
                                                                                                  <xsd:minLength value="3"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_127">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="30"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="1" minOccurs="0" name="MEA">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Measurements" xml:lang="en">Purpose: To specify physical measurements or counts, including dimensions, tolerances, variances, and weights(See Figures Appendix for example of use of C001)
Semantics: MEA04 defines the unit of measure for MEA03, MEA05, and MEA06.


Comments: When citing dimensional tolerances, any measurement requiring a sign (+ or -), or any measurement where a positive (+) value cannot be assumed, use MEA05 as the negative (-) value and MEA06 as the positive (+) value.


Syntax Rules:
R03050608 : At least one of MEA03, MEA05, MEA06 or MEA08 is required.
C0504 : If MEA05 is present, then MEA04 is required.
C0604 : If MEA06 is present, then MEA04 is required.
L07030506 : If MEA07 is present, then at least one of MEA03, MEA05 or MEA06 is required.
E0803 : Only one of MEA08 or MEA03 may be present.
</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="  " minOccurs="0" name="_737">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Measurement Reference ID Code" xml:lang="en">Description: Code identifying the broad category to which a measurement applies</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_738">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Measurement Qualifier" xml:lang="en">Description: Code identifying a specific product or process characteristic to which a measurement applies</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="3"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_739">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Measurement Value" xml:lang="en">Description: The value of the measurement</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-99999999999999999999"/>
                                                                                                  <xsd:maxInclusive value="99999999999999999999"/>
                                                                                                  <xsd:totalDigits value="20"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element minOccurs="0" name="C001">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Composite Unit of Measure" xml:lang="en">Description: To identify a composite unit of measure(See Figures Appendix for examples of use)
Comments: If C001-02 is not used, its value is to be interpreted as 1.
If C001-03 is not used, its value is to be interpreted as 1.
If C001-05 is not used, its value is to be interpreted as 1.
If C001-06 is not used, its value is to be interpreted as 1.
If C001-08 is not used, its value is to be interpreted as 1.
If C001-09 is not used, its value is to be interpreted as 1.
If C001-11 is not used, its value is to be interpreted as 1.
If C001-12 is not used, its value is to be interpreted as 1.
If C001-14 is not used, its value is to be interpreted as 1.
If C001-15 is not used, its value is to be interpreted as 1.
</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:complexType>
                                                                                                <xsd:complexContent>
                                                                                                  <xsd:extension base="ansix12:FieldGroup">
                                                                                                    <xsd:sequence>
                                                                                                      <xsd:element default="  " name="_355">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_1018">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Exponent" xml:lang="en">Description: Power to which a unit is raised</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-999999999999999"/>
                                                                                                            <xsd:maxInclusive value="999999999999999"/>
                                                                                                            <xsd:totalDigits value="15"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_649">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Multiplier" xml:lang="en">Description: Value to be used as a multiplier to obtain a new value</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-9999999999"/>
                                                                                                            <xsd:maxInclusive value="9999999999"/>
                                                                                                            <xsd:totalDigits value="10"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_1018">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Exponent" xml:lang="en">Description: Power to which a unit is raised</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-999999999999999"/>
                                                                                                            <xsd:maxInclusive value="999999999999999"/>
                                                                                                            <xsd:totalDigits value="15"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_649">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Multiplier" xml:lang="en">Description: Value to be used as a multiplier to obtain a new value</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-9999999999"/>
                                                                                                            <xsd:maxInclusive value="9999999999"/>
                                                                                                            <xsd:totalDigits value="10"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_1018">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Exponent" xml:lang="en">Description: Power to which a unit is raised</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-999999999999999"/>
                                                                                                            <xsd:maxInclusive value="999999999999999"/>
                                                                                                            <xsd:totalDigits value="15"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_649">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Multiplier" xml:lang="en">Description: Value to be used as a multiplier to obtain a new value</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-9999999999"/>
                                                                                                            <xsd:maxInclusive value="9999999999"/>
                                                                                                            <xsd:totalDigits value="10"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_1018">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Exponent" xml:lang="en">Description: Power to which a unit is raised</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-999999999999999"/>
                                                                                                            <xsd:maxInclusive value="999999999999999"/>
                                                                                                            <xsd:totalDigits value="15"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_649">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Multiplier" xml:lang="en">Description: Value to be used as a multiplier to obtain a new value</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-9999999999"/>
                                                                                                            <xsd:maxInclusive value="9999999999"/>
                                                                                                            <xsd:totalDigits value="10"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_1018">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Exponent" xml:lang="en">Description: Power to which a unit is raised</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-999999999999999"/>
                                                                                                            <xsd:maxInclusive value="999999999999999"/>
                                                                                                            <xsd:totalDigits value="15"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_649">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Multiplier" xml:lang="en">Description: Value to be used as a multiplier to obtain a new value</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-9999999999"/>
                                                                                                            <xsd:maxInclusive value="9999999999"/>
                                                                                                            <xsd:totalDigits value="10"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                    </xsd:sequence>
                                                                                                  </xsd:extension>
                                                                                                </xsd:complexContent>
                                                                                              </xsd:complexType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_740">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Range Minimum" xml:lang="en">Description: The value specifying the minimum of the measurement range</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-99999999999999999999"/>
                                                                                                  <xsd:maxInclusive value="99999999999999999999"/>
                                                                                                  <xsd:totalDigits value="20"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_741">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Range Maximum" xml:lang="en">Description: The value specifying the maximum of the measurement range</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-99999999999999999999"/>
                                                                                                  <xsd:maxInclusive value="99999999999999999999"/>
                                                                                                  <xsd:totalDigits value="20"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_935">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Measurement Significance Code" xml:lang="en">Description: Code used to benchmark, qualify or further define a measurement value</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_936">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Measurement Attribute Code" xml:lang="en">Description: Code used to express an attribute response when a numeric measurement value cannot be determined</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_752">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Surface/Layer/Position Code" xml:lang="en">Description: Code indicating the product surface, layer or position that is being described</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_1373">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Measurement Method or Device" xml:lang="en">Description: The method or device used to record the measurement</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="4"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="2" minOccurs="0" name="M7">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Seal Numbers" xml:lang="en">Purpose: To record seal numbers used and the organization that applied the seals
Comments: M705 indicates the name of the organization which applied the seal(s).

</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="  " name="_225">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Seal Number" xml:lang="en">Description: Unique number on seal used to close a shipment</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="15"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_225">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Seal Number" xml:lang="en">Description: Unique number on seal used to close a shipment</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="15"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_225">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Seal Number" xml:lang="en">Description: Unique number on seal used to close a shipment</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="15"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_225">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Seal Number" xml:lang="en">Description: Unique number on seal used to close a shipment</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="15"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_98">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Entity Identifier Code" xml:lang="en">Description: Code identifying an organizational entity, a physical location, property or an individual</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="3"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="1" minOccurs="0" name="L3">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Total Weight and Charges" xml:lang="en">Purpose: To specify the total shipment in terms of weight, volume, rates, charges, advances, and prepaid amounts applicable to one or more line items
Semantics: L305 is the total charges.


Syntax Rules:
P0102 : If either L301 or L302 is present, then the other is required.
P0304 : If either L303 or L304 is present, then the other is required.
P0910 : If either L309 or L310 is present, then the other is required.
C1201 : If L312 is present, then L301 is required.
P1415 : If either L314 or L315 is present, then the other is required.
</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="ansix12:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element default="0" minOccurs="0" name="_81">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:R">
                                                          <xsd:minInclusive value="-9999999999"/>
                                                          <xsd:maxInclusive value="9999999999"/>
                                                          <xsd:totalDigits value="10"/>
                                                          <xsd:minLength value="1"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default=" " minOccurs="0" name="_187">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Weight Qualifier" xml:lang="en">Description: Code defining the type of weight</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:AN">
                                                          <xsd:length value="2"/>
                                                          <xsd:minLength value="1"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="0" minOccurs="0" name="_60">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Freight Rate" xml:lang="en">Description: Rate that applies to the specific commodity</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:R">
                                                          <xsd:minInclusive value="-999999999"/>
                                                          <xsd:maxInclusive value="999999999"/>
                                                          <xsd:totalDigits value="9"/>
                                                          <xsd:minLength value="1"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="  " minOccurs="0" name="_122">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Rate/Value Qualifier" xml:lang="en">Description: Code qualifying how to extend charges or interpret value</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:AN">
                                                          <xsd:length value="2"/>
                                                          <xsd:minLength value="2"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="0" minOccurs="0" name="_58">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Charge" xml:lang="en">Description: For a line item: freight or special charge; for the total invoice: the total charges -- expressed in the standard monetary denomination for the currency specified</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:N">
                                                          <xsd:minInclusive value="-999999999999"/>
                                                          <xsd:maxInclusive value="999999999999"/>
                                                          <xsd:totalDigits value="12"/>
                                                          <xsd:fractionDigits value="2"/>
                                                          <xsd:minLength value="0"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="0" minOccurs="0" name="_191">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Advances" xml:lang="en">Description: Incidental charges occurring during transportation which are not generally considered to be freight charges (examples - stop charges, diversion and reconsignment, icing) expressed in the standard monetary denomination for the currency specified</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:N">
                                                          <xsd:minInclusive value="-999999999"/>
                                                          <xsd:maxInclusive value="999999999"/>
                                                          <xsd:totalDigits value="9"/>
                                                          <xsd:fractionDigits value="2"/>
                                                          <xsd:minLength value="0"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="0" minOccurs="0" name="_117">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Prepaid Amount" xml:lang="en">Description: Money paid at point of origin (usually by shipper) expressed in the standard monetary denomination for the currency specified</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:N">
                                                          <xsd:minInclusive value="-999999999"/>
                                                          <xsd:maxInclusive value="999999999"/>
                                                          <xsd:totalDigits value="9"/>
                                                          <xsd:fractionDigits value="2"/>
                                                          <xsd:minLength value="0"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="   " minOccurs="0" name="_150">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Special Charge or Allowance Code" xml:lang="en">Description: Code identifying type of special charge or allowance</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:AN">
                                                          <xsd:length value="3"/>
                                                          <xsd:minLength value="3"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="0" minOccurs="0" name="_183">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Volume" xml:lang="en">Description: Value of volumetric measure</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:R">
                                                          <xsd:minInclusive value="-99999999"/>
                                                          <xsd:maxInclusive value="99999999"/>
                                                          <xsd:totalDigits value="8"/>
                                                          <xsd:minLength value="1"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default=" " minOccurs="0" name="_184">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Volume Unit Qualifier" xml:lang="en">Description: Code identifying the volume unit</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:AN">
                                                          <xsd:length value="1"/>
                                                          <xsd:minLength value="1"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="0" minOccurs="0" name="_80">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Lading Quantity" xml:lang="en">Description: Number of units (pieces) of the lading commodity</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:N">
                                                          <xsd:minInclusive value="-9999999"/>
                                                          <xsd:maxInclusive value="9999999"/>
                                                          <xsd:totalDigits value="7"/>
                                                          <xsd:fractionDigits value="0"/>
                                                          <xsd:minLength value="0"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default=" " minOccurs="0" name="_188">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:AN">
                                                          <xsd:length value="1"/>
                                                          <xsd:minLength value="1"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default=" " minOccurs="0" name="_171">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Tariff Number" xml:lang="en">Description: Standard tariff number for the tariff which governs the rates applied to the commodity item(s)</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:AN">
                                                          <xsd:length value="7"/>
                                                          <xsd:minLength value="1"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="00" minOccurs="0" name="_74">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Declared Value" xml:lang="en">Description: Monetary assigned value expressed in the standard monetary denomination for the currency specified</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:N">
                                                          <xsd:minInclusive value="-999999999999"/>
                                                          <xsd:maxInclusive value="999999999999"/>
                                                          <xsd:totalDigits value="12"/>
                                                          <xsd:fractionDigits value="2"/>
                                                          <xsd:minLength value="1"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="  " minOccurs="0" name="_122">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Rate/Value Qualifier" xml:lang="en">Description: Code qualifying how to extend charges or interpret value</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:AN">
                                                          <xsd:length value="2"/>
                                                          <xsd:minLength value="2"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="1" minOccurs="1" name="SE">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Transaction Set Trailer" xml:lang="en">Purpose: To indicate the end of the transaction set and provide the count of the transmitted segments (including the beginning (ST) and ending (SE) segments)
Comments: SE is the last segment of each transaction set.

</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="ansix12:Segment">
                                                  <xsd:sequence>
                                                    <xsd:element default="0" name="_96">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Number of Included Segments" xml:lang="en">Description: Total number of segments included in a transaction set including ST and SE segments</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:N">
                                                          <xsd:minInclusive value="-9999999999"/>
                                                          <xsd:maxInclusive value="9999999999"/>
                                                          <xsd:totalDigits value="10"/>
                                                          <xsd:fractionDigits value="0"/>
                                                          <xsd:minLength value="0"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                    <xsd:element default="    " name="_329">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Transaction Set Control Number" xml:lang="en">Description: Identifying control number that must be unique within the transaction set functional group assigned by the originator for a transaction set</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:simpleType>
                                                        <xsd:restriction base="ansix12:AN">
                                                          <xsd:length value="9"/>
                                                          <xsd:minLength value="4"/>
                                                        </xsd:restriction>
                                                      </xsd:simpleType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element maxOccurs="1" minOccurs="1" name="GE">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Functional Group Trailer" xml:lang="en">Purpose: To indicate the end of a functional group and to provide control information
Semantics: The data interchange control number GE02 in this trailer must be identical to the same data element in the associated functional group header, GS06.
Comments: The use of identical data interchange control numbers in the associated functional group header and trailer is designed to maximize functional group integrity. The control number is the same as that used in the corresponding header.</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:complexType>
                                    <xsd:complexContent>
                                      <xsd:extension base="ansix12:Segment">
                                        <xsd:sequence>
                                          <xsd:element default="0" name="_97">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Number of Transaction Sets Included" xml:lang="en">Description: Total number of transaction sets included in the functional group or interchange (transmission) group terminated by the trailer containing this data element</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="ansix12:N">
                                                <xsd:minInclusive value="-999999"/>
                                                <xsd:maxInclusive value="999999"/>
                                                <xsd:totalDigits value="6"/>
                                                <xsd:fractionDigits value="0"/>
                                                <xsd:minLength value="0"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                          <xsd:element default="0" name="_28">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Group Control Number" xml:lang="en">Description: Assigned number originated and maintained by the sender</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:simpleType>
                                              <xsd:restriction base="ansix12:N">
                                                <xsd:minInclusive value="-999999999"/>
                                                <xsd:maxInclusive value="999999999"/>
                                                <xsd:totalDigits value="9"/>
                                                <xsd:fractionDigits value="0"/>
                                                <xsd:minLength value="0"/>
                                              </xsd:restriction>
                                            </xsd:simpleType>
                                          </xsd:element>
                                        </xsd:sequence>
                                      </xsd:extension>
                                    </xsd:complexContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                      <xsd:element maxOccurs="1" minOccurs="1" name="IEA">
                        <xsd:annotation>
                          <xsd:documentation bic:title="Interchange Control Trailer" xml:lang="en">Purpose: To define the end of an interchange of zero or more functional groups and interchange-related control segments</xsd:documentation>
                        </xsd:annotation>
                        <xsd:complexType>
                          <xsd:complexContent>
                            <xsd:extension base="ansix12:Segment">
                              <xsd:sequence>
                                <xsd:element default="0" name="I16">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Number of Included Functional Groups" xml:lang="en">Description: A count of the number of functional groups included in an interchange</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="ansix12:N">
                                      <xsd:minInclusive value="-99999"/>
                                      <xsd:maxInclusive value="99999"/>
                                      <xsd:totalDigits value="5"/>
                                      <xsd:fractionDigits value="0"/>
                                      <xsd:minLength value="0"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                                <xsd:element default="000000000" name="I12">
                                  <xsd:annotation>
                                    <xsd:documentation bic:title="Interchange Control Number" xml:lang="en">Description: A control number assigned by the interchange sender</xsd:documentation>
                                  </xsd:annotation>
                                  <xsd:simpleType>
                                    <xsd:restriction base="ansix12:N">
                                      <xsd:totalDigits value="9"/>
                                      <xsd:minLength value="9"/>
                                    </xsd:restriction>
                                  </xsd:simpleType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:extension>
                          </xsd:complexContent>
                        </xsd:complexType>
                      </xsd:element>
                    </xsd:sequence>
                  </xsd:extension>
                </xsd:complexContent>
              </xsd:complexType>
            </xsd:element>
          </xsd:sequence>
        </xsd:extension>
      </xsd:complexContent>
    </xsd:complexType>
  </xsd:element>
</xsd:schema>
