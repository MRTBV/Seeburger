                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="20"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " name="_235">
