                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_728">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Returnable Container Load Make-Up Code" xml:lang="en">Description: Code identifying the load make-up of the returnable containers in the shipment</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_668">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Line Item Status Code" xml:lang="en">Description: Code specifying the action taken by the seller on a line item requested by the buyer</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
