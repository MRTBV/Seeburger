                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_1018">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Exponent" xml:lang="en">Description: Power to which a unit is raised</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:R">
                                                                                        <xsd:minInclusive value="-999999999999999"/>
                                                                                        <xsd:maxInclusive value="999999999999999"/>
                                                                                        <xsd:totalDigits value="15"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
