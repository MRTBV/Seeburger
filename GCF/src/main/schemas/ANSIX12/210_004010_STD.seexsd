                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_706">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Entity Relationship Code" xml:lang="en">Description: Code describing entity relationship</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="2"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_98">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Entity Identifier Code" xml:lang="en">Description: Code identifying an organizational entity, a physical location, property or an individual</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="3"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="1" minOccurs="0" name="N2">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Additional Name Information" xml:lang="en">Purpose: To specify additional names or those longer than 35 characters in length</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default=" " name="_93">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="60"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_93">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="60"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="2" minOccurs="0" name="N3">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Address Information" xml:lang="en">Purpose: To specify the location of the named party</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default=" " name="_166">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Address Information" xml:lang="en">Description: Address information</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="55"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_166">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Address Information" xml:lang="en">Description: Address information</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="55"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="1" minOccurs="0" name="N4">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Geographic Location" xml:lang="en">Purpose: To specify the geographic place of the named party
Comments: A combination of either N401 through N404, or N405 and N406 may be adequate to specify a location.

N402 is required only if city name (N401) is in the U.S. or Canada.

'
Syntax Rules:
C0605 : If N406 is present, then N405 is required.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="  " minOccurs="0" name="_19">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="City Name" xml:lang="en">Description: Free-form text for city name</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="30"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_156">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="State or Province Code" xml:lang="en">Description: Code (Standard State/Province) as defined by appropriate government agency</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="   " minOccurs="0" name="_116">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Postal Code" xml:lang="en">Description: Code defining international postal zone code excluding punctuation and blanks (zip code for United States)</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="15"/>
                                                                                                  <xsd:minLength value="3"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_26">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Country Code" xml:lang="en">Description: Code identifying the country</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="3"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_309">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Location Qualifier" xml:lang="en">Description: Code identifying type of location</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_310">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Location Identifier" xml:lang="en">Description: Code which identifies a specific location</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="30"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="5" minOccurs="0" name="N9">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Reference Identification" xml:lang="en">Purpose: To transmit identifying information as specified by the Reference Identification Qualifier
Semantics: N906 reflects the time zone which the time reflects.

N907 contains data relating to the value cited in N902.

'
Syntax Rules:
R0203 : At least one of N902 or N903 is required.
C0605 : If N906 is present, then N905 is required.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="  " name="_128">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="3"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_127">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="30"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_369">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Free-form Description" xml:lang="en">Description: Free-form descriptive text</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="45"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="        " minOccurs="0" name="_373">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Date" xml:lang="en">Description: Date expressed as CCYYMMDD</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:DT">
                                                                                                  <xsd:length value="8"/>
                                                                                                  <xsd:minLength value="8"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="    " minOccurs="0" name="_337">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Time" xml:lang="en">Description: Time expressed in 24-hour clock time as follows: HHMM, or HHMMSS, or HHMMSSD, or HHMMSSDD, where H = hours (00-23), M = minutes (00-59), S = integer seconds (00-59) and DD = decimal seconds; decimal seconds are expressed as follows: D = tenths (0-9) and DD = hundredths (00-99)</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="8"/>
                                                                                                  <xsd:minLength value="4"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_623">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Time Code" xml:lang="en">Description: Code identifying the time. In accordance with International Standards Organization standard 8601, time can be specified by a + or - and an indication in hours in relation to Universal Time Coordinate (UTC) time; since + is a restricted character, + and - are substituted by P and M in the codes that follow</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element minOccurs="0" name="C040">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Reference Identifier" xml:lang="en">Description: To identify one or more reference numbers or identification numbers as specified by the Reference Qualifier'
Syntax Rules:
P0304 : If either N9.C04003 or N9.C04004 is present, then the other is required.
P0506 : If either N9.C04005 or N9.C04006 is present, then the other is required.</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:complexType>
                                                                                                <xsd:complexContent>
                                                                                                  <xsd:extension base="ansix12:FieldGroup">
                                                                                                    <xsd:sequence>
                                                                                                      <xsd:element default="  " name="_128">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="3"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " name="_127">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="30"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_128">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="3"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="30"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_128">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="3"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="30"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                    </xsd:sequence>
                                                                                                  </xsd:extension>
                                                                                                </xsd:complexContent>
                                                                                              </xsd:complexType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="10" minOccurs="0" name="S0320">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Equipment Details" xml:lang="en">Purpose: To identify the equipment</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:SegmentGroup">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element maxOccurs="1" minOccurs="0" name="N7">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Equipment Details" xml:lang="en">Purpose: To identify the equipment
Semantics: N712 is the owner of the equipment.

N723 is the operator or carrier of the rights of the equipment.


Comments: N701 is mandatory for rail transactions.

N720 and N721 are expressed in inches.

'
Syntax Rules:
P0304 : If either N703 or N704 is present, then the other is required.
P0516 : If either N705 or N716 is present, then the other is required.
P0809 : If either N708 or N709 is present, then the other is required.</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:complexType>
                                                                                                <xsd:complexContent>
                                                                                                  <xsd:extension base="ansix12:Segment">
                                                                                                    <xsd:sequence>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_206">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Equipment Initial" xml:lang="en">Description: Prefix or alphabetic part of an equipment unit's identifying number</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="4"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " name="_207">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Equipment Number" xml:lang="en">Description: Sequencing or serial part of an equipment unit's identifying number (pure numeric form for equipment number is preferred)</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="10"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_81">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-9999999999"/>
                                                                                                            <xsd:maxInclusive value="9999999999"/>
                                                                                                            <xsd:totalDigits value="10"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_187">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Weight Qualifier" xml:lang="en">Description: Code defining the type of weight</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="000" minOccurs="0" name="_167">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Tare Weight" xml:lang="en">Description: Weight of the equipment</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:N">
                                                                                                            <xsd:minInclusive value="-99999999"/>
                                                                                                            <xsd:maxInclusive value="99999999"/>
                                                                                                            <xsd:totalDigits value="8"/>
                                                                                                            <xsd:fractionDigits value="0"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="00" minOccurs="0" name="_232">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Weight Allowance" xml:lang="en">Description: Allowance made for increased weight due to such factors as snow</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:N">
                                                                                                            <xsd:minInclusive value="-999999"/>
                                                                                                            <xsd:maxInclusive value="999999"/>
                                                                                                            <xsd:totalDigits value="6"/>
                                                                                                            <xsd:fractionDigits value="0"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_205">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Dunnage" xml:lang="en">Description: Weight of material used to protect lading (even bracings, false floors, etc.)</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:N">
                                                                                                            <xsd:minInclusive value="-999999"/>
                                                                                                            <xsd:maxInclusive value="999999"/>
                                                                                                            <xsd:totalDigits value="6"/>
                                                                                                            <xsd:fractionDigits value="0"/>
                                                                                                            <xsd:minLength value="0"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_183">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Volume" xml:lang="en">Description: Value of volumetric measure</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-99999999"/>
                                                                                                            <xsd:maxInclusive value="99999999"/>
                                                                                                            <xsd:totalDigits value="8"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_184">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Volume Unit Qualifier" xml:lang="en">Description: Code identifying the volume unit</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="1"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_102">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Ownership Code" xml:lang="en">Description: Code indicating the relationship of equipment to carrier or ownership of equipment</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="1"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_40">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Equipment Description Code" xml:lang="en">Description: Code identifying type of equipment used for shipment</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_140">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Standard Carrier Alpha Code" xml:lang="en">Description: Standard Carrier Alpha Code</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="4"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="   " minOccurs="0" name="_319">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Temperature Control" xml:lang="en">Description: Free-form abbreviation of temperature range or flash-point temperature</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="6"/>
                                                                                                            <xsd:minLength value="3"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_219">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Position" xml:lang="en">Description: Relative position of shipment in car, trailer, or container (mutually defined)</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="3"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0000" minOccurs="0" name="_567">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Equipment Length" xml:lang="en">Description: Length (in feet and inches) of equipment ordered or used to transport shipment (The format is FFFII where FFF is feet and II is inches; the range for II is 00 through 11)</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:N">
                                                                                                            <xsd:minInclusive value="-99999"/>
                                                                                                            <xsd:maxInclusive value="99999"/>
                                                                                                            <xsd:totalDigits value="5"/>
                                                                                                            <xsd:fractionDigits value="0"/>
                                                                                                            <xsd:minLength value="3"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_571">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Tare Qualifier Code" xml:lang="en">Description: Code identifying the type of tare</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="1"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_188">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="1"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_761">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Equipment Number Check Digit" xml:lang="en">Description: Number which designates the check digit applied to a piece of equipment</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:N">
                                                                                                            <xsd:totalDigits value="1"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_56">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Type of Service Code" xml:lang="en">Description: Code specifying extent of transportation service requested</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_65">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Height" xml:lang="en">Description: Vertical dimension of an object measured when the object is in the upright position</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-99999999"/>
                                                                                                            <xsd:maxInclusive value="99999999"/>
                                                                                                            <xsd:totalDigits value="8"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_189">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Width" xml:lang="en">Description: Shorter measurement of the two horizontal dimensions measured with the object in the upright position</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-99999999"/>
                                                                                                            <xsd:maxInclusive value="99999999"/>
                                                                                                            <xsd:totalDigits value="8"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="    " minOccurs="0" name="_24">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Equipment Type" xml:lang="en">Description: Code identifying equipment type</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="4"/>
                                                                                                            <xsd:minLength value="4"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_140">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Standard Carrier Alpha Code" xml:lang="en">Description: Standard Carrier Alpha Code</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="4"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_301">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Car Type Code" xml:lang="en">Description: Code specifying type of rail car or intermodal equipment type and its general characteristics</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="4"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element maxOccurs="2" minOccurs="0" name="M7">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Seal Numbers" xml:lang="en">Purpose: To record seal numbers used and the organization that applied the seals
Comments: M705 indicates the name of the organization which applied the seal(s).</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:complexType>
                                                                                                          <xsd:complexContent>
                                                                                                            <xsd:extension base="ansix12:Segment">
                                                                                                              <xsd:sequence>
                                                                                                                <xsd:element default="  " name="_225">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Seal Number" xml:lang="en">Description: Unique number on seal used to close a shipment</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="15"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_225">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Seal Number" xml:lang="en">Description: Unique number on seal used to close a shipment</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="15"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_225">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Seal Number" xml:lang="en">Description: Unique number on seal used to close a shipment</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="15"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_225">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Seal Number" xml:lang="en">Description: Unique number on seal used to close a shipment</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="15"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_98">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Entity Identifier Code" xml:lang="en">Description: Code identifying an organizational entity, a physical location, property or an individual</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="3"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                              </xsd:sequence>
                                                                                                            </xsd:extension>
                                                                                                          </xsd:complexContent>
                                                                                                        </xsd:complexType>
                                                                                                      </xsd:element>
                                                                                                    </xsd:sequence>
                                                                                                  </xsd:extension>
                                                                                                </xsd:complexContent>
                                                                                              </xsd:complexType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                            </xsd:sequence>
                                                          </xsd:extension>
                                                        </xsd:complexContent>
                                                      </xsd:complexType>
                                                    </xsd:element>
                                                  </xsd:sequence>
                                                </xsd:extension>
                                              </xsd:complexContent>
                                            </xsd:complexType>
                                          </xsd:element>
                                          <xsd:element maxOccurs="9999" minOccurs="0" name="S0400">
                                            <xsd:annotation>
                                              <xsd:documentation bic:title="Assigned Number" xml:lang="en">Purpose: To reference a line number in a transaction set</xsd:documentation>
                                            </xsd:annotation>
                                            <xsd:complexType>
                                              <xsd:complexContent>
                                                <xsd:extension base="ansix12:SegmentGroup">
                                                  <xsd:sequence>
                                                    <xsd:element maxOccurs="1" minOccurs="0" name="LX">
                                                      <xsd:annotation>
                                                        <xsd:documentation bic:title="Assigned Number" xml:lang="en">Purpose: To reference a line number in a transaction set</xsd:documentation>
                                                      </xsd:annotation>
                                                      <xsd:complexType>
                                                        <xsd:complexContent>
                                                          <xsd:extension base="ansix12:Segment">
                                                            <xsd:sequence>
                                                              <xsd:element default="0" name="_554">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Assigned Number" xml:lang="en">Description: Number assigned for differentiation within a transaction set</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:simpleType>
                                                                  <xsd:restriction base="ansix12:N">
                                                                    <xsd:minInclusive value="-999999"/>
                                                                    <xsd:maxInclusive value="999999"/>
                                                                    <xsd:totalDigits value="6"/>
                                                                    <xsd:fractionDigits value="0"/>
                                                                    <xsd:minLength value="0"/>
                                                                  </xsd:restriction>
                                                                </xsd:simpleType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="5" minOccurs="0" name="N9">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Reference Identification" xml:lang="en">Purpose: To transmit identifying information as specified by the Reference Identification Qualifier
Semantics: N906 reflects the time zone which the time reflects.

N907 contains data relating to the value cited in N902.

'
Syntax Rules:
R0203 : At least one of N902 or N903 is required.
C0605 : If N906 is present, then N905 is required.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="  " name="_128">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="3"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_127">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="30"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_369">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Free-form Description" xml:lang="en">Description: Free-form descriptive text</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="45"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="        " minOccurs="0" name="_373">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Date" xml:lang="en">Description: Date expressed as CCYYMMDD</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:DT">
                                                                              <xsd:length value="8"/>
                                                                              <xsd:minLength value="8"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="    " minOccurs="0" name="_337">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Time" xml:lang="en">Description: Time expressed in 24-hour clock time as follows: HHMM, or HHMMSS, or HHMMSSD, or HHMMSSDD, where H = hours (00-23), M = minutes (00-59), S = integer seconds (00-59) and DD = decimal seconds; decimal seconds are expressed as follows: D = tenths (0-9) and DD = hundredths (00-99)</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="8"/>
                                                                              <xsd:minLength value="4"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_623">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Time Code" xml:lang="en">Description: Code identifying the time. In accordance with International Standards Organization standard 8601, time can be specified by a + or - and an indication in hours in relation to Universal Time Coordinate (UTC) time; since + is a restricted character, + and - are substituted by P and M in the codes that follow</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element minOccurs="0" name="C040">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Reference Identifier" xml:lang="en">Description: To identify one or more reference numbers or identification numbers as specified by the Reference Qualifier'
Syntax Rules:
P0304 : If either N9.C04003 or N9.C04004 is present, then the other is required.
P0506 : If either N9.C04005 or N9.C04006 is present, then the other is required.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:complexType>
                                                                            <xsd:complexContent>
                                                                              <xsd:extension base="ansix12:FieldGroup">
                                                                                <xsd:sequence>
                                                                                  <xsd:element default="  " name="_128">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="3"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " name="_127">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="30"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_128">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="3"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_127">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="30"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_128">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="3"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_127">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="30"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="1" minOccurs="0" name="POD">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Proof of Delivery" xml:lang="en">Purpose: To provide proof of delivery</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="        " name="_373">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Date" xml:lang="en">Description: Date expressed as CCYYMMDD</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:DT">
                                                                              <xsd:length value="8"/>
                                                                              <xsd:minLength value="8"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="    " minOccurs="0" name="_337">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Time" xml:lang="en">Description: Time expressed in 24-hour clock time as follows: HHMM, or HHMMSS, or HHMMSSD, or HHMMSSDD, where H = hours (00-23), M = minutes (00-59), S = integer seconds (00-59) and DD = decimal seconds; decimal seconds are expressed as follows: D = tenths (0-9) and DD = hundredths (00-99)</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="8"/>
                                                                              <xsd:minLength value="4"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " name="_93">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="60"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="30" minOccurs="0" name="L5">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Description, Marks and Numbers" xml:lang="en">Purpose: To specify the line item in terms of description, quantity, packaging, and marks and numbers
Comments: L502 may be used to send quantity information as part of the product description.

'
Syntax Rules:
P0304 : If either L503 or L504 is present, then the other is required.
C0706 : If L507 is present, then L506 is required.
P0809 : If either L508 or L509 is present, then the other is required.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="0" minOccurs="0" name="_213">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Lading Line Item Number" xml:lang="en">Description: Sequential line number for a lading item</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-999"/>
                                                                              <xsd:maxInclusive value="999"/>
                                                                              <xsd:totalDigits value="3"/>
                                                                              <xsd:fractionDigits value="0"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_79">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Lading Description" xml:lang="en">Description: Description of an item as required for rating and billing purposes</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="50"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_22">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Commodity Code" xml:lang="en">Description: Code describing a commodity or group of commodities</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="30"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_23">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Commodity Code Qualifier" xml:lang="en">Description: Code identifying the commodity coding system used for Commodity Code</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="   " minOccurs="0" name="_103">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Packaging Code" xml:lang="en">Description: Code identifying the type of packaging; Part 1: Packaging Form, Part 2: Packaging Material; if the Data Element is used, then Part 1 is always required</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="5"/>
                                                                              <xsd:minLength value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_87">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Marks and Numbers" xml:lang="en">Description: Marks and numbers used to identify a shipment or parts of a shipment</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="48"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_88">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Marks and Numbers Qualifier" xml:lang="en">Description: Code specifying the application or source of Marks and Numbers (87)</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_23">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Commodity Code Qualifier" xml:lang="en">Description: Code identifying the commodity coding system used for Commodity Code</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_22">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Commodity Code" xml:lang="en">Description: Code describing a commodity or group of commodities</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="30"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_595">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Compartment ID Code" xml:lang="en">Description: Code identifying the compartment in a compartmentalized tank car</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="3" minOccurs="0" name="H1">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Hazardous Material" xml:lang="en">Purpose: To specify information relative to hazardous material
Comments: This segment is required when the shipment contains hazardous material.

H107 is the lowest temperature for hazardous materials.

'
Syntax Rules:
P0708 : If either H107 or H108 is present, then the other is required.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="    " name="_62">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Hazardous Material Code" xml:lang="en">Description: Code relating to hazardous material code qualifier for regulated hazardous materials</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="10"/>
                                                                              <xsd:minLength value="4"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_209">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Hazardous Material Class Code" xml:lang="en">Description: Code specifying the kind of hazard for a material</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="4"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_208">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Hazardous Material Code Qualifier" xml:lang="en">Description: Code which qualifies the Hazardous Material Class Code (209)</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_64">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Hazardous Material Description" xml:lang="en">Description: Material name, special instructions, and phone number if any</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="30"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_63">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Hazardous Material Contact" xml:lang="en">Description: Phone number and name of person or department to contact in case of emergency</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="24"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_200">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Hazardous Materials Page" xml:lang="en">Description: The United Nations page number as required for the international transport of hazardous materials</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="6"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_77">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Flashpoint Temperature" xml:lang="en">Description: The flashpoint temperature for hazardous material</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:totalDigits value="3"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_355">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_254">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Packing Group Code" xml:lang="en">Description: Code indicating degree of danger in terms of Roman number I, II or III</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="3"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="2" minOccurs="0" name="H2">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Additional Hazardous Material Description" xml:lang="en">Purpose: To specify free-form hazardous material descriptive data in addition to the information provided in the H1 segment</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="  " name="_64">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Hazardous Material Description" xml:lang="en">Description: Material name, special instructions, and phone number if any</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="30"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_274">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Hazardous Material Classification" xml:lang="en">Description: Free-form description of hazardous material classification or division or label requirements</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="30"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="10" minOccurs="0" name="L0">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Line Item - Quantity and Weight" xml:lang="en">Purpose: To specify quantity, weight, volume, and type of service for a line item including applicable "quantity/rate-as" data
Semantics: L008 is the number of handling units of the line item tendered to the carrier.

L013 can only be used if the code in L009 is PLT, SKD, or SLP.

L015 designates whether the carrier will be required to verify the number of units contained on a pallet, slip sheet or skid. Code "Y" indicates that the carrier will be required to verify. Code "N" indicates that the carrier will not be required to verify.


Comments: L013 is used to convey the total number of boxes, cartons, or pieces contained on a pallet, skid, or slip sheet for the line item.

'
Syntax Rules:
P0203 : If either L002 or L003 is present, then the other is required.
P0405 : If either L004 or L005 is present, then the other is required.
P0607 : If either L006 or L007 is present, then the other is required.
P0809 : If either L008 or L009 is present, then the other is required.
C1104 : If L011 is present, then L004 is required.
P1315 : If either L013 or L015 is present, then the other is required.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="0" minOccurs="0" name="_213">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Lading Line Item Number" xml:lang="en">Description: Sequential line number for a lading item</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-999"/>
                                                                              <xsd:maxInclusive value="999"/>
                                                                              <xsd:totalDigits value="3"/>
                                                                              <xsd:fractionDigits value="0"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_220">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Billed/Rated-as Quantity" xml:lang="en">Description: Basis for rating (miles, value, volume, etc.); Note: Weight may be defined by either data element 220 or 81</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-99999999999"/>
                                                                              <xsd:maxInclusive value="99999999999"/>
                                                                              <xsd:totalDigits value="11"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_221">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Billed/Rated-as Qualifier" xml:lang="en">Description: Code identifying the type of quantity or value on which the rate or item pricing is based</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_81">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-9999999999"/>
                                                                              <xsd:maxInclusive value="9999999999"/>
                                                                              <xsd:totalDigits value="10"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_187">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Weight Qualifier" xml:lang="en">Description: Code defining the type of weight</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_183">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Volume" xml:lang="en">Description: Value of volumetric measure</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-99999999"/>
                                                                              <xsd:maxInclusive value="99999999"/>
                                                                              <xsd:totalDigits value="8"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_184">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Volume Unit Qualifier" xml:lang="en">Description: Code identifying the volume unit</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_80">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Lading Quantity" xml:lang="en">Description: Number of units (pieces) of the lading commodity</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-9999999"/>
                                                                              <xsd:maxInclusive value="9999999"/>
                                                                              <xsd:totalDigits value="7"/>
                                                                              <xsd:fractionDigits value="0"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="   " minOccurs="0" name="_211">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Packaging Form Code" xml:lang="en">Description: Code for packaging form of the lading quantity</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="3"/>
                                                                              <xsd:minLength value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_458">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Dunnage Description" xml:lang="en">Description: Material used to protect lading</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="25"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_188">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_56">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Type of Service Code" xml:lang="en">Description: Code specifying extent of transportation service requested</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_380">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-999999999999999"/>
                                                                              <xsd:maxInclusive value="999999999999999"/>
                                                                              <xsd:totalDigits value="15"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="   " minOccurs="0" name="_211">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Packaging Form Code" xml:lang="en">Description: Code for packaging form of the lading quantity</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="3"/>
                                                                              <xsd:minLength value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_1073">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Yes/No Condition or Response Code" xml:lang="en">Description: Code indicating a Yes or No condition or response</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="10" minOccurs="0" name="L1">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Rate and Charges" xml:lang="en">Purpose: To specify rate and charges detail relative to a line item including freight charges, advances, special charges, and entitlements
Semantics: L119 is the percent used to determine the charge in L104.

L120, if used, indicates the currency for all monetary amounts in this L1 segment.

L121 is the origin rated as charge amount.

'
Syntax Rules:
P0203 : If either L102 or L103 is present, then the other is required.
R040506 : At least one of L104, L105 or L106 is required.
P1415 : If either L114 or L115 is present, then the other is required.
P1718 : If either L117 or L118 is present, then the other is required.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="0" minOccurs="0" name="_213">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Lading Line Item Number" xml:lang="en">Description: Sequential line number for a lading item</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-999"/>
                                                                              <xsd:maxInclusive value="999"/>
                                                                              <xsd:totalDigits value="3"/>
                                                                              <xsd:fractionDigits value="0"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_60">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Freight Rate" xml:lang="en">Description: Rate that applies to the specific commodity</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-999999999"/>
                                                                              <xsd:maxInclusive value="999999999"/>
                                                                              <xsd:totalDigits value="9"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_122">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Rate/Value Qualifier" xml:lang="en">Description: Code qualifying how to extend charges or interpret value</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_58">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Charge" xml:lang="en">Description: For a line item: freight or special charge; for the total invoice: the total charges -- expressed in the standard monetary denomination for the currency specified</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-999999999999"/>
                                                                              <xsd:maxInclusive value="999999999999"/>
                                                                              <xsd:totalDigits value="12"/>
                                                                              <xsd:fractionDigits value="2"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_191">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Advances" xml:lang="en">Description: Incidental charges occurring during transportation which are not generally considered to be freight charges (examples - stop charges, diversion and reconsignment, icing) expressed in the standard monetary denomination for the currency specified</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-999999999"/>
                                                                              <xsd:maxInclusive value="999999999"/>
                                                                              <xsd:totalDigits value="9"/>
                                                                              <xsd:fractionDigits value="2"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_117">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Prepaid Amount" xml:lang="en">Description: Money paid at point of origin (usually by shipper) expressed in the standard monetary denomination for the currency specified</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-999999999"/>
                                                                              <xsd:maxInclusive value="999999999"/>
                                                                              <xsd:totalDigits value="9"/>
                                                                              <xsd:fractionDigits value="2"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="   " minOccurs="0" name="_120">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Rate Combination Point Code" xml:lang="en">Description: The code denoting the connecting station for a joint rate obtained by combining two or more published rates which are used for the calculation of transportation charges</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="9"/>
                                                                              <xsd:minLength value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="   " minOccurs="0" name="_150">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Special Charge or Allowance Code" xml:lang="en">Description: Code identifying type of special charge or allowance</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="3"/>
                                                                              <xsd:minLength value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_121">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Rate Class Code" xml:lang="en">Description: Code identifying specifically designated class of goods; Note: For international air shipments, see IATA Resolution 600k</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="3"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_39">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Entitlement Code" xml:lang="en">Description: Code identifying entitlement party</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_16">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Charge Method of Payment" xml:lang="en">Description: Code defining method of payment</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_276">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Special Charge Description" xml:lang="en">Description: Identification of special charge; this data element is used whenever an applicable code cannot be found in data element 150</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="25"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_257">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Tariff Application Code" xml:lang="en">Description: Code indicating to which traffic a tariff applies</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="00" minOccurs="0" name="_74">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Declared Value" xml:lang="en">Description: Monetary assigned value expressed in the standard monetary denomination for the currency specified</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-999999999999"/>
                                                                              <xsd:maxInclusive value="999999999999"/>
                                                                              <xsd:totalDigits value="12"/>
                                                                              <xsd:fractionDigits value="2"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_122">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Rate/Value Qualifier" xml:lang="en">Description: Code qualifying how to extend charges or interpret value</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_372">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Lading Liability Code" xml:lang="en">Description: Code identifying limits of liability</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_220">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Billed/Rated-as Quantity" xml:lang="en">Description: Basis for rating (miles, value, volume, etc.); Note: Weight may be defined by either data element 220 or 81</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-99999999999"/>
                                                                              <xsd:maxInclusive value="99999999999"/>
                                                                              <xsd:totalDigits value="11"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_221">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Billed/Rated-as Qualifier" xml:lang="en">Description: Code identifying the type of quantity or value on which the rate or item pricing is based</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_954">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Percent" xml:lang="en">Description: Percentage expressed as a decimal</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-9999999999"/>
                                                                              <xsd:maxInclusive value="9999999999"/>
                                                                              <xsd:totalDigits value="10"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="   " minOccurs="0" name="_100">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Currency Code" xml:lang="en">Description: Code (Standard ISO) for country in whose currency the charges are specified</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="3"/>
                                                                              <xsd:minLength value="3"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_610">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Amount" xml:lang="en">Description: Monetary amount</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-999999999999999"/>
                                                                              <xsd:maxInclusive value="999999999999999"/>
                                                                              <xsd:totalDigits value="15"/>
                                                                              <xsd:fractionDigits value="2"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="10" minOccurs="0" name="L4">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Measurement" xml:lang="en">Purpose: To describe physical dimensions and quantities
Semantics: L406 is the Rounding in Pattern for dimensional shipments.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="0" name="_82">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Length" xml:lang="en">Description: Largest horizontal dimension of an object measured when the object is in the upright position</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-99999999"/>
                                                                              <xsd:maxInclusive value="99999999"/>
                                                                              <xsd:totalDigits value="8"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" name="_189">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Width" xml:lang="en">Description: Shorter measurement of the two horizontal dimensions measured with the object in the upright position</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-99999999"/>
                                                                              <xsd:maxInclusive value="99999999"/>
                                                                              <xsd:totalDigits value="8"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" name="_65">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Height" xml:lang="en">Description: Vertical dimension of an object measured when the object is in the upright position</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-99999999"/>
                                                                              <xsd:maxInclusive value="99999999"/>
                                                                              <xsd:totalDigits value="8"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " name="_90">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Measurement Unit Qualifier" xml:lang="en">Description: Code specifying the linear dimensional unit</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_380">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:R">
                                                                              <xsd:minInclusive value="-999999999999999"/>
                                                                              <xsd:maxInclusive value="999999999999999"/>
                                                                              <xsd:totalDigits value="15"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_1271">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Industry Code" xml:lang="en">Description: Code indicating a code from a specific industry code list</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="30"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="10" minOccurs="0" name="L7">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Tariff Reference" xml:lang="en">Purpose: To reference details of the tariff used to arrive at applicable rates or charge
Semantics: L710 is the effective date.

In L715 and L716, "City" and "State" are used for rate combination city and state.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default="0" minOccurs="0" name="_213">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Lading Line Item Number" xml:lang="en">Description: Sequential line number for a lading item</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-999"/>
                                                                              <xsd:maxInclusive value="999"/>
                                                                              <xsd:totalDigits value="3"/>
                                                                              <xsd:fractionDigits value="0"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_168">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Tariff Agency Code" xml:lang="en">Description: Code defining the tariff bureau or tariff publishing agent that governs the rates applied to this shipment</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="4"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_171">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Tariff Number" xml:lang="en">Description: Standard tariff number for the tariff which governs the rates applied to the commodity item(s)</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="7"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_172">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Tariff Section" xml:lang="en">Description: Number used as an extension of the basic tariff number to identify the rates published within specific sections of the tariff</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_169">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Tariff Item Number" xml:lang="en">Description: Number assigned in the tariff to specific rate or group of rates that applies to one or more items in the shipment</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="16"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_170">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Tariff Item Part" xml:lang="en">Description: Number assigned to subsection of a specific tariff item (arbitrary)</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-99"/>
                                                                              <xsd:maxInclusive value="99"/>
                                                                              <xsd:totalDigits value="2"/>
                                                                              <xsd:fractionDigits value="0"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_59">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Freight Class Code" xml:lang="en">Description: Code indicating generalized classification that applies to one or more items in the shipment, i.e., class 70, 77.5, etc.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="5"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_173">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Tariff Supplement Identifier" xml:lang="en">Description: Identifier for the tariff supplement which contains the rate used</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="4"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="    " minOccurs="0" name="_46">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Ex Parte" xml:lang="en">Description: Level of rates as published in the tariff</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="4"/>
                                                                              <xsd:minLength value="4"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="        " minOccurs="0" name="_373">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Date" xml:lang="en">Description: Date expressed as CCYYMMDD</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:DT">
                                                                              <xsd:length value="8"/>
                                                                              <xsd:minLength value="8"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_119">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Rate Basis Number" xml:lang="en">Description: The (mileage) factor published for rating purposes in the appropriate tariff</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="6"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_227">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Tariff Column" xml:lang="en">Description: A tariff commodity classification that is used, as a means of control, for grouping of commodities in tariff applications</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="0" minOccurs="0" name="_294">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Tariff Distance" xml:lang="en">Description: Distance on which the rate for a shipment is based</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:N">
                                                                              <xsd:minInclusive value="-99999"/>
                                                                              <xsd:maxInclusive value="99999"/>
                                                                              <xsd:totalDigits value="5"/>
                                                                              <xsd:fractionDigits value="0"/>
                                                                              <xsd:minLength value="0"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_295">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Distance Qualifier" xml:lang="en">Description: Code identifying the distance unit</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="1"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_19">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="City Name" xml:lang="en">Description: Free-form text for city name</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="30"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default="  " minOccurs="0" name="_156">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="State or Province Code" xml:lang="en">Description: Code (Standard State/Province) as defined by appropriate government agency</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="2"/>
                                                                              <xsd:minLength value="2"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="10" minOccurs="0" name="K1">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Remarks" xml:lang="en">Purpose: To transmit information in a free-form format for comment or special instruction</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:Segment">
                                                                      <xsd:sequence>
                                                                        <xsd:element default=" " name="_61">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Free-Form Message" xml:lang="en">Description: Free-form information</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="30"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                        <xsd:element default=" " minOccurs="0" name="_61">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Free-Form Message" xml:lang="en">Description: Free-form information</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:simpleType>
                                                                            <xsd:restriction base="ansix12:AN">
                                                                              <xsd:length value="30"/>
                                                                              <xsd:minLength value="1"/>
                                                                            </xsd:restriction>
                                                                          </xsd:simpleType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="unbounded" minOccurs="0" name="S0430">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Shipment Purchase Order Detail" xml:lang="en">Purpose: To specify the purchase order details for a shipment</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:SegmentGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element maxOccurs="1" minOccurs="0" name="SPO">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Shipment Purchase Order Detail" xml:lang="en">Purpose: To specify the purchase order details for a shipment
Semantics: SPO02 is the department number.

SPO04 is the total quantity for the purchase order.

SPO06 is the total weight for the purchase order.

SPO07 indicates the data error condition relative to the shipment management information.

SPO08 is used to specify sorting and/or segregating reference numbers for each receiving location (processing area).

'
Syntax Rules:
P0304 : If either SPO03 or SPO04 is present, then the other is required.
P0506 : If either SPO05 or SPO06 is present, then the other is required.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:complexType>
                                                                            <xsd:complexContent>
                                                                              <xsd:extension base="ansix12:Segment">
                                                                                <xsd:sequence>
                                                                                  <xsd:element default=" " name="_324">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Purchase Order Number" xml:lang="en">Description: Identifying number for Purchase Order assigned by the orderer/purchaser</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="22"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_127">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="30"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_355">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="2"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_380">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:R">
                                                                                        <xsd:minInclusive value="-999999999999999"/>
                                                                                        <xsd:maxInclusive value="999999999999999"/>
                                                                                        <xsd:totalDigits value="15"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_188">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="1"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="0" minOccurs="0" name="_81">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:R">
                                                                                        <xsd:minInclusive value="-9999999999"/>
                                                                                        <xsd:maxInclusive value="9999999999"/>
                                                                                        <xsd:totalDigits value="10"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_647">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Application Error Condition Code" xml:lang="en">Description: Code indicating application error condition</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="3"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_127">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="30"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="10" minOccurs="0" name="SDQ">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Destination Quantity" xml:lang="en">Purpose: To specify destination and quantity detail
Semantics: SDQ23 identifies the area within the location identified in SDQ03, SDQ05, SDQ07, SDQ09, SDQ11, SDQ13, SDQ15, SDQ17, SDQ19, and SDQ21.


Comments: SDQ02 is used only if different than previously defined in the transaction set.

SDQ03 is the store number.

SDQ23 may be used to identify areas within a store, e.g., front room, back room, selling outpost, end aisle display, etc. The value is agreed to by trading partners or industry conventions.

'
Syntax Rules:
P0506 : If either SDQ05 or SDQ06 is present, then the other is required.
P0708 : If either SDQ07 or SDQ08 is present, then the other is required.
P0910 : If either SDQ09 or SDQ10 is present, then the other is required.
P1112 : If either SDQ11 or SDQ12 is present, then the other is required.
P1314 : If either SDQ13 or SDQ14 is present, then the other is required.
P1516 : If either SDQ15 or SDQ16 is present, then the other is required.
P1718 : If either SDQ17 or SDQ18 is present, then the other is required.
P1920 : If either SDQ19 or SDQ20 is present, then the other is required.
P2122 : If either SDQ21 or SDQ22 is present, then the other is required.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="  " name="_355">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_66">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Identification Code Qualifier" xml:lang="en">Description: Code designating the system/method of code structure used for Identification Code (67)</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " name="_67">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Identification Code" xml:lang="en">Description: Code identifying a party or other code</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="80"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" name="_380">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-999999999999999"/>
                                                                                                  <xsd:maxInclusive value="999999999999999"/>
                                                                                                  <xsd:totalDigits value="15"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_67">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Identification Code" xml:lang="en">Description: Code identifying a party or other code</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="80"/>
