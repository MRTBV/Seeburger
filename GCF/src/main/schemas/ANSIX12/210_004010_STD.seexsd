                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:R">
                                                                                                                      <xsd:minInclusive value="-999999999999999"/>
                                                                                                                      <xsd:maxInclusive value="999999999999999"/>
                                                                                                                      <xsd:totalDigits value="15"/>
