                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_67">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Identification Code" xml:lang="en">Description: Code identifying a party or other code</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="80"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_380">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-999999999999999"/>
                                                                                                  <xsd:maxInclusive value="999999999999999"/>
                                                                                                  <xsd:totalDigits value="15"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_67">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Identification Code" xml:lang="en">Description: Code identifying a party or other code</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="80"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="0" minOccurs="0" name="_380">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:R">
                                                                                                  <xsd:minInclusive value="-999999999999999"/>
                                                                                                  <xsd:maxInclusive value="999999999999999"/>
                                                                                                  <xsd:totalDigits value="15"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_310">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Location Identifier" xml:lang="en">Description: Code which identifies a specific location</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="30"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                </xsd:sequence>
                                                                              </xsd:extension>
                                                                            </xsd:complexContent>
                                                                          </xsd:complexType>
                                                                        </xsd:element>
                                                                      </xsd:sequence>
                                                                    </xsd:extension>
                                                                  </xsd:complexContent>
                                                                </xsd:complexType>
                                                              </xsd:element>
                                                              <xsd:element maxOccurs="unbounded" minOccurs="0" name="S0460">
                                                                <xsd:annotation>
                                                                  <xsd:documentation bic:title="Name" xml:lang="en">Purpose: To identify a party by type of organization, name, and code
Notes: Loops 0460 and 0463 shall be used to identify all small package carrier details related to the consignee (delivery location) and the related shipment. The shipper shall be identified in loop 0100.</xsd:documentation>
                                                                </xsd:annotation>
                                                                <xsd:complexType>
                                                                  <xsd:complexContent>
                                                                    <xsd:extension base="ansix12:SegmentGroup">
                                                                      <xsd:sequence>
                                                                        <xsd:element maxOccurs="1" minOccurs="0" name="N1">
                                                                          <xsd:annotation>
                                                                            <xsd:documentation bic:title="Name" xml:lang="en">Purpose: To identify a party by type of organization, name, and code
Notes: Loops 0460 and 0463 shall be used to identify all small package carrier details related to the consignee (delivery location) and the related shipment. The shipper shall be identified in loop 0100.
Comments: This segment, used alone, provides the most efficient method of providing organizational identification. To obtain this efficiency the "ID Code" (N104) must provide a key to the table maintained by the transaction processing party.

N105 and N106 further define the type of entity in N101.

'
Syntax Rules:
R0203 : At least one of N102 or N103 is required.
P0304 : If either N103 or N104 is present, then the other is required.</xsd:documentation>
                                                                          </xsd:annotation>
                                                                          <xsd:complexType>
                                                                            <xsd:complexContent>
                                                                              <xsd:extension base="ansix12:Segment">
                                                                                <xsd:sequence>
                                                                                  <xsd:element default="  " name="_98">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Entity Identifier Code" xml:lang="en">Description: Code identifying an organizational entity, a physical location, property or an individual</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="3"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_93">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="60"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default=" " minOccurs="0" name="_66">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identification Code Qualifier" xml:lang="en">Description: Code designating the system/method of code structure used for Identification Code (67)</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="2"/>
                                                                                        <xsd:minLength value="1"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_67">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Identification Code" xml:lang="en">Description: Code identifying a party or other code</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="80"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_706">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Entity Relationship Code" xml:lang="en">Description: Code describing entity relationship</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="2"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element default="  " minOccurs="0" name="_98">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Entity Identifier Code" xml:lang="en">Description: Code identifying an organizational entity, a physical location, property or an individual</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:simpleType>
                                                                                      <xsd:restriction base="ansix12:AN">
                                                                                        <xsd:length value="3"/>
                                                                                        <xsd:minLength value="2"/>
                                                                                      </xsd:restriction>
                                                                                    </xsd:simpleType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="1" minOccurs="0" name="N2">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Additional Name Information" xml:lang="en">Purpose: To specify additional names or those longer than 35 characters in length</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default=" " name="_93">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="60"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_93">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="60"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="2" minOccurs="0" name="N3">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Address Information" xml:lang="en">Purpose: To specify the location of the named party</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default=" " name="_166">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Address Information" xml:lang="en">Description: Address information</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="55"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_166">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Address Information" xml:lang="en">Description: Address information</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="55"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="1" minOccurs="0" name="N4">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Geographic Location" xml:lang="en">Purpose: To specify the geographic place of the named party
Comments: A combination of either N401 through N404, or N405 and N406 may be adequate to specify a location.

N402 is required only if city name (N401) is in the U.S. or Canada.

'
Syntax Rules:
C0605 : If N406 is present, then N405 is required.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="  " minOccurs="0" name="_19">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="City Name" xml:lang="en">Description: Free-form text for city name</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="30"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_156">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="State or Province Code" xml:lang="en">Description: Code (Standard State/Province) as defined by appropriate government agency</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="   " minOccurs="0" name="_116">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Postal Code" xml:lang="en">Description: Code defining international postal zone code excluding punctuation and blanks (zip code for United States)</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="15"/>
                                                                                                  <xsd:minLength value="3"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_26">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Country Code" xml:lang="en">Description: Code identifying the country</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="3"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_309">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Location Qualifier" xml:lang="en">Description: Code identifying type of location</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_310">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Location Identifier" xml:lang="en">Description: Code which identifies a specific location</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="30"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="10" minOccurs="0" name="N9">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Reference Identification" xml:lang="en">Purpose: To transmit identifying information as specified by the Reference Identification Qualifier
Semantics: N906 reflects the time zone which the time reflects.

N907 contains data relating to the value cited in N902.

'
Syntax Rules:
R0203 : At least one of N902 or N903 is required.
C0605 : If N906 is present, then N905 is required.</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:Segment">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element default="  " name="_128">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="3"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_127">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="30"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default=" " minOccurs="0" name="_369">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Free-form Description" xml:lang="en">Description: Free-form descriptive text</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="45"/>
                                                                                                  <xsd:minLength value="1"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="        " minOccurs="0" name="_373">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Date" xml:lang="en">Description: Date expressed as CCYYMMDD</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:DT">
                                                                                                  <xsd:length value="8"/>
                                                                                                  <xsd:minLength value="8"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="    " minOccurs="0" name="_337">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Time" xml:lang="en">Description: Time expressed in 24-hour clock time as follows: HHMM, or HHMMSS, or HHMMSSD, or HHMMSSDD, where H = hours (00-23), M = minutes (00-59), S = integer seconds (00-59) and DD = decimal seconds; decimal seconds are expressed as follows: D = tenths (0-9) and DD = hundredths (00-99)</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="8"/>
                                                                                                  <xsd:minLength value="4"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element default="  " minOccurs="0" name="_623">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Time Code" xml:lang="en">Description: Code identifying the time. In accordance with International Standards Organization standard 8601, time can be specified by a + or - and an indication in hours in relation to Universal Time Coordinate (UTC) time; since + is a restricted character, + and - are substituted by P and M in the codes that follow</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:simpleType>
                                                                                                <xsd:restriction base="ansix12:AN">
                                                                                                  <xsd:length value="2"/>
                                                                                                  <xsd:minLength value="2"/>
                                                                                                </xsd:restriction>
                                                                                              </xsd:simpleType>
                                                                                            </xsd:element>
                                                                                            <xsd:element minOccurs="0" name="C040">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Reference Identifier" xml:lang="en">Description: To identify one or more reference numbers or identification numbers as specified by the Reference Qualifier'
Syntax Rules:
P0304 : If either N9.C04003 or N9.C04004 is present, then the other is required.
P0506 : If either N9.C04005 or N9.C04006 is present, then the other is required.</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:complexType>
                                                                                                <xsd:complexContent>
                                                                                                  <xsd:extension base="ansix12:FieldGroup">
                                                                                                    <xsd:sequence>
                                                                                                      <xsd:element default="  " name="_128">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="3"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " name="_127">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="30"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_128">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="3"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="30"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_128">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="3"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="30"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                    </xsd:sequence>
                                                                                                  </xsd:extension>
                                                                                                </xsd:complexContent>
                                                                                              </xsd:complexType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="unbounded" minOccurs="0" name="S0463">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Carton (Package) Detail" xml:lang="en">Purpose: To transmit identifying codes, weights, and other related information related to an individual carton (package)</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:SegmentGroup">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element maxOccurs="1" minOccurs="0" name="CD3">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Carton (Package) Detail" xml:lang="en">Purpose: To transmit identifying codes, weights, and other related information related to an individual carton (package)
Semantics: CD308 is the charge for the single package.

CD310 is the total charge for all of the packages.

CD314 is the country where the service is to be performed.

'
Syntax Rules:
P0102 : If either CD301 or CD302 is present, then the other is required.
P0708 : If either CD307 or CD308 is present, then the other is required.
P0910 : If either CD309 or CD310 is present, then the other is required.
C1105 : If CD311 is present, then CD305 is required.
C1211 : If CD312 is present, then CD311 is required.
C1405 : If CD314 is present, then CD305 is required.</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:complexType>
                                                                                                <xsd:complexContent>
                                                                                                  <xsd:extension base="ansix12:Segment">
                                                                                                    <xsd:sequence>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_187">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Weight Qualifier" xml:lang="en">Description: Code defining the type of weight</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_81">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-9999999999"/>
                                                                                                            <xsd:maxInclusive value="9999999999"/>
                                                                                                            <xsd:totalDigits value="10"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_619">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Zone" xml:lang="en">Description: To identify zone</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="3"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_34">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Service Standard" xml:lang="en">Description: To report the time period of carrier's standard service for the shipment</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:N">
                                                                                                            <xsd:minInclusive value="-9999"/>
                                                                                                            <xsd:maxInclusive value="9999"/>
                                                                                                            <xsd:totalDigits value="4"/>
                                                                                                            <xsd:fractionDigits value="1"/>
                                                                                                            <xsd:minLength value="0"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_284">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Service Level Code" xml:lang="en">Description: Code indicating the level of transportation service or the billing service offered by the transportation carrier</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_108">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Pick-up or Delivery Code" xml:lang="en">Description: Specifies the location or type of pickup or delivery</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_122">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Rate/Value Qualifier" xml:lang="en">Description: Code qualifying how to extend charges or interpret value</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_58">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Charge" xml:lang="en">Description: For a line item: freight or special charge; for the total invoice: the total charges -- expressed in the standard monetary denomination for the currency specified</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:N">
                                                                                                            <xsd:minInclusive value="-999999999999"/>
                                                                                                            <xsd:maxInclusive value="999999999999"/>
                                                                                                            <xsd:totalDigits value="12"/>
                                                                                                            <xsd:fractionDigits value="2"/>
                                                                                                            <xsd:minLength value="0"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_122">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Rate/Value Qualifier" xml:lang="en">Description: Code qualifying how to extend charges or interpret value</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_58">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Charge" xml:lang="en">Description: For a line item: freight or special charge; for the total invoice: the total charges -- expressed in the standard monetary denomination for the currency specified</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:N">
                                                                                                            <xsd:minInclusive value="-999999999999"/>
                                                                                                            <xsd:maxInclusive value="999999999999"/>
                                                                                                            <xsd:totalDigits value="12"/>
                                                                                                            <xsd:fractionDigits value="2"/>
                                                                                                            <xsd:minLength value="0"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_284">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Service Level Code" xml:lang="en">Description: Code indicating the level of transportation service or the billing service offered by the transportation carrier</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_284">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Service Level Code" xml:lang="en">Description: Code indicating the level of transportation service or the billing service offered by the transportation carrier</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="   " minOccurs="0" name="_591">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Payment Method Code" xml:lang="en">Description: Code identifying the method for the movement of payment instructions</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="3"/>
                                                                                                            <xsd:minLength value="3"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_26">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Country Code" xml:lang="en">Description: Code identifying the country</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="3"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element maxOccurs="20" minOccurs="0" name="N9">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification" xml:lang="en">Purpose: To transmit identifying information as specified by the Reference Identification Qualifier
Semantics: N906 reflects the time zone which the time reflects.

N907 contains data relating to the value cited in N902.

'
Syntax Rules:
R0203 : At least one of N902 or N903 is required.
C0605 : If N906 is present, then N905 is required.</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:complexType>
                                                                                                          <xsd:complexContent>
                                                                                                            <xsd:extension base="ansix12:Segment">
                                                                                                              <xsd:sequence>
                                                                                                                <xsd:element default="  " name="_128">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="3"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="30"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_369">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Free-form Description" xml:lang="en">Description: Free-form descriptive text</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="45"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="        " minOccurs="0" name="_373">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Date" xml:lang="en">Description: Date expressed as CCYYMMDD</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:DT">
                                                                                                                      <xsd:length value="8"/>
                                                                                                                      <xsd:minLength value="8"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="    " minOccurs="0" name="_337">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Time" xml:lang="en">Description: Time expressed in 24-hour clock time as follows: HHMM, or HHMMSS, or HHMMSSD, or HHMMSSDD, where H = hours (00-23), M = minutes (00-59), S = integer seconds (00-59) and DD = decimal seconds; decimal seconds are expressed as follows: D = tenths (0-9) and DD = hundredths (00-99)</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="8"/>
                                                                                                                      <xsd:minLength value="4"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_623">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Time Code" xml:lang="en">Description: Code identifying the time. In accordance with International Standards Organization standard 8601, time can be specified by a + or - and an indication in hours in relation to Universal Time Coordinate (UTC) time; since + is a restricted character, + and - are substituted by P and M in the codes that follow</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="2"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element minOccurs="0" name="C040">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Reference Identifier" xml:lang="en">Description: To identify one or more reference numbers or identification numbers as specified by the Reference Qualifier'
Syntax Rules:
P0304 : If either N9.C04003 or N9.C04004 is present, then the other is required.
P0506 : If either N9.C04005 or N9.C04006 is present, then the other is required.</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:complexType>
                                                                                                                    <xsd:complexContent>
                                                                                                                      <xsd:extension base="ansix12:FieldGroup">
                                                                                                                        <xsd:sequence>
                                                                                                                          <xsd:element default="  " name="_128">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="3"/>
                                                                                                                                <xsd:minLength value="2"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default=" " name="_127">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="30"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default="  " minOccurs="0" name="_128">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="3"/>
                                                                                                                                <xsd:minLength value="2"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="30"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default="  " minOccurs="0" name="_128">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Reference Identification Qualifier" xml:lang="en">Description: Code qualifying the Reference Identification</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="3"/>
                                                                                                                                <xsd:minLength value="2"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                          <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                                            <xsd:annotation>
                                                                                                                              <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                                            </xsd:annotation>
                                                                                                                            <xsd:simpleType>
                                                                                                                              <xsd:restriction base="ansix12:AN">
                                                                                                                                <xsd:length value="30"/>
                                                                                                                                <xsd:minLength value="1"/>
                                                                                                                              </xsd:restriction>
                                                                                                                            </xsd:simpleType>
                                                                                                                          </xsd:element>
                                                                                                                        </xsd:sequence>
                                                                                                                      </xsd:extension>
                                                                                                                    </xsd:complexContent>
                                                                                                                  </xsd:complexType>
                                                                                                                </xsd:element>
                                                                                                              </xsd:sequence>
                                                                                                            </xsd:extension>
                                                                                                          </xsd:complexContent>
                                                                                                        </xsd:complexType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element maxOccurs="10" minOccurs="0" name="H6">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Special Services" xml:lang="en">Purpose: To identify forms of unitization, liability issues, and special services
Comments: H601 indicates base services. If H601 equals "PC" and H602 equals "PL", then H603 must be used.

H602 indicates special services.

H606 is used only when H605 is expressed in a unit of measure other than pounds (weight refers to pallet weight only).

'
Syntax Rules:
R0107 : At least one of H601 or H607 is required.
C0201 : If H602 is present, then H601 is required.</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:complexType>
                                                                                                          <xsd:complexContent>
                                                                                                            <xsd:extension base="ansix12:Segment">
                                                                                                              <xsd:sequence>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_560">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Special Services Code" xml:lang="en">Description: Code identifying the special service</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="10"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_560">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Special Services Code" xml:lang="en">Description: Code identifying the special service</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="10"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="0" minOccurs="0" name="_406">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Quantity of Pallets Shipped" xml:lang="en">Description: Number of pallets shipped</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:N">
                                                                                                                      <xsd:minInclusive value="-999"/>
                                                                                                                      <xsd:maxInclusive value="999"/>
                                                                                                                      <xsd:totalDigits value="3"/>
                                                                                                                      <xsd:fractionDigits value="0"/>
                                                                                                                      <xsd:minLength value="0"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_399">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Pallet Exchange Code" xml:lang="en">Description: Code specifying pallet exchange instructions</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="1"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="0" minOccurs="0" name="_81">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:R">
                                                                                                                      <xsd:minInclusive value="-9999999999"/>
                                                                                                                      <xsd:maxInclusive value="9999999999"/>
                                                                                                                      <xsd:totalDigits value="10"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_188">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="1"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_108">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Pick-up or Delivery Code" xml:lang="en">Description: Specifies the location or type of pickup or delivery</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="2"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                              </xsd:sequence>
                                                                                                            </xsd:extension>
                                                                                                          </xsd:complexContent>
                                                                                                        </xsd:complexType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element maxOccurs="10" minOccurs="0" name="L9">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Charge Detail" xml:lang="en">Purpose: To specify special charge code and the associated monetary amount
Semantics: L902 is the transportation charge for a special service performed, expressed in the standard monetary denomination for the currency specified.</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:complexType>
                                                                                                          <xsd:complexContent>
                                                                                                            <xsd:extension base="ansix12:Segment">
                                                                                                              <xsd:sequence>
                                                                                                                <xsd:element default="   " name="_150">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Special Charge or Allowance Code" xml:lang="en">Description: Code identifying type of special charge or allowance</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="3"/>
                                                                                                                      <xsd:minLength value="3"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="0" name="_782">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Monetary Amount" xml:lang="en">Description: Monetary amount</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:R">
                                                                                                                      <xsd:minInclusive value="-999999999999999999"/>
                                                                                                                      <xsd:maxInclusive value="999999999999999999"/>
                                                                                                                      <xsd:totalDigits value="18"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                              </xsd:sequence>
                                                                                                            </xsd:extension>
                                                                                                          </xsd:complexContent>
                                                                                                        </xsd:complexType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element maxOccurs="1" minOccurs="0" name="POD">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Proof of Delivery" xml:lang="en">Purpose: To provide proof of delivery</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:complexType>
                                                                                                          <xsd:complexContent>
                                                                                                            <xsd:extension base="ansix12:Segment">
                                                                                                              <xsd:sequence>
                                                                                                                <xsd:element default="        " name="_373">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Date" xml:lang="en">Description: Date expressed as CCYYMMDD</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:DT">
                                                                                                                      <xsd:length value="8"/>
                                                                                                                      <xsd:minLength value="8"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="    " minOccurs="0" name="_337">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Time" xml:lang="en">Description: Time expressed in 24-hour clock time as follows: HHMM, or HHMMSS, or HHMMSSD, or HHMMSSDD, where H = hours (00-23), M = minutes (00-59), S = integer seconds (00-59) and DD = decimal seconds; decimal seconds are expressed as follows: D = tenths (0-9) and DD = hundredths (00-99)</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="8"/>
                                                                                                                      <xsd:minLength value="4"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " name="_93">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Name" xml:lang="en">Description: Free-form name</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="60"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                              </xsd:sequence>
                                                                                                            </xsd:extension>
                                                                                                          </xsd:complexContent>
                                                                                                        </xsd:complexType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element maxOccurs="1" minOccurs="0" name="G62">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Date/Time" xml:lang="en">Purpose: To specify pertinent dates and times'
Syntax Rules:
R0103 : At least one of G6201 or G6203 is required.
P0102 : If either G6201 or G6202 is present, then the other is required.
P0304 : If either G6203 or G6204 is present, then the other is required.</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:complexType>
                                                                                                          <xsd:complexContent>
                                                                                                            <xsd:extension base="ansix12:Segment">
                                                                                                              <xsd:sequence>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_432">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Date Qualifier" xml:lang="en">Description: Code specifying type of date</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="2"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="        " minOccurs="0" name="_373">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Date" xml:lang="en">Description: Date expressed as CCYYMMDD</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:DT">
                                                                                                                      <xsd:length value="8"/>
                                                                                                                      <xsd:minLength value="8"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_176">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Time Qualifier" xml:lang="en">Description: Code specifying the reported time</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="2"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="    " minOccurs="0" name="_337">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Time" xml:lang="en">Description: Time expressed in 24-hour clock time as follows: HHMM, or HHMMSS, or HHMMSSD, or HHMMSSDD, where H = hours (00-23), M = minutes (00-59), S = integer seconds (00-59) and DD = decimal seconds; decimal seconds are expressed as follows: D = tenths (0-9) and DD = hundredths (00-99)</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="8"/>
                                                                                                                      <xsd:minLength value="4"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_623">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Time Code" xml:lang="en">Description: Code identifying the time. In accordance with International Standards Organization standard 8601, time can be specified by a + or - and an indication in hours in relation to Universal Time Coordinate (UTC) time; since + is a restricted character, + and - are substituted by P and M in the codes that follow</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="2"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                              </xsd:sequence>
                                                                                                            </xsd:extension>
                                                                                                          </xsd:complexContent>
                                                                                                        </xsd:complexType>
                                                                                                      </xsd:element>
                                                                                                    </xsd:sequence>
                                                                                                  </xsd:extension>
                                                                                                </xsd:complexContent>
                                                                                              </xsd:complexType>
                                                                                            </xsd:element>
                                                                                          </xsd:sequence>
                                                                                        </xsd:extension>
                                                                                      </xsd:complexContent>
                                                                                    </xsd:complexType>
                                                                                  </xsd:element>
                                                                                  <xsd:element maxOccurs="unbounded" minOccurs="0" name="S0465">
                                                                                    <xsd:annotation>
                                                                                      <xsd:documentation bic:title="Shipment Purchase Order Detail" xml:lang="en">Purpose: To specify the purchase order details for a shipment</xsd:documentation>
                                                                                    </xsd:annotation>
                                                                                    <xsd:complexType>
                                                                                      <xsd:complexContent>
                                                                                        <xsd:extension base="ansix12:SegmentGroup">
                                                                                          <xsd:sequence>
                                                                                            <xsd:element maxOccurs="1" minOccurs="0" name="SPO">
                                                                                              <xsd:annotation>
                                                                                                <xsd:documentation bic:title="Shipment Purchase Order Detail" xml:lang="en">Purpose: To specify the purchase order details for a shipment
Semantics: SPO02 is the department number.

SPO04 is the total quantity for the purchase order.

SPO06 is the total weight for the purchase order.

SPO07 indicates the data error condition relative to the shipment management information.

SPO08 is used to specify sorting and/or segregating reference numbers for each receiving location (processing area).

'
Syntax Rules:
P0304 : If either SPO03 or SPO04 is present, then the other is required.
P0506 : If either SPO05 or SPO06 is present, then the other is required.</xsd:documentation>
                                                                                              </xsd:annotation>
                                                                                              <xsd:complexType>
                                                                                                <xsd:complexContent>
                                                                                                  <xsd:extension base="ansix12:Segment">
                                                                                                    <xsd:sequence>
                                                                                                      <xsd:element default=" " name="_324">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Purchase Order Number" xml:lang="en">Description: Identifying number for Purchase Order assigned by the orderer/purchaser</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="22"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="30"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="  " minOccurs="0" name="_355">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="2"/>
                                                                                                            <xsd:minLength value="2"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_380">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-999999999999999"/>
                                                                                                            <xsd:maxInclusive value="999999999999999"/>
                                                                                                            <xsd:totalDigits value="15"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_188">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Weight Unit Code" xml:lang="en">Description: Code specifying the weight unit</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="1"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default="0" minOccurs="0" name="_81">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Weight" xml:lang="en">Description: Numeric value of weight</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:R">
                                                                                                            <xsd:minInclusive value="-9999999999"/>
                                                                                                            <xsd:maxInclusive value="9999999999"/>
                                                                                                            <xsd:totalDigits value="10"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_647">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Application Error Condition Code" xml:lang="en">Description: Code indicating application error condition</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="3"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element default=" " minOccurs="0" name="_127">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Reference Identification" xml:lang="en">Description: Reference information as defined for a particular Transaction Set or as specified by the Reference Identification Qualifier</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:simpleType>
                                                                                                          <xsd:restriction base="ansix12:AN">
                                                                                                            <xsd:length value="30"/>
                                                                                                            <xsd:minLength value="1"/>
                                                                                                          </xsd:restriction>
                                                                                                        </xsd:simpleType>
                                                                                                      </xsd:element>
                                                                                                      <xsd:element maxOccurs="10" minOccurs="0" name="SDQ">
                                                                                                        <xsd:annotation>
                                                                                                          <xsd:documentation bic:title="Destination Quantity" xml:lang="en">Purpose: To specify destination and quantity detail
Semantics: SDQ23 identifies the area within the location identified in SDQ03, SDQ05, SDQ07, SDQ09, SDQ11, SDQ13, SDQ15, SDQ17, SDQ19, and SDQ21.


Comments: SDQ02 is used only if different than previously defined in the transaction set.

SDQ03 is the store number.

SDQ23 may be used to identify areas within a store, e.g., front room, back room, selling outpost, end aisle display, etc. The value is agreed to by trading partners or industry conventions.

'
Syntax Rules:
P0506 : If either SDQ05 or SDQ06 is present, then the other is required.
P0708 : If either SDQ07 or SDQ08 is present, then the other is required.
P0910 : If either SDQ09 or SDQ10 is present, then the other is required.
P1112 : If either SDQ11 or SDQ12 is present, then the other is required.
P1314 : If either SDQ13 or SDQ14 is present, then the other is required.
P1516 : If either SDQ15 or SDQ16 is present, then the other is required.
P1718 : If either SDQ17 or SDQ18 is present, then the other is required.
P1920 : If either SDQ19 or SDQ20 is present, then the other is required.
P2122 : If either SDQ21 or SDQ22 is present, then the other is required.</xsd:documentation>
                                                                                                        </xsd:annotation>
                                                                                                        <xsd:complexType>
                                                                                                          <xsd:complexContent>
                                                                                                            <xsd:extension base="ansix12:Segment">
                                                                                                              <xsd:sequence>
                                                                                                                <xsd:element default="  " name="_355">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Unit or Basis for Measurement Code" xml:lang="en">Description: Code specifying the units in which a value is being expressed, or manner in which a measurement has been taken</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="2"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default=" " minOccurs="0" name="_66">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Identification Code Qualifier" xml:lang="en">Description: Code designating the system/method of code structure used for Identification Code (67)</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="2"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="  " name="_67">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Identification Code" xml:lang="en">Description: Code identifying a party or other code</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="80"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="0" name="_380">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:R">
                                                                                                                      <xsd:minInclusive value="-999999999999999"/>
                                                                                                                      <xsd:maxInclusive value="999999999999999"/>
                                                                                                                      <xsd:totalDigits value="15"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_67">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Identification Code" xml:lang="en">Description: Code identifying a party or other code</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="80"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="0" minOccurs="0" name="_380">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:R">
                                                                                                                      <xsd:minInclusive value="-999999999999999"/>
                                                                                                                      <xsd:maxInclusive value="999999999999999"/>
                                                                                                                      <xsd:totalDigits value="15"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_67">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Identification Code" xml:lang="en">Description: Code identifying a party or other code</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="80"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="0" minOccurs="0" name="_380">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:R">
                                                                                                                      <xsd:minInclusive value="-999999999999999"/>
                                                                                                                      <xsd:maxInclusive value="999999999999999"/>
                                                                                                                      <xsd:totalDigits value="15"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="  " minOccurs="0" name="_67">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Identification Code" xml:lang="en">Description: Code identifying a party or other code</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:AN">
                                                                                                                      <xsd:length value="80"/>
                                                                                                                      <xsd:minLength value="2"/>
                                                                                                                    </xsd:restriction>
                                                                                                                  </xsd:simpleType>
                                                                                                                </xsd:element>
                                                                                                                <xsd:element default="0" minOccurs="0" name="_380">
                                                                                                                  <xsd:annotation>
                                                                                                                    <xsd:documentation bic:title="Quantity" xml:lang="en">Description: Numeric value of quantity</xsd:documentation>
                                                                                                                  </xsd:annotation>
                                                                                                                  <xsd:simpleType>
                                                                                                                    <xsd:restriction base="ansix12:R">
                                                                                                                      <xsd:minInclusive value="-999999999999999"/>
                                                                                                                      <xsd:maxInclusive value="999999999999999"/>
                                                                                                                      <xsd:totalDigits value="15"/>
                                                                                                                      <xsd:minLength value="1"/>
                                                                                                                    </xsd:restriction>
